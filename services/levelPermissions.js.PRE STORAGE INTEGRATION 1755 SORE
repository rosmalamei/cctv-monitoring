/**
 * Initialize level_permissions table
 */
function initTable() {
    return new Promise((resolve) => {
        db.run(`CREATE TABLE IF NOT EXISTS level_permissions (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            level TEXT NOT NULL UNIQUE,
            permissions TEXT NOT NULL DEFAULT '{}',
            updated_at DATETIME DEFAULT CURRENT_TIMESTAMP
        )`, (err) => {
            if (err) {
                console.error('[Permissions] Table error:', err.message);
            }
            resolve();
        });
    });
}

/**
 * Get permissions for a specific level
 * Merges DB stored permissions with defaults
 */
function getLevelPermissions(level) {
    return new Promise((resolve) => {
        const lvl = (level || 'umum').toLowerCase();
        const defaults = DEFAULT_PERMISSIONS[lvl] || DEFAULT_PERMISSIONS.umum;
        
        db.get("SELECT permissions FROM level_permissions WHERE level = ?", [lvl], (err, row) => {
            if (err || !row) {
                resolve({ ...defaults });
            } else {
                try {
                    const stored = JSON.parse(row.permissions);
                    resolve({ ...defaults, ...stored });
                } catch (e) {
                    resolve({ ...defaults });
                }
            }
        });
    });
}

/**
 * Get all levels permissions
 */
function getAllPermissions() {
    return new Promise((resolve) => {
        const result = {};
        const levels = Object.keys(DEFAULT_PERMISSIONS);
        let pending = levels.length;
        
        levels.forEach(level => {
            getLevelPermissions(level).then(perms => {
                result[level] = perms;
                pending--;
                if (pending === 0) resolve(result);
            });
        });
    });
}

/**
 * Save permissions for a level
 */
function saveLevelPermissions(level, permissions) {
    return new Promise((resolve, reject) => {
        const lvl = (level || 'umum').toLowerCase();
        const json = JSON.stringify(permissions);
        
        db.run(
            `INSERT OR REPLACE INTO level_permissions (level, permissions, updated_at) VALUES (?, ?, CURRENT_TIMESTAMP)`,
            [lvl, json],
            (err) => {
                if (err) return reject(err);
                resolve({ success: true, level: lvl });
            }
        );
    });
}

/**
 * Check if a user level has access to a specific menu
 */
function canAccess(permissions, menuId) {
    if (!permissions) return false;
    return permissions[menuId] === true;
}

/**
 * Get groups for UI display
 */
function getMenuGroups() {
    const groups = {};
    MENU_DEFINITIONS.forEach(m => {
        if (!groups[m.group]) groups[m.group] = [];
        groups[m.group].push(m);
    });
    return groups;
}

module.exports = {
    DEFAULT_PERMISSIONS,
    MENU_DEFINITIONS,
    initTable,
    getLevelPermissions,
    getAllPermissions,
    saveLevelPermissions,
    canAccess,
    getMenuGroups
};