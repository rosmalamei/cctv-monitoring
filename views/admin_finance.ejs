<%- include('partials/admin_header', { title: 'Laporan Keuangan' }) %>
<%- include('partials/admin_sidebar', { page: 'finance' }) %>

<div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
    <div class="bg-gray-800 p-6 rounded-2xl border border-gray-700 shadow-xl">
        <p class="text-[10px] font-black text-gray-500 uppercase tracking-widest mb-1">Total Pendapatan</p>
        <h3 class="text-2xl font-bold text-emerald-400">Rp <%= stats.totalRevenue.toLocaleString('id-ID') %></h3>
    </div>
    <div class="bg-gray-800 p-6 rounded-2xl border border-gray-700 shadow-xl">
        <p class="text-[10px] font-black text-gray-500 uppercase tracking-widest mb-1">Transaksi Berhasil</p>
        <h3 class="text-2xl font-bold text-white"><%= stats.successCount %></h3>
    </div>
    <div class="bg-gray-800 p-6 rounded-2xl border border-gray-700 shadow-xl">
        <p class="text-[10px] font-black text-gray-500 uppercase tracking-widest mb-1">Menunggu Pembayaran</p>
        <h3 class="text-2xl font-bold text-amber-400"><%= stats.pendingCount %></h3>
    </div>
    <div class="bg-gray-800 p-6 rounded-2xl border border-gray-700 shadow-xl">
        <p class="text-[10px] font-black text-gray-500 uppercase tracking-widest mb-1">Bulan Ini</p>
        <h3 class="text-2xl font-bold text-blue-400">Rp <%= stats.monthlyRevenue.toLocaleString('id-ID') %></h3>
    </div>
</div>

<div class="bg-gray-800 rounded-2xl shadow-xl border border-gray-700 overflow-hidden">
    <div class="p-6 border-b border-gray-700 flex justify-between items-center">
        <h2 class="text-lg font-bold text-white uppercase tracking-wider">Riwayat Transaksi</h2>
        <div class="flex gap-2">
            <button onclick="exportFinance()" class="text-[10px] bg-gray-700 hover:bg-gray-600 text-white px-4 py-2 rounded-xl transition font-bold uppercase tracking-widest">Export CSV</button>
        </div>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-left text-sm">
            <thead>
                <tr class="text-gray-500 uppercase text-[10px] tracking-widest border-b border-gray-700 bg-gray-900/50 font-black">
                    <th class="p-4">Tanggal</th>
                    <th class="p-4">Pelanggan</th>
                    <th class="p-4">Paket</th>
                    <th class="p-4">Jumlah</th>
                    <th class="p-4">Status</th>
                    <th class="p-4 text-right">Aksi</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-700/50">
                <% transactions.forEach(function(t) { %>
                    <tr class="hover:bg-gray-700/30 transition group">
                        <td class="p-4 text-gray-500 text-xs">
                            <%= new Date(t.created_at).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
                        </td>
                        <td class="p-4">
                            <div class="font-bold text-white"><%= t.full_name || t.username %></div>
                            <div class="text-[10px] text-gray-500 font-mono">@<%= t.username %></div>
                        </td>
                        <td class="p-4 text-gray-400 text-xs">
                            <%= t.package_name %>
                        </td>
                        <td class="p-4 font-bold text-white">
                            Rp <%= t.amount.toLocaleString('id-ID') %>
                        </td>
                        <td class="p-4">
                            <span class="px-2 py-0.5 rounded-full text-[9px] font-black uppercase tracking-widest border
                                <%= t.payment_status === 'success' ? 'bg-emerald-900/40 text-emerald-400 border-emerald-500/20' : 
                                    t.payment_status === 'pending' ? 'bg-amber-900/40 text-amber-400 border-amber-500/20' : 
                                    'bg-rose-900/40 text-rose-400 border-rose-500/20' %>">
                                <%= t.payment_status.toUpperCase() %>
                            </span>
                        </td>
                        <td class="p-4 text-right">
                            <div class="flex justify-end gap-1 opacity-0 group-hover:opacity-100 transition">
                                <% if (t.proof_image) { %>
                                    <button onclick="viewProof('<%= t.id %>', '<%= t.proof_image %>', '<%= t.payment_status %>')" class="bg-gray-700 hover:bg-gray-600 text-white px-3 py-1.5 rounded-lg text-[9px] font-bold uppercase tracking-widest transition flex items-center gap-1">
                                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                                        Detail
                                    </button>
                                <% } %>
                                <button onclick="deleteTransaction('<%= t.id %>')" class="text-rose-500 hover:bg-rose-500/10 p-2 rounded-xl transition" title="Delete">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                </button>
                            </div>
                        </td>
                    </tr>
                <% }); %>
                <% if (transactions.length === 0) { %>
                    <tr>
                        <td colspan="6" class="p-8 text-center text-gray-500 italic text-xs">Belum ada riwayat transaksi.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<!-- Proof Detail Modal -->
<div id="proofModal" class="fixed inset-0 z-[100] hidden items-center justify-center p-4">
    <div class="absolute inset-0 bg-gray-950/95 backdrop-blur-md" onclick="closeProofModal()"></div>
    <div class="relative bg-gray-800 border border-gray-700 max-w-xl w-full rounded-[2.5rem] overflow-hidden shadow-2xl transform transition-all">
        <div class="p-6 border-b border-gray-700 flex justify-between items-center bg-gray-900/50">
            <div>
                <h3 class="text-sm font-black text-white uppercase tracking-widest">Detail Bukti Pembayaran</h3>
                <p id="modalTransId" class="text-[8px] text-gray-500 font-mono mt-1">ID: #000</p>
            </div>
            <button onclick="closeProofModal()" class="text-gray-400 hover:text-white transition p-2 bg-gray-700 rounded-full">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>
        
        <div class="p-4 bg-black flex justify-center min-h-[300px]">
            <img id="proofImageEl" class="max-h-[60vh] w-full object-contain">
        </div>

        <div class="p-6 bg-gray-900/80 border-t border-gray-700">
            <div id="adminActionButtons" class="flex gap-3">
                <button id="approveBtn" class="flex-1 bg-emerald-600 hover:bg-emerald-500 text-white font-black py-4 rounded-2xl transition shadow-xl shadow-emerald-900/40 uppercase tracking-widest text-[10px]">Terima & Aktifkan</button>
                <button id="rejectBtn" class="flex-1 bg-rose-600 hover:bg-rose-500 text-white font-black py-4 rounded-2xl transition shadow-xl shadow-rose-900/40 uppercase tracking-widest text-[10px]">Tolak Pembayaran</button>
            </div>
            <div id="statusBadge" class="hidden text-center py-4 text-[10px] font-black uppercase tracking-widest text-gray-500 italic">
                Status: <span id="statusLabel">SELESAI</span>
            </div>
        </div>
    </div>
</div>

<!-- Rejection Reason Modal -->
<div id="rejectReasonModal" class="fixed inset-0 z-[110] hidden items-center justify-center p-4">
    <div class="absolute inset-0 bg-gray-950/80 backdrop-blur-sm" onclick="closeRejectModal()"></div>
    <div class="relative bg-gray-800 border border-gray-700 max-w-sm w-full rounded-3xl p-8 shadow-2xl">
        <h4 class="text-lg font-black text-white mb-2 uppercase tracking-tight">Alasan Penolakan</h4>
        <p class="text-[10px] text-gray-500 mb-6 uppercase tracking-widest">Informasi ini akan dilihat oleh pelanggan</p>
        
        <textarea id="rejectReasonInput" class="w-full bg-gray-900 border border-gray-700 rounded-2xl p-4 text-sm text-white focus:border-rose-500 outline-none transition-all h-32 mb-6" placeholder="Contoh: Bukti transfer tidak terbaca / Nominal tidak sesuai..."></textarea>
        
        <div class="flex gap-3">
            <button onclick="closeRejectModal()" class="flex-1 py-3 bg-gray-700 text-white text-[10px] font-black uppercase rounded-xl tracking-widest">Batal</button>
            <button id="confirmRejectBtn" class="flex-1 py-3 bg-rose-600 text-white text-[10px] font-black uppercase rounded-xl tracking-widest">Kirim Penolakan</button>
        </div>
    </div>
</div>

<script>
    let activeTransId = null;

    function viewProof(id, img, status) {
        activeTransId = id;
        document.getElementById('modalTransId').innerText = 'ID: #' + id;
        const proofPath = img.includes('/') ? '<%= base_path %>/' + img : '<%= base_path %>/uploads/payments/' + img;
        document.getElementById('proofImageEl').src = proofPath;

        
        const actionBtn = document.getElementById('adminActionButtons');
        const badge = document.getElementById('statusBadge');
        const label = document.getElementById('statusLabel');

        if (status === 'pending') {
            actionBtn.classList.remove('hidden');
            badge.classList.add('hidden');
            
            document.getElementById('approveBtn').onclick = () => approveTransaction(id);
            document.getElementById('rejectBtn').onclick = () => openRejectModal(id);
        } else {
            actionBtn.classList.add('hidden');
            badge.classList.remove('hidden');
            label.innerText = status.toUpperCase();
        }

        document.getElementById('proofModal').classList.replace('hidden', 'flex');
    }

    function closeProofModal() {
        document.getElementById('proofModal').classList.replace('flex', 'hidden');
    }

    function openRejectModal(id) {
        activeTransId = id;
        document.getElementById('rejectReasonInput').value = '';
        document.getElementById('rejectReasonModal').classList.replace('hidden', 'flex');
        document.getElementById('confirmRejectBtn').onclick = () => processReject(id);
    }

    function closeRejectModal() {
        document.getElementById('rejectReasonModal').classList.replace('flex', 'hidden');
    }

    async function approveTransaction(id) {
        showModal("Konfirmasi pembayaran ini dan aktifkan paket pelanggan?", "confirm", async () => {
            const res = await fetch('<%= base_path %>/admin/finance/approve', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id })
            });
            if (res.ok) window.location.reload();
            else showModal('Gagal menyetujui transaksi', 'error');
        });
    }

    async function processReject(id) {
        const reason = document.getElementById('rejectReasonInput').value || 'Bukti pembayaran tidak valid';
        const res = await fetch('<%= base_path %>/admin/finance/reject', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id, reason })
        });
        if (res.ok) window.location.reload();
        else showModal('Gagal menolak transaksi', 'error');
    }

    async function deleteTransaction(id) {
        showModal("Hapus permanen data transaksi ini?", "confirm", async () => {
            const res = await fetch('<%= base_path %>/admin/finance/delete', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id })
            });
            if (res.ok) window.location.reload();
        });
    }

    function exportFinance() {
        showModal('Fitur Export sedang disiapkan.');
    }
</script>

<%- include('partials/admin_footer') %>
