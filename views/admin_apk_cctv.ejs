            template: 'rtsp://{username}:{password}@{uid}:554/Streaming/Channels/{channel}01',
            description: 'SPC DVR 4/8/16 channel. Gunakan Device ID/UID dari perangkat. Channel 1-4 untuk kamera 1-4. Ubah angka channel sesuai kamera yang ingin diakses.',
            tips: 'SPC banyak yang berbasis Hikvision. Untuk DVR 4 channel: channel1=kamera1, channel2=kamera2, dst. Cek UID di aplikasi SPC/INSNET atau stiker perangkat.'
        },
        tiandy: {
            name: 'Tiandy',
            app: 'Tiandy App / CloudSEE',
            method: 'p2p',
            hasVerification: false,
            template: 'rtsp://{username}:{password}@{uid}.tiandy.com:554/live/ch0',
            description: 'Tiandy menggunakan cloud P2P sendiri via CloudSEE. Serial Number dari perangkat.',
            tips: 'Aktifkan P2P di menu Network Tiandy. Serial ada di stiker perangkat.'
        },
        glenz: {
            name: 'Glenz',
            app: 'Glenz App / HDW',
            method: 'p2p',
            hasVerification: false,
            template: 'rtsp://{username}:{password}@{uid}:554/live/ch0',
            description: 'Glenz/HDW camera menggunakan P2P cloud dengan UID perangkat.',
            tips: 'UID bisa dicek di aplikasi Glenz atau menu Device Info.'
        }
    };

    let selectedApkBrand = null;
    let selectedApkMethod = 'p2p';

    // ========== METHOD SELECTION ==========
    function selectMethod(method) {
        selectedApkMethod = method;
        document.querySelectorAll('.method-card').forEach(c => c.classList.remove('active'));
        document.querySelector(`.method-card[data-method="${method}"]`).classList.add('active');
        document.getElementById('formMethod').value = method;
        
        // Show/hide fields
        document.getElementById('p2pFields').classList.toggle('hidden', method !== 'p2p');
        document.getElementById('ddnsFields').classList.toggle('hidden', method !== 'ddns');
        document.getElementById('publicFields').classList.toggle('hidden', method !== 'public');
        
        // Update info
        const info = {
            p2p: {
                title: 'P2P / Cloud',
                desc: 'Mirip aplikasi Android: masukkan UID/Serial Number kamera dan kredensial DVR. Sistem akan otomatis membuat URL akses yang bisa digunakan dari luar jaringan.'
            },
            ddns: {
                title: 'DDNS / Domain',
                desc: 'Gunakan domain/DDNS dan port forwarding untuk mengakses DVR dari luar. Pastikan port RTSP (554) sudah diforward di router.'
            },
            public: {
                title: 'IP Publik Langsung',
                desc: 'Jika DVR memiliki IP publik statis. Cukup masukkan IP dan port RTSP untuk akses langsung. Opsi ini kurang aman tanpa VPN.'
            }
        };
        
        document.getElementById('methodTitle').textContent = info[method].title;
        document.getElementById('methodDesc').textContent = info[method].desc;
    }

    // ========== BRAND SELECTION ==========
    function selectBrandApk(brand) {
        selectedApkBrand = brand;
        document.querySelectorAll('.brand-apk').forEach(c => c.classList.remove('border-emerald-500', 'bg-emerald-900/20'));
        const el = document.querySelector(`.brand-apk[data-brand="${brand}"]`);
        if (el) {
            el.classList.add('border-emerald-500', 'bg-emerald-900/20');
        }
        
        document.getElementById('formBrand').value = brand;
        const info = APK_BRANDS[brand];
        
        // Show verification code if needed
        document.getElementById('verificationField').classList.toggle('hidden', !info.hasVerification);
        
        // Update brand detail panel
        document.getElementById('apkBrandDetail').innerHTML = `
            <p><strong class="text-white">Merek:</strong> ${info.name}</p>
            <p><strong class="text-white">Aplikasi:</strong> ${info.app}</p>
            <p><strong class="text-white">Metode:</strong> ${info.method.toUpperCase()}</p>
            <div class="mt-2 p-2 bg-gray-950 rounded-lg">
                <p class="text-[10px] text-gray-500 mb-1">Template URL:</p>
                <code class="text-[10px] text-emerald-400 break-all font-mono">${info.template}</code>
            </div>
            <p class="mt-2 text-gray-500 text-[10px]">${info.description}</p>
            <p class="mt-1 text-amber-400 text-[10px]"><strong>Tips:</strong> ${info.tips}</p>
        `;
        
        // Auto-select method based on brand
        selectMethod(info.method);
    }

    // ========== SUBMIT FORM ==========
    document.getElementById('apkCctvForm').onsubmit = async (e) => {
        e.preventDefault();
        
        if (!selectedApkBrand) {
            showModal('Pilih merek perangkat terlebih dahulu', 'error');
            return;
        }
        
        const saveBtn = document.getElementById('apkSaveBtn');
        const saveText = document.getElementById('apkSaveText');
        saveBtn.disabled = true;
        saveBtn.innerHTML = '<span class="animate-spin">⟳</span> Menyimpan...';
        
        const brand = selectedApkBrand;
        const info = APK_BRANDS[brand];
        const name = document.getElementById('apkName').value;
        const location = document.getElementById('apkLocation').value;
        const username = document.getElementById('apkUsername').value;
        const password = document.getElementById('apkPassword').value;
        const uid = document.getElementById('apkUid').value;
        const verification = document.getElementById('apkVerification').value;
        const method = selectedApkMethod;
        
        // Build RTSP URL from template
        let url = info.template;
        url = url.replace(/\{username\}/g, encodeURIComponent(username));
        url = url.replace(/\{password\}/g, encodeURIComponent(password));
        url = url.replace(/\{verification\}/g, encodeURIComponent(verification || password));
        url = url.replace(/\{uid\}/g, uid);
        
        if (method === 'ddns' || method === 'public') {
            const domain = document.getElementById('apkDomain').value || document.getElementById('apkPublicIp').value;
            const port = document.getElementById('apkDomainPort').value || document.getElementById('apkPublicPort').value || '554';
            const channel = document.getElementById('apkDomainChannel').value || document.getElementById('apkPublicChannel').value || '1';
            url = url.replace(/\{domain\}/g, domain);
            url = url.replace(/\{port\}/g, port);
            url = url.replace(/\{channel\}/g, channel);
        } else {
            url = url.replace(/\{channel\}/g, '1');
            url = url.replace(/\{domain\}/g, uid);
            url = url.replace(/\{port\}/g, '554');
        }
        
        const formData = new URLSearchParams();
        formData.append('nama', name);
        formData.append('lokasi', location);
        formData.append('url_rtsp', url);
        formData.append('level', document.getElementById('apkLevel')?.value || 'umum');
        formData.append('camera_type', 'rtsp');
        
        try {
            const res = await fetch('<%= base_path %>/admin/camera/add', {
                method: 'POST',
                body: formData
            });
            
            if (res.ok) {
                showModal('✅ Perangkat berhasil ditambahkan!');
                setTimeout(() => {
                    window.location.href = '<%= base_path %>/admin/cameras';
                }, 1500);
            } else {
                const err = await res.text();
                showModal('Gagal: ' + err, 'error');
            }
        } catch (err) {
            showModal('Kesalahan: ' + err.message, 'error');
        } finally {
            saveBtn.disabled = false;
            saveBtn.innerHTML = '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path></svg> Tambah Perangkat';
        }
    };
</script>

<%- include('partials/admin_footer') %>