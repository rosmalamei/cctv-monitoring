<%- include('partials/admin_header', { title: 'APK CCTV - Tambah via Cloud/P2P' }) %>
<%- include('partials/admin_sidebar', { page: 'apk_cctv' }) %>

<style>
    .phone-frame {
        background: linear-gradient(145deg, #1c212c, #12151c);
        border: 2px solid #2d3544;
        border-radius: 32px;
        padding: 16px;
        position: relative;
        max-width: 380px;
        margin: 0 auto;
    }
    .phone-frame::before {
        content: '';
        position: absolute;
        top: 8px;
        left: 50%;
        transform: translateX(-50%);
        width: 120px;
        height: 6px;
        background: #2d3544;
        border-radius: 10px;
    }
    .phone-screen {
        border-radius: 24px;
        overflow: hidden;
        background: #0a0c10;
        min-height: 600px;
    }
    .apk-brand-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        font-weight: bold;
    }
    .input-group-apk {
        background: #12151c;
        border: 1px solid #2d3544;
    }
    .input-group-apk:focus-within {
        border-color: #10b981;
        box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1);
    }
    .method-card {
        background: #1c212c;
        border: 1px solid #2d3544;
        border-radius: 16px;
        padding: 16px;
        cursor: pointer;
        transition: all 0.3s;
    }
    .method-card:hover {
        border-color: #10b981;
        background: rgba(16, 185, 129, 0.05);
    }
    .method-card.active {
        border-color: #10b981;
        background: rgba(16, 185, 129, 0.1);
    }
    .cloud-badge {
        background: rgba(59, 130, 246, 0.15);
        border: 1px solid rgba(59, 130, 246, 0.3);
        color: #60a5fa;
    }
    .p2p-badge {
        background: rgba(139, 92, 246, 0.15);
        border: 1px solid rgba(139, 92, 246, 0.3);
        color: #a78bfa;
    }
    .device-card {
        background: #1c212c;
        border: 1px solid #2d3544;
        border-radius: 12px;
        transition: all 0.3s;
    }
    .device-card:hover {
        border-color: #10b981;
        transform: translateY(-1px);
    }
    @keyframes scanning {
        0% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.5; transform: scale(1.05); }
        100% { opacity: 1; transform: scale(1); }
    }
    .scanning-active {
        animation: scanning 1.5s ease-in-out infinite;
    }
</style>

<div class="animate-fade-in">
    <!-- Alert Penting -->
    <div class="bg-amber-900/20 border border-amber-500/30 rounded-2xl p-6 mb-8">
        <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-amber-500/20 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
            </div>
            <div>
                <h3 class="text-amber-400 font-bold text-sm">⚠️ PENTING! Cara Kerja UID/Cloud ID</h3>
                <p class="text-amber-200/70 text-xs mt-2"><strong class="text-white">UID P2P (seperti <code class="text-emerald-400">umksi759ryxi</code>) hanya bisa diakses oleh aplikasi resmi</strong> (SPC App, Hik-Connect, DMSS, CMS Windows, dll) karena menggunakan protokol proprietary/cloud P2P.</p>
                <p class="text-gray-400 text-xs mt-2">Server CCTV monitoring ini menggunakan <strong class="text-white">protokol RTSP standar</strong>, bukan protokol P2P. Jadi:</p>
                <ul class="text-xs text-gray-400 mt-2 space-y-1 list-disc list-inside">
                    <li>❌ <strong class="text-white">Tidak bisa</strong> menggunakan UID P2P langsung untuk streaming</li>
                    <li>✅ Gunakan <strong class="text-emerald-400">IP Lokal</strong> jika DVR satu jaringan dengan server</li>
                    <li>✅ Gunakan <strong class="text-emerald-400">IP Publik / DDNS</strong> dengan port forwarding untuk akses dari luar</li>
                    <li>✅ Atau scan jaringan lokal dengan tombol <strong class="text-cyan-400">"Cari DVR via ONVIF"</strong> di bawah</li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between mb-8">
        <div>
            <h1 class="text-2xl font-bold text-white flex items-center gap-3">
                <svg class="w-8 h-8 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
                </svg>
                Tambah Kamera via APK / Cloud
            </h1>
            <p class="text-gray-500 text-sm mt-1">Tambahkan DVR/CCTV seperti menggunakan aplikasi Android. Untuk akses RTSP, gunakan <strong class="text-emerald-400">IP Lokal</strong> atau <strong class="text-emerald-400">IP Publik/DDNS</strong> dengan port forwarding.</p>
        </div>
    </div>

    <!-- ============ METHOD SELECTION ============ -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
        <!-- Left: Phone Preview -->
        <div class="lg:col-span-2">
            <div class="bg-gray-800 rounded-2xl border border-gray-700 p-6">
                <div class="flex items-center justify-between mb-6">
                    <h2 class="text-lg font-bold text-white flex items-center gap-2">
                        <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
                        </svg>
                        Pilih Metode Koneksi
                    </h2>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
                    <!-- P2P / Cloud -->
                    <div class="method-card active" data-method="p2p" onclick="selectMethod('p2p')">
                        <div class="flex items-center gap-3 mb-3">
                            <div class="w-10 h-10 rounded-xl bg-purple-500/20 flex items-center justify-center">
                                <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"></path></svg>
                            </div>
                            <div>
                                <div class="text-white text-sm font-bold">P2P / Cloud</div>
                                <div class="text-[10px] text-gray-500">UID + Kredensial</div>
                            </div>
                        </div>
                        <p class="text-[10px] text-gray-500">Akses dari luar jaringan via cloud P2P. Contoh: Hik-Connect, DMSS, EZVIZ, V380</p>
                    </div>

                    <!-- DDNS / Domain -->
                    <div class="method-card" data-method="ddns" onclick="selectMethod('ddns')">
                        <div class="flex items-center gap-3 mb-3">
                            <div class="w-10 h-10 rounded-xl bg-blue-500/20 flex items-center justify-center">
                                <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path></svg>
                            </div>
                            <div>
                                <div class="text-white text-sm font-bold">DDNS / Domain</div>
                                <div class="text-[10px] text-gray-500">URL + Port</div>
                            </div>
                        </div>
                        <p class="text-[10px] text-gray-500">Gunakan domain/DDNS dan port forwarding. Contoh: dvr.rumahku.net:8555</p>
                    </div>

                    <!-- IP Publik -->
                    <div class="method-card" data-method="public" onclick="selectMethod('public')">
                        <div class="flex items-center gap-3 mb-3">
                            <div class="w-10 h-10 rounded-xl bg-green-500/20 flex items-center justify-center">
                                <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                            </div>
                            <div>
                                <div class="text-white text-sm font-bold">IP Publik Langsung</div>
                                <div class="text-[10px] text-gray-500">IP + Port RTSP</div>
                            </div>
                        </div>
                        <p class="text-[10px] text-gray-500">Jika DVR memiliki IP publik statis. Langsung konek via RTSP.</p>
                    </div>
                </div>

                <!-- Selected Method Description -->
                <div id="methodInfo" class="bg-gray-900/50 rounded-xl p-4 mb-6 border border-purple-500/20 flex items-start gap-3">
                    <div class="w-8 h-8 rounded-lg bg-purple-500/20 flex items-center justify-center shrink-0">
                        <svg class="w-4 h-4 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                    <div>
                        <div class="text-white text-sm font-bold" id="methodTitle">P2P / Cloud</div>
                        <div class="text-xs text-gray-400 mt-1" id="methodDesc">Mirip aplikasi Android: masukkan UID/Serial Number kamera dan kredensial DVR. Sistem akan otomatis membuat URL akses yang bisa digunakan dari luar jaringan.</div>
                    </div>
                </div>

                <!-- ============ SIMULASI APK ============ -->
                <div class="phone-frame">
                    <div class="phone-screen p-4">
                        <!-- Status Bar -->
                        <div class="flex items-center justify-between text-[10px] text-gray-500 mb-6 px-1">
                            <div class="font-bold text-white">9:41</div>
                            <div class="flex items-center gap-2">
                                <svg class="w-3 h-3 text-emerald-400" fill="currentColor" viewBox="0 0 24 24"><path d="M1 9l2 2c4.97-4.97 13.03-4.97 18 0l2-2C16.93 2.93 7.08 2.93 1 9zm8 8l3 3 3-3c-1.65-1.66-4.34-1.66-6 0zm-4-4l2 2c2.76-2.76 7.24-2.76 10 0l2-2C15.14 9.14 8.87 9.14 5 13z"></path></svg>
                                <svg class="w-3 h-3 text-gray-500" fill="currentColor" viewBox="0 0 24 24"><path d="M15.67 4H14V2h-4v2H8.33C7.6 4 7 4.6 7 5.33v15.33C7 21.4 7.6 22 8.33 22h7.33c.74 0 1.34-.6 1.34-1.33V5.33C17 4.6 16.4 4 15.67 4z"></path></svg>
                            </div>
                        </div>

                        <!-- App Header -->
                        <div class="text-center mb-6">
                            <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-emerald-500 to-emerald-700 flex items-center justify-center mx-auto mb-2 shadow-lg">
                                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
                            </div>
                            <h3 class="text-white text-sm font-bold">Tambah Perangkat</h3>
                            <p class="text-[10px] text-gray-500">Masukkan informasi perangkat DVR/CCTV Anda</p>
                        </div>

                        <!-- APK-Style Form -->
                        <form id="apkCctvForm" class="space-y-4">
                            <input type="hidden" name="method" id="formMethod" value="p2p">
                            <input type="hidden" name="brand" id="formBrand">
                            <input type="hidden" name="channel" id="formChannelHidden" value="1">
                            <input type="hidden" name="stream_type" id="formStreamTypeHidden" value="main">

                            <!-- Pilih Merek (APK Style) -->
                            <div>
                                <label class="text-[10px] font-black text-gray-500 uppercase tracking-widest mb-2 block">Pilih Merek DVR / Kamera</label>
                                <div class="grid grid-cols-4 gap-2">
                                    <div onclick="selectBrandApk('hikvision')" class="brand-apk bg-gray-900 rounded-xl border border-gray-700 p-2 text-center cursor-pointer hover:border-emerald-500 transition" data-brand="hikvision">
                                        <div class="w-8 h-8 mx-auto rounded-lg bg-gradient-to-br from-blue-600 to-blue-800 flex items-center justify-center mb-1">
                                            <span class="text-white text-[10px] font-bold">HK</span>
                                        </div>
                                        <div class="text-[9px] text-white font-bold">Hikvision</div>
                                    </div>
                                    <div onclick="selectBrandApk('dahua')" class="brand-apk bg-gray-900 rounded-xl border border-gray-700 p-2 text-center cursor-pointer hover:border-emerald-500 transition" data-brand="dahua">
                                        <div class="w-8 h-8 mx-auto rounded-lg bg-gradient-to-br from-orange-600 to-orange-800 flex items-center justify-center mb-1">
                                            <span class="text-white text-[10px] font-bold">DH</span>
                                        </div>
                                        <div class="text-[9px] text-white font-bold">Dahua</div>
                                    </div>
                                    <div onclick="selectBrandApk('ezviz')" class="brand-apk bg-gray-900 rounded-xl border border-gray-700 p-2 text-center cursor-pointer hover:border-emerald-500 transition" data-brand="ezviz">
                                        <div class="w-8 h-8 mx-auto rounded-lg bg-gradient-to-br from-emerald-600 to-emerald-800 flex items-center justify-center mb-1">
                                            <span class="text-white text-[10px] font-bold">EZ</span>
                                        </div>
                                        <div class="text-[9px] text-white font-bold">EZVIZ</div>
                                    </div>
                                    <div onclick="selectBrandApk('v380')" class="brand-apk bg-gray-900 rounded-xl border border-gray-700 p-2 text-center cursor-pointer hover:border-emerald-500 transition" data-brand="v380">
                                        <div class="w-8 h-8 mx-auto rounded-lg bg-gradient-to-br from-pink-600 to-pink-800 flex items-center justify-center mb-1">
                                            <span class="text-white text-[10px] font-bold">V3</span>
                                        </div>
                                        <div class="text-[9px] text-white font-bold">V380</div>
                                    </div>
                                    <div onclick="selectBrandApk('imou')" class="brand-apk bg-gray-900 rounded-xl border border-gray-700 p-2 text-center cursor-pointer hover:border-emerald-500 transition" data-brand="imou">
                                        <div class="w-8 h-8 mx-auto rounded-lg bg-gradient-to-br from-blue-500 to-blue-700 flex items-center justify-center mb-1">
                                            <span class="text-white text-[10px] font-bold">IM</span>
                                        </div>
                                        <div class="text-[9px] text-white font-bold">Imou</div>
                                    </div>
                                    <div onclick="selectBrandApk('tp_link')" class="brand-apk bg-gray-900 rounded-xl border border-gray-700 p-2 text-center cursor-pointer hover:border-emerald-500 transition" data-brand="tp_link">
                                        <div class="w-8 h-8 mx-auto rounded-lg bg-gradient-to-br from-teal-600 to-teal-800 flex items-center justify-center mb-1">
                                            <span class="text-white text-[10px] font-bold">TP</span>
                                        </div>
                                        <div class="text-[9px] text-white font-bold">Tapo</div>
                                    </div>
                                    <div onclick="selectBrandApk('reolink')" class="brand-apk bg-gray-900 rounded-xl border border-gray-700 p-2 text-center cursor-pointer hover:border-emerald-500 transition" data-brand="reolink">
                                        <div class="w-8 h-8 mx-auto rounded-lg bg-gradient-to-br from-green-600 to-green-800 flex items-center justify-center mb-1">
                                            <span class="text-white text-[10px] font-bold">RL</span>
                                        </div>
                                        <div class="text-[9px] text-white font-bold">Reolink</div>
                                    </div>
                                    <div onclick="selectBrandApk('wanscam')" class="brand-apk bg-gray-900 rounded-xl border border-gray-700 p-2 text-center cursor-pointer hover:border-emerald-500 transition" data-brand="wanscam">
                                        <div class="w-8 h-8 mx-auto rounded-lg bg-gradient-to-br from-red-600 to-red-800 flex items-center justify-center mb-1">
                                            <span class="text-white text-[10px] font-bold">WS</span>
                                        </div>
                                        <div class="text-[9px] text-white font-bold">Wanscam</div>
                                    </div>
                                    <div onclick="selectBrandApk('tengfei')" class="brand-apk bg-gray-900 rounded-xl border border-gray-700 p-2 text-center cursor-pointer hover:border-emerald-500 transition" data-brand="tengfei">
                                        <div class="w-8 h-8 mx-auto rounded-lg bg-gradient-to-br from-gray-600 to-gray-800 flex items-center justify-center mb-1">
                                            <span class="text-white text-[10px] font-bold">TF</span>
                                        </div>
                                        <div class="text-[9px] text-white font-bold">Tengfei</div>
                                    </div>
                                    <div onclick="selectBrandApk('spc')" class="brand-apk bg-gray-900 rounded-xl border border-gray-700 p-2 text-center cursor-pointer hover:border-emerald-500 transition" data-brand="spc">
                                        <div class="w-8 h-8 mx-auto rounded-lg bg-gradient-to-br from-red-700 to-red-900 flex items-center justify-center mb-1">
                                            <span class="text-white text-[10px] font-bold">SP</span>
                                        </div>
                                        <div class="text-[9px] text-white font-bold">SPC</div>
                                    </div>
                                    <div onclick="selectBrandApk('tiandy')" class="brand-apk bg-gray-900 rounded-xl border border-gray-700 p-2 text-center cursor-pointer hover:border-emerald-500 transition" data-brand="tiandy">
                                        <div class="w-8 h-8 mx-auto rounded-lg bg-gradient-to-br from-cyan-700 to-cyan-900 flex items-center justify-center mb-1">
                                            <span class="text-white text-[10px] font-bold">TD</span>
                                        </div>
                                        <div class="text-[9px] text-white font-bold">Tiandy</div>
                                    </div>
                                    <div onclick="selectBrandApk('glenz')" class="brand-apk bg-gray-900 rounded-xl border border-gray-700 p-2 text-center cursor-pointer hover:border-emerald-500 transition" data-brand="glenz">
                                        <div class="w-8 h-8 mx-auto rounded-lg bg-gradient-to-br from-amber-700 to-amber-900 flex items-center justify-center mb-1">
                                            <span class="text-white text-[10px] font-bold">GL</span>
                                        </div>
                                        <div class="text-[9px] text-white font-bold">Glenz</div>
                                    </div>
                                    <div onclick="selectBrandApk('axis')" class="brand-apk bg-gray-900 rounded-xl border border-gray-700 p-2 text-center cursor-pointer hover:border-emerald-500 transition" data-brand="axis">
                                        <div class="w-8 h-8 mx-auto rounded-lg bg-gradient-to-br from-yellow-600 to-yellow-800 flex items-center justify-center mb-1">
                                            <span class="text-white text-[10px] font-bold">AX</span>
                                        </div>
                                        <div class="text-[9px] text-white font-bold">Axis</div>
                                    </div>
                                    <div onclick="selectBrandApk('foscam')" class="brand-apk bg-gray-900 rounded-xl border border-gray-700 p-2 text-center cursor-pointer hover:border-emerald-500 transition" data-brand="foscam">
                                        <div class="w-8 h-8 mx-auto rounded-lg bg-gradient-to-br from-cyan-600 to-cyan-800 flex items-center justify-center mb-1">
                                            <span class="text-white text-[10px] font-bold">FC</span>
                                        </div>
                                        <div class="text-[9px] text-white font-bold">Foscam</div>
                                    </div>
                                    <div onclick="selectBrandApk('uniview')" class="brand-apk bg-gray-900 rounded-xl border border-gray-700 p-2 text-center cursor-pointer hover:border-emerald-500 transition" data-brand="uniview">
                                        <div class="w-8 h-8 mx-auto rounded-lg bg-gradient-to-br from-indigo-600 to-indigo-800 flex items-center justify-center mb-1">
                                            <span class="text-white text-[10px] font-bold">UN</span>
                                        </div>
                                        <div class="text-[9px] text-white font-bold">Uniview</div>
                                    </div>
                                </div>
                            </div>

                            <!-- Nama & Lokasi -->
                            <div class="grid grid-cols-2 gap-3">
                                <div>
                                    <label class="text-[10px] font-black text-gray-500 uppercase tracking-widest mb-1 block">Nama Kamera</label>
                                    <input type="text" id="apkName" required class="w-full bg-gray-900 border border-gray-700 rounded-xl px-4 py-3 text-white text-sm focus:outline-none focus:border-emerald-500 placeholder-gray-600" placeholder="Depan Rumah">
                                </div>
                                <div>
                                    <label class="text-[10px] font-black text-gray-500 uppercase tracking-widest mb-1 block">Lokasi</label>
                                    <input type="text" id="apkLocation" required class="w-full bg-gray-900 border border-gray-700 rounded-xl px-4 py-3 text-white text-sm focus:outline-none focus:border-emerald-500 placeholder-gray-600" placeholder="Ruang Tamu">
                                </div>
                            </div>

                            <!-- UID / IP / Domain (depend on method) -->
                            <div id="p2pFields">
                                <label class="text-[10px] font-black text-gray-500 uppercase tracking-widest mb-1 block">
                                    <span class="text-purple-400">🔑</span> UID / Serial Number / Cloud ID *
                                </label>
                                <div class="input-group-apk rounded-xl px-4 py-3 flex items-center gap-3">
                                    <svg class="w-5 h-5 text-gray-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 012-2h2a2 2 0 012 2v1m-4 0a2 2 0 012-2h2a2 2 0 012 2"></path></svg>
                                    <input type="text" id="apkUid" required class="flex-1 bg-transparent border-none text-white text-sm focus:outline-none placeholder-gray-600 font-mono" placeholder="Contoh: DS-2CD2T47G2-LIU12345678 atau UID1234567890">
                                </div>
                                <div id="uidHint" class="text-[10px] text-gray-500 mt-1 flex items-center gap-1">
                                    <svg class="w-3 h-3 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                    UID bisa ditemukan di stiker perangkat atau menu Info di APK resmi.
