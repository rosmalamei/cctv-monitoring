<!DOCTYPE html>
<html lang="id" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#0f172a">
    <link rel="manifest" href="<%= base_path %>/manifest.json">
    <link rel="icon" href="<%= base_path %>/icon-192x192.png">
    <link rel="apple-touch-icon" href="<%= base_path %>/icon-192x192.png">
    <title><%= title %> | CCTV Admin Dashboard</title>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    
    <!-- CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="<%= base_path %>/css/leaflet.css" />
    <script src="<%= base_path %>/js/leaflet.js"></script>
    <script src="<%= base_path %>/js/hls.min.js"></script>
    
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Plus Jakarta Sans', 'sans-serif'],
                        mono: ['JetBrains Mono', 'monospace'],
                    },
                    colors: {
                        gray: {
                            950: '#0a0c10',
                            900: '#12151c',
                            800: '#1c212c',
                            700: '#2d3544',
                        }
                    }
                }
            }
        }
    </script>

    <style>
        body { 
            background-color: #0a0c10; 
            color: #e2e8f0;
            -webkit-font-smoothing: antialiased;
        }
        
        .custom-scrollbar::-webkit-scrollbar {
            width: 4px;
            height: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: transparent;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #2d3544;
            border-radius: 10px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: #3b4455;
        }

        .glass-panel {
            background: rgba(28, 33, 44, 0.7);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        .animate-fade-in {
            animation: fadeIn 0.4s ease-out forwards;
        }
    </style>
</head>
<body class="bg-gray-950 min-h-screen text-gray-200 font-sans selection:bg-emerald-500/30 selection:text-emerald-400">
    <!-- Global Modal remains in body but I'll move it to a partial if needed -->
    <%- include('global_modal') %>

    <div class="flex h-screen overflow-hidden">
