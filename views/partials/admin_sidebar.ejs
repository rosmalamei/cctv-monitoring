        <div class="mb-1 sidebar-group">
            <div class="section-title">
                <span class="text-[9px] font-black text-gray-500 uppercase tracking-[0.2em] px-3 py-1 block select-none" style="transition: opacity 0.2s ease;">Manajemen</span>
            </div>
            <%- renderMenuItem(base_path, 'admin/customers', 'customers', page, '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>', 'Pelanggan') %>
            <%- renderMenuItem(base_path, 'admin/permissions', 'permissions', page, '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>', 'Permission') %>
            <%- renderMenuItem(base_path, 'admin/billing', 'billing', page, '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>', 'Billing') %>
            <%- renderMenuItem(base_path, 'admin/finance', 'finance', page, '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>', 'Keuangan') %>
