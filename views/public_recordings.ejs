<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="theme-color" content="#020617">
    <title><%= site.title %> - Rekaman</title>
    
    <!-- Fonts & CSS -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    animation: {
                        'fade-in': 'fadeIn 0.3s ease-out forwards',
                        'slide-up': 'slideUp 0.4s ease-out forwards',
                    },
                    keyframes: {
                        fadeIn: { '0%': { opacity: '0' }, '100%': { opacity: '1' } },
                        slideUp: { '0%': { opacity: '0', transform: 'translateY(10px)' }, '100%': { opacity: '1', transform: 'translateY(0)' } }
                    }
                }
            }
        }
    </script>
    
    <style>
        body { background-color: #020617; color: #f8fafc; font-family: 'Inter', sans-serif; -webkit-tap-highlight-color: transparent; }
        .glass-panel { background: rgba(15, 23, 42, 0.6); backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.05); }
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        
        .camera-item.active { border-color: #10b981; background: rgba(16, 185, 129, 0.1); }
        .recording-item.active { background: rgba(16, 185, 129, 0.1); border-color: #10b981; }
        
        .video-wrapper { position: relative; width: 100%; aspect-ratio: 16 / 9; background: #000; overflow: hidden; border-bottom: 1px solid #1e293b; }
        @media (min-width: 1024px) {
            .video-wrapper { border-radius: 0; border: 1px solid #1e293b; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5); margin: 0; aspect-ratio: auto; flex: 1; }
        }
        .video-wrapper video { width: 100%; height: 100%; object-fit: cover; }
        @media (min-width: 1024px) {
            .video-wrapper video { object-fit: contain; }
        }

        .date-btn.active { background: #10b981; color: #020617; }
        
        .camera-list-item.active { background: #10b981; color: #020617; }
        .camera-list-item.active svg { color: #020617; }
        
        .sidebar-scroll::-webkit-scrollbar { width: 4px; }
        .sidebar-scroll::-webkit-scrollbar-track { background: transparent; }
        .sidebar-scroll::-webkit-scrollbar-thumb { background: #1e293b; border-radius: 10px; }

        /* Responsive Sidebar */
        #camera-sidebar { position: fixed; inset: 0 0 0 0; width: 100%; z-index: 150; visibility: hidden; transition: visibility 0.3s; }
        #camera-sidebar.open { visibility: visible; }
        
        .sidebar-overlay { position: absolute; inset: 0; background: rgba(2, 6, 23, 0.8); backdrop-filter: blur(4px); opacity: 0; transition: opacity 0.3s; }
        #camera-sidebar.open .sidebar-overlay { opacity: 1; }
        
        .sidebar-content { position: absolute; inset: 0 auto 0 0; width: 280px; background: #0f172a; transform: translateX(-100%); transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1); display: flex; flex-direction: column; }
        #camera-sidebar.open .sidebar-content { transform: translateX(0); }

        @media (min-width: 1024px) {
            #camera-sidebar { position: relative; width: 288px; visibility: visible; z-index: 10; inset: auto; height: 100%; }
            .sidebar-overlay { display: none; }
            .sidebar-content { position: relative; width: 100%; transform: none; inset: auto; height: 100%; }
        }

        /* Bottom Bar */
        .bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; height: 56px; background: rgba(15, 23, 42, 0.95); backdrop-filter: blur(16px); border-top: 1px solid rgba(255,255,255,0.05); display: flex; align-items: center; px: 1rem; z-index: 80; }
        
        /* Hide Scrollbars */
        #dateScroll::-webkit-scrollbar { display: none; }
        #dateScroll { -ms-overflow-style: none; scrollbar-width: none; }
    </style>
</head>
<body class="antialiased h-screen flex flex-col overflow-hidden">

    <!-- Header Navigation (Same as index.ejs) -->
    <nav class="bg-slate-900/90 backdrop-blur-md border-b border-slate-800 flex-none h-14 lg:h-16 flex items-center z-50">
        <div class="w-full px-4 lg:px-6 flex justify-between items-center gap-4">
            <!-- Left: Brand -->
            <div class="flex items-center gap-4 cursor-pointer" onclick="window.location.href='<%= base_path %>/'">
                <div class="hidden lg:flex p-2 bg-emerald-500/20 rounded-lg">
                    <svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
                </div>
                <div>
                    <h1 class="text-sm font-black text-white tracking-tight uppercase leading-none"><%= site.title %></h1>
                    <p class="text-[9px] text-slate-500 font-bold uppercase tracking-widest mt-1"><%= site.footer %></p>
                </div>
            </div>

            <!-- Middle/Right: Nav & Weather -->
            <div class="flex items-center gap-2 lg:gap-3">
                <!-- Desktop Clock & Status -->
                <div class="hidden lg:flex items-center gap-4 px-4 py-1.5 bg-slate-950/50 rounded-xl border border-slate-800/50 mr-2">
                    <div class="flex items-center gap-3">
                        <span id="topbar-clock" class="text-sm font-black text-white leading-none tracking-tighter">00:00:00</span>
                        <div class="w-px h-3 bg-slate-800"></div>
                        <span id="topbar-date" class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">01 Januari 2026</span>
                    </div>
                    <div class="h-6 w-px bg-slate-800"></div>
                    <div class="flex items-center gap-2">
                        <div class="w-2 h-2 bg-emerald-500 rounded-full blink"></div>
                        <span class="text-[9px] font-black text-slate-300 uppercase tracking-widest">Server Live</span>
                    </div>
                </div>

                <!-- Mobile Date Button -->
                <button onclick="showTimeModal()" class="lg:hidden flex items-center justify-center w-9 h-9 bg-slate-800 text-white rounded-xl border border-slate-700 shadow-lg active:scale-95 transition">
                    <span id="mobile-date-num" class="text-sm font-black"><%= new Date().getDate() %></span>
                </button>

                <div class="hidden lg:flex items-center gap-2 border-r border-slate-800 pr-4 mr-2">
                    <a href="<%= base_path %>/" class="px-4 py-2 text-[10px] font-black text-slate-400 uppercase tracking-widest hover:text-white transition">Live Dashboard</a>
                    <a href="<%= base_path %>/user/account" class="px-4 py-2 bg-slate-800 text-white text-[10px] font-black rounded-lg uppercase tracking-widest border border-slate-700 hover:bg-slate-700 transition">Akun Saya</a>
                </div>
                <!-- Weather -->
                <div id="weather-widget" onclick="showWeatherDetail()" class="flex items-center gap-2 px-3 py-1.5 bg-slate-800/50 hover:bg-slate-700/50 cursor-pointer rounded-xl border border-slate-700/50 transition duration-300">
                    <span id="weather-icon" class="text-sm">🌤️</span>
                    <span id="weather-temp" class="text-xs font-bold text-slate-200">--°C</span>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content Area -->
    <div class="flex-1 flex flex-col lg:flex-row overflow-hidden relative">
        
        <!-- Sidebar: Camera List -->
        <aside id="camera-sidebar">
            <div class="sidebar-overlay" onclick="toggleCameraSidebar()"></div>
            <div class="sidebar-content border-r border-slate-800">
                <div class="p-4 border-b border-slate-800 flex items-center justify-between lg:hidden bg-slate-900/50">
                    <h2 class="text-xs font-black text-white uppercase tracking-widest">Daftar Kamera</h2>
                    <button onclick="toggleCameraSidebar()" class="p-2 hover:bg-slate-800 rounded-lg text-slate-500 transition">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                    </button>
                </div>
                <div class="p-3 border-b border-slate-800 flex-none">
                    <div class="relative">
                        <input type="text" oninput="filterCameras(this.value)" placeholder="Cari Kamera..." 
                            class="w-full bg-slate-950 border border-slate-800 rounded-xl px-9 py-2.5 text-[10px] text-white focus:border-emerald-500 transition-all focus:outline-none uppercase font-bold">
                        <svg class="w-3.5 h-3.5 text-slate-600 absolute left-3 top-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                    </div>
                </div>
                <div class="flex-1 overflow-y-auto sidebar-scroll p-2 space-y-1 pb-24">
                    <% if (cameras && cameras.length > 0) { %>
                        <% cameras.forEach(cam => { 
                            const camLevel = (cam.level || 'umum').toLowerCase();
                            const levelColors = {
                                'umum': 'text-emerald-500',
                                'member': 'text-blue-500',
                                'vip': 'text-purple-500',
                                'vvip': 'text-orange-500',
                                'pemerintahan': 'text-sky-400',
                                'admin': 'text-rose-500'
                            };
                            const colorClass = levelColors[camLevel] || 'text-slate-500';
                        %>
                            <div class="camera-list-item px-3 py-2.5 rounded-lg flex items-center gap-3 cursor-pointer hover:bg-slate-800 transition group"
                                data-id="<%= cam.id %>" data-nama="<%= cam.nama %>" onclick="selectCamera('<%= cam.id %>', '<%= cam.nama %>')">
                                <div class="w-7 h-7 bg-slate-950 rounded flex items-center justify-center border border-slate-800 group-hover:border-emerald-500/50 transition">
                                    <svg class="w-3.5 h-3.5 text-slate-600 group-hover:text-emerald-500 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
                                </div>
                                <div class="flex-1 min-w-0">
                                    <p class="text-[10px] lg:text-[12px] font-black text-white uppercase tracking-tight truncate"><%= cam.nama %></p>
                                    <p class="text-[8px] lg:text-[10px] text-sky-400 font-bold uppercase truncate"><%= cam.lokasi %></p>
                                    <span class="text-[7px] lg:text-[9px] font-black <%= colorClass %> uppercase tracking-widest block mt-0.5">
                                        <%= camLevel === 'umum' ? 'UMUM' : camLevel === 'member' ? 'MEMBER' : camLevel.toUpperCase() %>
                                    </span>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="py-10 text-center opacity-30">
                            <p class="text-[9px] font-black uppercase tracking-widest">Kamera tidak tersedia</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </aside>

        <!-- Player Section (Middle on Desktop) -->
        <main class="flex-none lg:flex-1 flex flex-col overflow-hidden bg-slate-950 relative border-b lg:border-b-0 lg:border-r border-slate-800 lg:pb-0 lg:p-6">
            <div class="video-wrapper" id="player-container">
                <video id="main-player" controls preload="metadata" class="hidden w-full h-full"></video>
                <div id="player-placeholder" class="absolute inset-0 flex flex-col items-center justify-center text-slate-800 gap-6">
                    <svg class="w-20 h-20 opacity-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    <p class="text-[9px] font-black uppercase tracking-[0.3em] opacity-30">Pilih Rekaman Untuk Diputar</p>
                </div>
            </div>
            <!-- Playback Speed Control - Moved outside video-wrapper to prevent overlapping on mobile -->
            <div id="speed-control" class="flex-none bg-slate-900 border-b border-slate-800 lg:border lg:rounded-xl p-2 flex items-center justify-center gap-2 z-10 hidden lg:mt-4 lg:mx-0">
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest px-2">Kecepatan:</span>
                <div class="flex items-center gap-1">
                    <button onclick="setPlaybackSpeed(0.5)" class="speed-btn px-2.5 py-1.5 text-[10px] font-bold text-slate-400 hover:text-white hover:bg-slate-800 rounded-lg transition" data-speed="0.5">0.5x</button>
                    <button onclick="setPlaybackSpeed(1)" class="speed-btn px-2.5 py-1.5 text-[10px] font-bold text-white bg-emerald-500/20 border border-emerald-500/50 rounded-lg transition active" data-speed="1">1x</button>
                    <button onclick="setPlaybackSpeed(1.5)" class="speed-btn px-2.5 py-1.5 text-[10px] font-bold text-slate-400 hover:text-white hover:bg-slate-800 rounded-lg transition" data-speed="1.5">1.5x</button>
                    <button onclick="setPlaybackSpeed(2)" class="speed-btn px-2.5 py-1.5 text-[10px] font-bold text-slate-400 hover:text-white hover:bg-slate-800 rounded-lg transition" data-speed="2">2x</button>
                </div>
            </div>
        </main>

        <!-- Sidebar: Recording List (Right on Desktop) -->
        <aside class="flex-1 lg:flex-none flex flex-col overflow-hidden lg:w-[320px] bg-slate-900/20 lg:pb-0 border-l border-slate-800">
            <!-- Calendar Section -->
            <div class="bg-slate-900 border-b border-slate-800 flex flex-col p-3 gap-2">
                <div class="flex items-center justify-between">
                    <h3 class="text-[10px] font-black text-slate-500 uppercase tracking-widest">Kalender</h3>
                    <div class="flex items-center gap-2">
                        <select id="monthSelect" onchange="generateDates()" class="bg-slate-800 px-2 py-1.5 rounded-lg text-[10px] font-black text-white uppercase focus:outline-none cursor-pointer border border-slate-700">
                            <% 
                                const months = ['Januari', 'Februari', 'Maret', 'April', 'Mei', 'Juni', 'Juli', 'Agustus', 'September', 'Oktober', 'November', 'Desember'];
                                const now = new Date();
                                months.forEach((m, i) => { %>
                                <option value="<%= i %>" <%= i === now.getMonth() ? 'selected' : '' %>><%= m %></option>
                            <% }) %>
                        </select>
                        <a id="downloadBtn" href="#" download class="hidden p-1.5 bg-emerald-500 text-slate-950 rounded-lg hover:bg-emerald-400 transition shadow-lg shadow-emerald-500/20">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                        </a>
                    </div>
                </div>
                <div id="dateScroll" class="flex items-center gap-2 overflow-x-auto sidebar-scroll py-1"></div>
            </div>

            <div class="p-3 border-b border-slate-800 flex justify-between items-center bg-slate-950/30">
                <h3 class="text-[10px] font-black text-white uppercase tracking-widest" id="recording-title">Rekaman</h3>
                <span id="recording-count" class="text-[9px] font-bold text-emerald-500 bg-emerald-500/10 px-2 py-0.5 rounded-full">0</span>
            </div>

            <!-- Scrollable List of Recordings -->
            <div class="flex-1 overflow-y-auto sidebar-scroll pb-24">
                <div id="recording-list" class="divide-y divide-slate-800/50">
                    <!-- Recordings injected here -->
                </div>
                <div id="recording-empty" class="hidden py-20 flex flex-col items-center justify-center opacity-20">
                    <svg class="w-10 h-10 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    <p class="text-[9px] font-black uppercase tracking-widest">Tidak ada rekaman</p>
                </div>
            </div>
        </aside>
    </div>

    <!-- Mobile Bottom Navigation -->
    <div class="lg:hidden fixed bottom-0 left-0 right-0 h-14 bg-slate-900/95 backdrop-blur-xl border-t border-slate-800 flex items-center justify-around px-2 z-[100] shadow-[0_-10px_30px_-15px_rgba(0,0,0,0.5)]">
        <button onclick="toggleCameraSidebar()" class="flex flex-col items-center gap-1 px-3 group text-slate-500">
            <div class="p-1.5 rounded-xl transition-all duration-300">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
            </div>
            <span class="text-[8px] font-black uppercase tracking-widest">Kamera</span>
        </button>

        <a href="<%= base_path %>/" class="flex flex-col items-center gap-1 px-3 group text-slate-500">
            <div class="p-1.5 rounded-xl transition-all duration-300">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
            </div>
            <span class="text-[8px] font-black uppercase tracking-widest">Live</span>
        </a>
        
        <div class="flex flex-col items-center gap-1 px-3 group text-emerald-500">
            <div class="p-1.5 rounded-xl bg-emerald-500 text-slate-950 shadow-lg shadow-emerald-500/20">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <span class="text-[8px] font-black uppercase tracking-widest">Rekaman</span>
        </div>

        <button onclick="window.location.href='<%= base_path %>/user/account'" class="flex flex-col items-center gap-1 px-3 group text-slate-500">
            <div class="p-1.5 rounded-xl">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
            </div>
            <span class="text-[8px] font-black uppercase tracking-widest">Akun</span>
        </button>
    </div>

    <!-- Time Modal (Mobile) -->
    <div id="timeModal" onclick="closeTimeModal()" class="fixed inset-0 z-[120] hidden items-center justify-center p-4 bg-slate-950/80 backdrop-blur-md animate-fade-in">
        <div onclick="event.stopPropagation()" class="bg-slate-900 border border-slate-800 w-full max-w-xs rounded-3xl shadow-2xl overflow-hidden p-8 flex flex-col items-center gap-6">
            <div class="w-16 h-16 bg-emerald-500/10 rounded-2xl flex items-center justify-center">
                <svg class="w-8 h-8 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <div class="text-center">
                <h2 id="modal-clock" class="text-4xl font-black text-white tracking-tighter mb-1">00:00:00</h2>
                <p id="modal-date" class="text-[10px] font-bold text-slate-500 uppercase tracking-[0.2em]">01 Januari 2026</p>
            </div>
            <div class="w-full h-px bg-slate-800"></div>
            <div class="flex items-center gap-3">
                <div class="w-2 h-2 bg-emerald-500 rounded-full blink"></div>
                <span class="text-[10px] font-black text-slate-300 uppercase tracking-widest">Server Live Status</span>
            </div>
            <button onclick="closeTimeModal()" class="mt-4 w-full py-3 bg-slate-800 text-white text-[10px] font-black rounded-xl uppercase tracking-widest hover:bg-slate-700 transition">Tutup</button>
        </div>
    </div>
    
    <!-- Weather Modal -->
    <div id="weatherModal" onclick="closeWeatherModalOnBackdrop(event)" class="fixed inset-0 z-[100] hidden items-center justify-center p-4 bg-slate-950/80 backdrop-blur-sm animate-fade-in">
        <div class="bg-slate-900 border border-slate-800 w-full max-w-lg rounded-3xl shadow-2xl overflow-hidden flex flex-col max-h-[90vh]" onclick="event.stopPropagation()">
            <div class="p-6 border-b border-slate-800 flex justify-between items-center bg-slate-900 sticky top-0 z-10">
                <div class="flex items-center gap-3">
                    <div class="p-2 bg-cyan-500/20 rounded-xl"><svg class="w-6 h-6 text-cyan-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg></div>
                    <div><h3 class="text-sm font-bold text-white uppercase tracking-widest">Detail Cuaca</h3></div>
                </div>
                <button onclick="closeWeatherModal()" class="p-2 hover:bg-slate-800 rounded-xl text-slate-500 hover:text-white transition"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg></button>
            </div>
            <div class="flex-1 overflow-y-auto sidebar-scroll p-8 space-y-8">
                <div id="modal-weather-content" class="flex flex-col gap-6"></div>
            </div>
            
            <!-- Tombol Kembali -->
            <div class="p-6 border-t border-slate-800 bg-slate-900 sticky bottom-0 z-10">
                <button onclick="closeWeatherModal()" class="w-full py-3 bg-slate-800 hover:bg-slate-700 text-white rounded-xl font-bold transition flex items-center justify-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                    TUTUP
                </button>
            </div>
        </div>
    </div>


    <script id="data-recordings" type="application/json"><%- JSON.stringify(recordings || []) %></script>
    <script id="data-initial-state" type="application/json"><%- JSON.stringify({ filterDate: (typeof filterDate !== 'undefined' ? filterDate : ''), filterCameraId: (typeof filterCameraId !== 'undefined' ? filterCameraId : '') }) %></script>
    <script>
        let allRecordings = JSON.parse(document.getElementById('data-recordings').textContent);
        const initialState = JSON.parse(document.getElementById('data-initial-state').textContent);
        const basePath = '<%= base_path %>';
        const isAdmin = <%= isAdmin ? 'true' : 'false' %>;
        const player = document.getElementById('main-player');
        
        // --- Sidebar Logic ---
        function toggleCameraSidebar() {
            const sidebar = document.getElementById('camera-sidebar');
            sidebar.classList.toggle('open');
            document.body.classList.toggle('modal-open');
        }

        function filterCameras(term) {
            term = term.toLowerCase();
            document.querySelectorAll('.camera-list-item').forEach(item => {
                const name = (item.dataset.nama || '').toLowerCase();
                const location = (item.querySelector('p:nth-child(2)')?.textContent || '').toLowerCase();
                const level = (item.querySelector('span')?.textContent || '').toLowerCase();
                const matches = name.includes(term) || location.includes(term) || level.includes(term);
                item.style.display = matches ? 'flex' : 'none';
            });
        }

        // Initialize state from server or defaults
        let selectedCamId = initialState.filterCameraId || null;
        
        function getLocalDateString() {
            const now = new Date();
            const year = now.getFullYear();
            const month = String(now.getMonth() + 1).padStart(2, '0');
            const day = String(now.getDate()).padStart(2, '0');
            return `${year}-${month}-${day}`;
        }

        // Always prefer server-side date to avoid timezone mismatches on mobile
        let selectedDate = initialState.filterDate || getLocalDateString();
        let isLoading = false;

        // --- Weather Logic ---
        async function updateWeather() {
            try {
                const res = await fetch(`${basePath}/api/weather`);
                const data = await res.json();
                if (data && data.success && data.current) {
                    const temp = Math.round(data.current.temperature_2m);
                    const code = data.current.weather_code;
                    document.getElementById('weather-temp').textContent = `${temp}°C`;
                    const weatherMap = { 0: '☀️', 1: '🌤️', 2: '⛅', 3: '☁️', 45: '🌫️', 51: '🌧️', 61: '🌧️', 80: '🌦️', 95: '⛈️' };
                    document.getElementById('weather-icon').textContent = weatherMap[code] || '🌤️';
                    window.currentWeather = data;
                }
            } catch (e) { }
        }

        async function showWeatherDetail() {
            const content = document.getElementById('modal-weather-content');
            content.innerHTML = '<div class="py-20 flex justify-center"><div class="w-8 h-8 border-4 border-emerald-500 border-t-transparent rounded-full animate-spin"></div></div>';
            document.getElementById('weatherModal').classList.remove('hidden');
            document.getElementById('weatherModal').classList.add('flex');

            try {
                const res = await fetch(`${basePath}/api/weather`);
                const data = await res.json();
                
                if (!data.success || !data.data) {
                    content.innerHTML = '<div class="py-20 text-center text-slate-400">Gagal memuat data cuaca</div>';
                    return;
                }
                
                const weatherData = data.data;
                const marine = weatherData.marine_hourly || {};
                
                // Helper function untuk konversi derajat ke kompas
                function degToCompass(deg) {
                    const dirs = ['U', 'TL', 'T', 'TG', 'S', 'BD', 'B', 'BL'];
                    return dirs[Math.round(deg / 45) % 8];
                }
                
                // Data maritim saat ini
                let marineCurrentHtml = '';
                if (marine && marine.wave_height && marine.wave_height.length > 0) {
                    const waveHeight = marine.wave_height[0] || 0;
                    const wavePeriod = marine.wave_period ? marine.wave_period[0] : 0;
                    const waveDirection = marine.wave_direction ? marine.wave_direction[0] : 0;
                    const seaTemp = marine.sea_surface_temperature ? marine.sea_surface_temperature[0] : null;
                    const oceanCurrent = marine.ocean_current_velocity ? marine.ocean_current_velocity[0] : null;
                    const oceanCurrentDir = marine.ocean_current_direction ? marine.ocean_current_direction[0] : null;
                    const seaLevel = marine.sea_level_height_msl ? marine.sea_level_height_msl[0] : null;
                    
                    // Status keamanan laut
                    let statusIcon = '🟢';
                    let statusText = 'Laut Tenang';
                    let statusDesc = 'Aman untuk semua aktivitas maritim';
                    let statusColor = 'from-emerald-500/20 to-emerald-600/10 border-emerald-500/30';
                    
                    if (waveHeight >= 2.5) {
                        statusIcon = '🔴';
                        statusText = 'Laut Sangat Bergelombang';
                        statusDesc = 'Berbahaya - Hindari pelayaran';
                        statusColor = 'from-rose-500/20 to-rose-600/10 border-rose-500/30';
                    } else if (waveHeight >= 1.25) {
                        statusIcon = '🟠';
                        statusText = 'Laut Bergelombang';
                        statusDesc = 'Tidak disarankan untuk kapal kecil';
                        statusColor = 'from-orange-500/20 to-orange-600/10 border-orange-500/30';
                    } else if (waveHeight >= 0.5) {
                        statusIcon = '🟡';
                        statusText = 'Laut Sedikit Bergelombang';
                        statusDesc = 'Hati-hati untuk kapal kecil';
                        statusColor = 'from-yellow-500/20 to-yellow-600/10 border-yellow-500/30';
                    }
                    
                    marineCurrentHtml = `
                        <div class="mt-6 space-y-4">
                            <h4 class="text-[10px] font-black text-slate-500 uppercase tracking-widest">Data Maritim</h4>
                            
                            <!-- Status Keamanan Laut -->
                            <div class="bg-gradient-to-r ${statusColor} p-4 rounded-xl border">
                                <div class="flex items-center gap-3">
                                    <span class="text-2xl">${statusIcon}</span>
                                    <div>
                                        <div class="text-sm font-bold text-white">${statusText}</div>
                                        <div class="text-[10px] text-slate-300">${statusDesc}</div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Data Maritim Grid -->
                            <div class="grid grid-cols-2 gap-3">
                                <div class="bg-cyan-950/30 p-4 rounded-xl border border-cyan-800/30">
                                    <div class="flex items-center gap-2 mb-2">
                                        <span class="text-2xl">🌊</span>
                                        <div class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">Ombak</div>
                                    </div>
                                    <div class="text-2xl font-black text-cyan-400">${waveHeight.toFixed(1)}m</div>
                                    <div class="text-xs text-slate-400 mt-1">Periode: ${wavePeriod.toFixed(1)}s</div>
                                    <div class="text-xs text-slate-400">Arah: ${Math.round(waveDirection)}° ${degToCompass(waveDirection)}</div>
                                </div>
                                
                                ${seaTemp !== null ? `
                                <div class="bg-slate-800/30 p-4 rounded-xl border border-slate-800">
                                    <div class="flex items-center gap-2 mb-2">
                                        <span class="text-2xl">🌡️</span>
                                        <div class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">Suhu Laut</div>
                                    </div>
                                    <div class="text-2xl font-black text-emerald-400">${seaTemp.toFixed(1)}°C</div>
                                    <div class="text-xs text-slate-400 mt-1">Permukaan laut</div>
                                </div>
                                ` : ''}
                                
                                ${oceanCurrent !== null ? `
                                <div class="bg-slate-800/30 p-4 rounded-xl border border-slate-800">
                                    <div class="flex items-center gap-2 mb-2">
                                        <span class="text-2xl">🌀</span>
                                        <div class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">Arus Laut</div>
                                    </div>
                                    <div class="text-2xl font-black text-blue-400">${oceanCurrent.toFixed(2)} m/s</div>
                                    ${oceanCurrentDir !== null ? `<div class="text-xs text-slate-400 mt-1">Arah: ${Math.round(oceanCurrentDir)}° ${degToCompass(oceanCurrentDir)}</div>` : ''}
                                </div>
                                ` : ''}
                                
                                ${seaLevel !== null ? `
                                <div class="bg-slate-800/30 p-4 rounded-xl border border-slate-800">
                                    <div class="flex items-center gap-2 mb-2">
                                        <span class="text-2xl">📏</span>
                                        <div class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">Tinggi Laut</div>
                                    </div>
                                    <div class="text-2xl font-black text-purple-400">${seaLevel.toFixed(2)}m</div>
                                    <div class="text-xs text-slate-400 mt-1">MSL (Mean Sea Level)</div>
                                </div>
                                ` : ''}
                            </div>
                        </div>
                    `;
                }
                
                let hourlyHtml = '';
                let dailyHtml = '';
                const weatherMap = { 0: '☀️', 1: '🌤️', 2: '⛅', 3: '☁️', 45: '🌫️', 51: '🌧️', 61: '🌧️', 80: '🌦️', 95: '⛈️' };

                if (weatherData.daily) {
                    for (let i = 0; i < 7; i++) {
                        const date = new Date(weatherData.daily.time[i]);
                        dailyHtml += `<div class="flex flex-col items-center gap-2 p-2 min-w-[60px]"><span class="text-[10px] font-bold text-slate-500 uppercase">${date.toLocaleDateString('id-ID', { weekday: 'short' })}</span><span class="text-2xl">${weatherMap[weatherData.daily.weather_code[i]] || '🌤️'}</span><div class="flex flex-col items-center"><span class="text-xs font-bold text-white">${Math.round(weatherData.daily.temperature_2m_max[i])}°</span><span class="text-[9px] text-slate-500">${Math.round(weatherData.daily.temperature_2m_min[i])}°</span></div></div>`;
                    }
                }
                if (weatherData.hourly) {
                    const nowIdx = new Date().getHours();
                    for (let i = nowIdx; i < nowIdx + 12; i++) {
                        hourlyHtml += `<div class="flex flex-col items-center gap-1 min-w-[50px]"><span class="text-[9px] text-slate-500">${(i % 24).toString().padStart(2, '0')}.00</span><span class="text-lg">${weatherMap[weatherData.hourly.weather_code[i]] || '🌤️'}</span><span class="text-xs font-bold text-white">${Math.round(weatherData.hourly.temperature_2m[i])}°</span></div>`;
                    }
                }

                const locationText = data.source && data.source.lokasi ? data.source.lokasi : 'Lokasi Server (Config)';

                content.innerHTML = `
                    <div class="flex items-start justify-between mb-2">
                        <div><h4 class="text-slate-400 text-[10px] font-black uppercase tracking-widest mb-1">${locationText}</h4><div class="flex items-center gap-4"><span class="text-6xl font-black text-white">${Math.round(weatherData.current.temperature_2m)}°</span><div class="text-sm text-slate-400"><p>Kelembapan: ${weatherData.current.relative_humidity_2m}%</p><p>Angin: ${weatherData.current.wind_speed_10m} km/h</p></div></div></div>
                        <div class="text-7xl">${document.getElementById('weather-icon').textContent}</div>
                    </div>
                    
                    ${marineCurrentHtml}
                    
                    <div class="border-t border-slate-800 pt-6"><p class="text-[9px] font-black text-slate-500 uppercase tracking-widest mb-4">Prakiraan Per Jam</p><div class="flex gap-4 overflow-x-auto pb-4 no-scrollbar">${hourlyHtml}</div></div>
                    <div class="border-t border-slate-800 pt-6"><p class="text-[9px] font-black text-slate-500 uppercase tracking-widest mb-4">Prakiraan 7 Hari</p><div class="flex justify-between gap-2 overflow-x-auto pb-2 no-scrollbar">${dailyHtml}</div></div>
                `;
            } catch (e) {
                console.error('Weather detail error:', e);
                content.innerHTML = '<div class="py-20 text-center text-slate-400">Gagal memuat data cuaca</div>';
            }
        }
        function closeWeatherModal() { 
            document.getElementById('weatherModal').classList.add('hidden'); 
            document.getElementById('weatherModal').classList.remove('flex'); 
        }
        
        function closeWeatherModalOnBackdrop(event) {
            // Close modal hanya jika klik di backdrop (bukan di konten modal)
            if (event.target.id === 'weatherModal') {
                closeWeatherModal();
            }
        }

        function updateClock() {
            const now = new Date();
            const options = { timeZone: 'Asia/Jakarta', hour12: false, hour: '2-digit', minute: '2-digit', second: '2-digit' };
            const timeStr = now.toLocaleTimeString('en-GB', options);
            const dateStr = now.toLocaleDateString('id-ID', { timeZone: 'Asia/Jakarta', day: 'numeric', month: 'long', year: 'numeric' });
            
            const clockEl = document.getElementById('topbar-clock');
            const dateEl = document.getElementById('topbar-date');
            const mClockEl = document.getElementById('modal-clock');
            const mDateEl = document.getElementById('modal-date');
            
            if (clockEl) clockEl.textContent = timeStr;
            if (dateEl) dateEl.textContent = dateStr;
            if (mClockEl) mClockEl.textContent = timeStr;
            if (mDateEl) mDateEl.textContent = dateStr;
        }

        function showTimeModal() {
            document.getElementById('timeModal').classList.remove('hidden');
            document.getElementById('timeModal').classList.add('flex');
        }
        function closeTimeModal() {
            document.getElementById('timeModal').classList.add('hidden');
            document.getElementById('timeModal').classList.remove('flex');
        }

        setInterval(updateClock, 1000);
        updateClock();

        // --- Date Logic ---
        function generateDates() {
            const containers = [document.getElementById('dateScroll')];
            const month = parseInt(document.getElementById('monthSelect').value);
            const year = new Date().getFullYear();
            const daysInMonth = new Date(year, month + 1, 0).getDate();
            const today = new Date();
            const todayStr = `${today.getFullYear()}-${String(today.getMonth() + 1).padStart(2, '0')}-${String(today.getDate()).padStart(2, '0')}`;
            
            containers.forEach(container => {
                if (!container) return;
                container.innerHTML = '';
                for (let i = 1; i <= daysInMonth; i++) {
                    const dateStr = `${year}-${String(month + 1).padStart(2, '0')}-${String(i).padStart(2, '0')}`;
                    const dateObj = new Date(year, month, i);
                    const dayName = dateObj.toLocaleDateString('id-ID', { weekday: 'short' });
                    
                    const btn = document.createElement('button');
                    btn.className = `date-btn flex flex-col items-center min-w-[38px] py-1.5 rounded-lg transition-all ${dateStr === selectedDate ? 'active' : 'bg-slate-800/50 hover:bg-slate-800'}`;
                    btn.onclick = async () => {
                        selectedDate = dateStr;
                        generateDates();
                        await fetchRecordings();
                    };
                    btn.innerHTML = `<span class="text-[7px] font-black uppercase opacity-50 mb-0.5">${dayName}</span><span class="text-[10px] font-black">${i}</span>`;
                    container.appendChild(btn);
                    
                    if (dateStr === selectedDate) {
                        setTimeout(() => btn.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' }), 100);
                    }
                }
            });
        }

        // --- Camera & Recording Logic ---
        async function selectCamera(id, name) {
            if (selectedCamId === id) return;
            selectedCamId = id;
            document.querySelectorAll('.camera-list-item').forEach(item => {
                item.classList.toggle('active', item.dataset.id === id);
            });
            
            // Close sidebar on mobile
            if (window.innerWidth < 1024 && document.getElementById('camera-sidebar').classList.contains('open')) {
                toggleCameraSidebar();
            }
            
            await fetchRecordings();
        }

        async function fetchRecordings() {
            if (!selectedCamId) return;
            
            const list = document.getElementById('recording-list');
            const empty = document.getElementById('recording-empty');
            const countEl = document.getElementById('recording-count');
            
            isLoading = true;
            list.innerHTML = `<div class="py-20 text-center"><div class="inline-block animate-spin rounded-full h-5 w-5 border-2 border-emerald-500 border-t-transparent"></div></div>`;
            empty.classList.add('hidden');
            countEl.textContent = '0';

            try {
                const res = await fetch(`${basePath}/api/recordings?camera_id=${selectedCamId}&date=${selectedDate}`);
                const data = await res.json();
                
                allRecordings = data.recordings || [];
                countEl.textContent = allRecordings.length;
                renderRecordings();
            } catch (e) {
                console.error("Error fetching recordings:", e);
                list.innerHTML = `<div class="py-20 text-center text-red-500 text-[9px] uppercase font-black">Gagal memuat data</div>`;
            } finally {
                isLoading = false;
            }
        }

        function renderRecordings() {
            const list = document.getElementById('recording-list');
            const empty = document.getElementById('recording-empty');
            
            if (!selectedCamId || allRecordings.length === 0) {
                list.innerHTML = '';
                empty.classList.remove('hidden');
                return;
            }

            empty.classList.add('hidden');
            list.innerHTML = allRecordings.map(rec => {
                const parts = rec.created_at.split(' ');
                const time = parts[1] || '--:--';
                const size = (rec.size / (1024 * 1024)).toFixed(1);
                const title = rec.title ? String(rec.title) : '';
                const notes = rec.notes ? String(rec.notes) : '';
                
                return `
                    <div class="recording-row p-4 lg:p-5 hover:bg-slate-800/50 transition cursor-pointer flex items-center justify-between group" onclick="playRecording('${rec.file_path}', this)">
                        <div class="flex items-center gap-4">
                            <div class="w-8 h-8 lg:w-10 lg:h-10 bg-slate-950 rounded flex items-center justify-center border border-slate-800 text-slate-500 group-hover:text-emerald-500 transition">
                                <svg class="w-4 h-4 lg:w-5 lg:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path></svg>
                            </div>
                            <div>
                                <p class="text-[11px] lg:text-[14px] font-black text-white">${time}</p>
                                <p class="text-[8px] lg:text-[11px] text-slate-500 font-bold uppercase">${size} MB</p>
                                ${(title || notes) ? `<p class="text-[8px] lg:text-[10px] text-slate-400 font-bold uppercase truncate max-w-[180px] lg:max-w-[220px]">${(title || notes).replace(/</g,'&lt;').replace(/>/g,'&gt;')}</p>` : ``}
                            </div>
                        </div>
                        <div class="flex items-center gap-2">
                            ${isAdmin && rec.id ? `
                                <button onclick="event.stopPropagation(); editRecordingMeta(${rec.id}, '${(title || '').replace(/\\/g,'\\\\').replace(/'/g,'\\\'')}', '${(notes || '').replace(/\\/g,'\\\\').replace(/'/g,'\\\'')}')" class="opacity-0 group-hover:opacity-100 transition px-2 py-1 rounded-lg border border-slate-700 text-slate-300 hover:bg-slate-800 text-[9px] font-black uppercase tracking-widest">EDIT</button>
                                <button onclick="event.stopPropagation(); deleteRecording(${rec.id})" class="opacity-0 group-hover:opacity-100 transition px-2 py-1 rounded-lg border border-rose-900/40 text-rose-400 hover:bg-rose-900/20 text-[9px] font-black uppercase tracking-widest">HAPUS</button>
                            ` : `
                                <div class="text-[9px] lg:text-[11px] font-black text-emerald-500 opacity-0 group-hover:opacity-100 transition tracking-widest">PUTAR</div>
                            `}
                        </div>
                    </div>
                `;
            }).join('');
        }

        async function deleteRecording(id) {
            if (!isAdmin) return;
            if (!confirm('Hapus rekaman ini? File dan data akan dihapus.')) return;
            try {
                const res = await fetch(`${basePath}/api/recordings/${id}`, { method: 'DELETE' });
                const data = await res.json();
                if (!res.ok) {
                    alert(data?.error || 'Gagal menghapus');
                    return;
                }
                allRecordings = allRecordings.filter(r => String(r.id) !== String(id));
                renderRecordings();
            } catch (e) {
                alert('Gagal menghapus: ' + (e?.message || String(e)));
            }
        }

        async function editRecordingMeta(id, currentTitle, currentNotes) {
            if (!isAdmin) return;
            const title = prompt('Judul (opsional):', currentTitle || '');
            if (title === null) return;
            const notes = prompt('Catatan (opsional):', currentNotes || '');
            if (notes === null) return;
            try {
                const res = await fetch(`${basePath}/api/recordings/${id}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ title, notes })
                });
                const data = await res.json();
                if (!res.ok) {
                    alert(data?.error || 'Gagal update');
                    return;
                }
                allRecordings = allRecordings.map(r => String(r.id) === String(id) ? { ...r, title: data.title, notes: data.notes } : r);
                renderRecordings();
            } catch (e) {
                alert('Gagal update: ' + (e?.message || String(e)));
            }
        }

        function playRecording(path, el) {
            document.querySelectorAll('.recording-row').forEach(r => r.classList.remove('active'));
            if (el) el.classList.add('active');
            
            const fullPath = basePath + '/' + path;
            const dlBtn = document.getElementById('downloadBtn');
            dlBtn.href = fullPath;
            dlBtn.classList.remove('hidden');
            dlBtn.classList.add('flex');

            document.getElementById('player-placeholder').classList.add('hidden');
            player.classList.remove('hidden');
            player.src = fullPath;
            player.play();
            
            // Show speed control when video is loaded
            document.getElementById('speed-control').classList.remove('hidden');
            
            if (window.innerWidth < 1024) {
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }
        }

        // Playback Speed Control
        function setPlaybackSpeed(speed) {
            player.playbackRate = speed;
            
            // Update button styles
            document.querySelectorAll('.speed-btn').forEach(btn => {
                btn.classList.remove('active', 'text-white', 'bg-emerald-500/20', 'border', 'border-emerald-500/50');
                btn.classList.add('text-slate-400', 'hover:text-white', 'hover:bg-slate-800');
            });
            
            // Highlight active button
            const activeBtn = document.querySelector(`.speed-btn[data-speed="${speed}"]`);
            if (activeBtn) {
                activeBtn.classList.remove('text-slate-400', 'hover:text-white', 'hover:bg-slate-800');
                activeBtn.classList.add('active', 'text-white', 'bg-emerald-500/20', 'border', 'border-emerald-500/50');
            }
        }

        window.onload = () => {
            updateWeather();
            generateDates();
            setInterval(updateWeather, 300000);
            
            // Auto select camera from URL state or first item
            if (selectedCamId) {
                const item = document.querySelector(`.camera-list-item[data-id="${selectedCamId}"]`);
                if (item) {
                    item.classList.add('active');
                    fetchRecordings();
                }
            } else {
                const first = document.querySelector('.camera-list-item');
                if (first) first.click();
            }
        };
    </script>
</body>
</html>
