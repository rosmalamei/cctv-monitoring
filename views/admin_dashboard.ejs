<script>
async function fetchSystemInfo() {
    try {
        const res = await fetch('<%= base_path %>/api/system/info');
        const data = await res.json();
        if (!data.success) return;
        
        const s = data.data;
        
        // Server Banner
        document.getElementById('serverDot').className = 'w-3 h-3 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.5)]';
        document.getElementById('serverName').innerText = s.hostname || 'CCTV Server';
        
        const uptimeStr = formatUptime(s.uptime_sec);
        document.getElementById('serverUptime').innerText = 'Online since ' + uptimeStr;
        document.getElementById('serverCpuLoad').innerText = (s.cpu_load || 0).toFixed(1);
        document.getElementById('serverMemUsage').innerText = (s.memory_percent || 0).toFixed(0) + '%';
        document.getElementById('serverDiskUsage').innerText = (s.disk_percent || 0).toFixed(0) + '%';
        document.getElementById('serverArch').innerText = s.arch || '--';
        
        // CPU
        const cpuPct = Math.min(100, Math.round((s.cpu_load || 0) / (s.cpu_cores || 1) * 100));
        document.getElementById('cpu-percent').innerText = cpuPct + '%';
        const cpuBar = document.getElementById('cpu-bar');
        cpuBar.style.width = cpuPct + '%';
        cpuBar.className = 'h-full rounded-full transition-all duration-1000 ' + (cpuPct > 80 ? 'bg-rose-500' : cpuPct > 50 ? 'bg-amber-500' : 'bg-emerald-500');
        document.getElementById('cpu-load-1').innerText = '1m: ' + (s.cpu_load || 0).toFixed(2);
        document.getElementById('cpu-load-5').innerText = '5m: ' + (s.cpu_load_5 || 0).toFixed(2);
        document.getElementById('cpu-load-15').innerText = '15m: ' + (s.cpu_load_15 || 0).toFixed(2);
        
        // Memory
        const memPct = Math.round(s.memory_percent || 0);
        document.getElementById('mem-percent').innerText = memPct + '%';
        const memBar = document.getElementById('mem-bar');
        memBar.style.width = memPct + '%';
        memBar.className = 'h-full rounded-full transition-all duration-1000 ' + (memPct > 80 ? 'bg-rose-500' : memPct > 50 ? 'bg-amber-500' : 'bg-blue-500');
        document.getElementById('mem-used').innerText = s.memory_used || '0 GB';
        document.getElementById('mem-free').innerText = s.memory_free || '0 GB';
        document.getElementById('mem-total').innerText = s.memory_total || '0 GB';
        
        // Disk
        const diskPct = Math.round(s.disk_percent || 0);
        document.getElementById('disk-percent').innerText = diskPct + '%';
        const diskBar = document.getElementById('disk-bar');
        diskBar.style.width = diskPct + '%';
        diskBar.className = 'h-full rounded-full transition-all duration-1000 ' + (diskPct > 80 ? 'bg-rose-500' : diskPct > 60 ? 'bg-amber-500' : 'bg-orange-500');
        document.getElementById('disk-used').innerText = s.disk_used || '0 GB';
        document.getElementById('disk-free').innerText = s.disk_free || '0 GB';
        document.getElementById('disk-total').innerText = s.disk_total || '0 GB';
        
        // System Info
        document.getElementById('sys-hostname').innerText = s.hostname || '--';
        document.getElementById('sys-platform').innerText = s.platform || '--';
        document.getElementById('sys-arch').innerText = s.arch || '--';
        document.getElementById('sys-cpu').innerText = s.cpu_model || '--';
        document.getElementById('sys-cores').innerText = s.cpu_cores + ' Cores' || '--';
        document.getElementById('sys-temp').innerText = s.cpu_temp || '--';
        document.getElementById('sys-uptime').innerText = formatUptime(s.uptime_sec);
        document.getElementById('sys-node').innerText = s.node_version || '--';
        document.getElementById('sys-version').innerText = s.app_version || '--';
        
        // AI Status
        if (s.ai_engine && s.ai_engine.status === 'ok') {
            document.getElementById('sys-ai').innerHTML = '<span class="text-emerald-400">Online</span> (' + (s.ai_engine.active_cameras||0) + ' cam)';
        } else {
            document.getElementById('sys-ai').innerHTML = '<span class="text-rose-400">Offline</span>';
        }
        
        // Disk Partitions
        if (s.disks && s.disks.length > 0) {
            const dc = document.getElementById('disks-container');
            dc.innerHTML = '';
            s.disks.forEach(function(d, i) {
                const pct = Math.round(d.percent || 0);
                const color = pct > 80 ? 'bg-rose-500' : pct > 60 ? 'bg-amber-500' : 'bg-orange-500';
                dc.innerHTML += '<div class="p-3 bg-gray-900/50 rounded-xl border border-gray-700">' +
                    '<div class="flex justify-between text-xs mb-1.5">' +
                        '<span class="text-gray-400 font-medium">' + (d.mounted || d.filesystem || 'Disk ' + (i+1)) + '</span>' +
                        '<span class="text-white font-bold">' + pct + '%</span>' +
                    '</div>' +
                    '<div class="h-1.5 bg-gray-800 rounded-full overflow-hidden">' +
                        '<div class="h-full rounded-full ' + color + '" style="width: ' + pct + '%"></div>' +
                    '</div>' +
                    '<div class="flex justify-between text-[9px] text-gray-600 mt-1">' +
                        '<span>' + (d.used || '0') + '</span>' +
                        '<span>' + (d.free || '0') + '</span>' +
                        '<span>' + (d.total || '0') + '</span>' +
                    '</div>' +
                '</div>';
            });
        }
        
        // Summary cards
        document.getElementById('disk-percent-badge').innerText = diskPct + '%';
        document.getElementById('disk-text').innerHTML = (s.disk_used_gb || '0') + ' <span class="text-sm font-normal text-gray-500">/ ' + (s.disk_total_gb || '0') + ' GB</span>';
        
    } catch(e) {
        console.error('[Dashboard] System info error:', e);
    }
}

async function checkSystemServices() {
    try {
        // MediaMTX
        const mtx = await fetch('<%= base_path %>/api/mediamtx/health').then(r => r.json()).catch(() => ({}));
        updateService('srv-mediamtx', mtx.success !== false, 'MediaMTX API', 'Running', 'Offline');
        
        // HLS (check port)
        const hls = await fetch('<%= base_path %>/api/system/disk').then(r => r.json()).catch(() => ({}));
        updateService('srv-hls', true, 'HLS Streamer', 'Active', 'Inactive');
        
        // FFmpeg
        const ff = await fetch('<%= base_path %>/api/youtube/check-ffmpeg').then(r => r.json()).catch(() => ({}));
        updateService('srv-ffmpeg', ff.available, 'FFmpeg Engine', 'Available', 'Missing');
        
        // AI Engine
        const ai = await fetch('<%= base_path %>/api/ai-proxy/health').then(r => r.json()).catch(() => ({}));
        const aiOk = ai && ai.status === 'ok';
        updateService('srv-ai', aiOk, 'AI Engine', 'Online', 'Offline');
        document.getElementById('ai-status-badge').innerText = aiOk ? 'Online' : 'Offline';
        document.getElementById('ai-status-badge').className = 'text-[10px] font-bold ' + (aiOk ? 'text-emerald-500 bg-emerald-500/10' : 'text-rose-500 bg-rose-500/10') + ' px-2 py-1 rounded-lg uppercase tracking-widest';
        document.getElementById('ai-status-text').innerHTML = (ai && ai.active_cameras || '0') + ' <span class="text-sm font-normal text-gray-500">Kamera</span>';
        
        // WhatsApp
        const wa = await fetch('<%= base_path %>/admin/whatsapp/status').then(r => r.json()).catch(() => ({}));
        updateService('srv-whatsapp', wa.connected, 'WhatsApp Bot', 'Connected', 'Disconnected');
        
        // Telegram
        const tg = await fetch('<%= base_path %>/api/settings/telegram').then(r => r.json()).catch(() => ({}));
        updateService('srv-telegram', false, 'Telegram Bot', 'Active', 'Inactive');
        
        // SQLite
        updateService('srv-sqlite', true, 'Database (SQLite)', 'Connected', 'Error');
        
    } catch(e) {
        console.error('[Dashboard] Service check error:', e);
    }
}

function updateService(dotId, isOk, name, okText, failText) {
    const dot = document.getElementById(dotId);
    const txt = document.getElementById(dotId + '-txt');
    if (dot) dot.className = 'w-2 h-2 rounded-full ' + (isOk ? 'bg-emerald-500 shadow-[0_0_6px_rgba(16,185,129,0.5)]' : 'bg-rose-500');
    if (txt) {
        txt.innerText = isOk ? okText : failText;
        txt.className = 'text-[10px] font-bold uppercase tracking-widest ' + (isOk ? 'text-emerald-500' : 'text-rose-500');
    }
}

function formatUptime(seconds) {
    if (!seconds) return '--';
    const d = Math.floor(seconds / 86400);
    const h = Math.floor((seconds % 86400) / 3600);
    const m = Math.floor((seconds % 3600) / 60);
    const s = Math.floor(seconds % 60);
    let parts = [];
    if (d > 0) parts.push(d + 'd');
    if (h > 0) parts.push(h + 'h');
    if (m > 0) parts.push(m + 'm');
    parts.push(s + 's');
    return parts.join(' ');
}

document.addEventListener('DOMContentLoaded', function() {
    fetchSystemInfo();
    checkSystemServices();
    setInterval(fetchSystemInfo, 10000);
    setInterval(checkSystemServices, 30000);
});
</script>

