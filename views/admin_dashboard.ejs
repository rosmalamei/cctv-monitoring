<%- include('partials/admin_header', { title: 'Dashboard' }) %>
<%- include('partials/admin_sidebar', { page: 'dashboard' }) %>

<!-- Server Status Banner -->
<div id="serverBanner" class="bg-gradient-to-r from-gray-800 to-gray-900 rounded-2xl border border-gray-700 p-5 mb-6 flex items-center justify-between">
    <div class="flex items-center gap-4">
        <div id="serverDot" class="w-3 h-3 rounded-full bg-gray-500"></div>
        <div>
            <div id="serverName" class="text-sm font-bold text-white">CCTV Server</div>
            <div id="serverUptime" class="text-[10px] text-gray-500">Checking...</div>
        </div>
    </div>
    <div class="flex items-center gap-4 text-right">
        <div>
            <div id="serverCpuLoad" class="text-xs font-bold text-gray-300">--</div>
            <div class="text-[9px] text-gray-600 uppercase tracking-widest">CPU Load</div>
        </div>
        <div class="w-px h-8 bg-gray-700"></div>
        <div>
            <div id="serverMemUsage" class="text-xs font-bold text-gray-300">--</div>
            <div class="text-[9px] text-gray-600 uppercase tracking-widest">Memory</div>
        </div>
        <div class="w-px h-8 bg-gray-700"></div>
        <div>
            <div id="serverDiskUsage" class="text-xs font-bold text-gray-300">--</div>
            <div class="text-[9px] text-gray-600 uppercase tracking-widest">Disk</div>
        </div>
        <div class="w-px h-8 bg-gray-700"></div>
        <div>
            <div id="serverArch" class="text-xs font-bold text-gray-300">--</div>
            <div class="text-[9px] text-gray-600 uppercase tracking-widest">Arch</div>
        </div>
    </div>
</div>

<!-- Stats Cards -->
<div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
    <div class="bg-gray-800 rounded-2xl border border-gray-700 p-5 shadow-xl">
        <div class="flex items-center justify-between mb-3">
            <div class="p-2.5 bg-emerald-500/10 rounded-xl">
                <svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
                </svg>
            </div>
            <span class="text-[10px] font-bold text-emerald-500 bg-emerald-500/10 px-2 py-1 rounded-lg uppercase tracking-widest">Online</span>
        </div>
        <h3 class="text-gray-400 text-[10px] font-black uppercase tracking-widest mb-1">Kamera Terdaftar</h3>
        <p class="text-3xl font-black text-white mt-1"><%= cameras.length %> <span class="text-sm font-normal text-gray-500">Unit</span></p>
    </div>

    <div class="bg-gray-800 rounded-2xl border border-gray-700 p-5 shadow-xl">
        <div class="flex items-center justify-between mb-3">
            <div class="p-2.5 bg-blue-500/10 rounded-xl">
                <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
                </svg>
            </div>
            <span class="text-[10px] font-bold text-blue-500 bg-blue-500/10 px-2 py-1 rounded-lg uppercase tracking-widest">Aktif</span>
        </div>
        <h3 class="text-gray-400 text-[10px] font-black uppercase tracking-widest mb-1">Total Pelanggan</h3>
        <p class="text-3xl font-black text-white mt-1"><%= users.length %> <span class="text-sm font-normal text-gray-500">User</span></p>
    </div>

    <div class="bg-gray-800 rounded-2xl border border-gray-700 p-5 shadow-xl">
        <div class="flex items-center justify-between mb-3">
            <div class="p-2.5 bg-amber-500/10 rounded-xl">
                <svg class="w-5 h-5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                </svg>
            </div>
            <span id="disk-percent-badge" class="text-[10px] font-bold text-amber-500 bg-amber-500/10 px-2 py-1 rounded-lg uppercase tracking-widest">--</span>
        </div>
        <h3 class="text-gray-400 text-[10px] font-black uppercase tracking-widest mb-1">Penyimpanan</h3>
        <p id="disk-text" class="text-3xl font-black text-white mt-1">-- <span class="text-sm font-normal text-gray-500">/ -- GB</span></p>
    </div>

    <div class="bg-gray-800 rounded-2xl border border-gray-700 p-5 shadow-xl">
        <div class="flex items-center justify-between mb-3">
            <div class="p-2.5 bg-purple-500/10 rounded-xl">
                <svg class="w-5 h-5 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
            </div>
            <span id="ai-status-badge" class="text-[10px] font-bold text-purple-500 bg-purple-500/10 px-2 py-1 rounded-lg uppercase tracking-widest">Checking...</span>
        </div>
        <h3 class="text-gray-400 text-[10px] font-black uppercase tracking-widest mb-1">AI Engine</h3>
        <p id="ai-status-text" class="text-3xl font-black text-white mt-1">-- <span class="text-sm font-normal text-gray-500">Kamera</span></p>
    </div>
</div>

<!-- System Monitor Section -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
    <!-- CPU & Memory Cards -->
    <div class="bg-gray-800 rounded-2xl border border-gray-700 p-6 shadow-xl">
        <h2 class="text-base font-bold text-white mb-5 flex items-center gap-2">
            <svg class="w-4 h-4 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"></path></svg>
            CPU & Memory Monitor
        </h2>
        <div class="space-y-5">
            <!-- CPU -->
            <div>
                <div class="flex justify-between text-xs mb-2">
                    <span class="text-gray-400 font-medium">CPU Load</span>
                    <span id="cpu-percent" class="text-white font-bold">0%</span>
                </div>
                <div class="h-2.5 bg-gray-900 rounded-full overflow-hidden">
                    <div id="cpu-bar" class="h-full rounded-full transition-all duration-1000" style="width: 0%"></div>
                </div>
                <div class="flex justify-between text-[9px] text-gray-600 mt-1">
                    <span id="cpu-load-1">0.00</span>
                    <span id="cpu-load-5">0.00</span>
                    <span id="cpu-load-15">0.00</span>
                </div>
            </div>
            <!-- Memory -->
            <div>
                <div class="flex justify-between text-xs mb-2">
                    <span class="text-gray-400 font-medium">Memory</span>
                    <span id="mem-percent" class="text-white font-bold">0%</span>
                </div>
                <div class="h-2.5 bg-gray-900 rounded-full overflow-hidden">
                    <div id="mem-bar" class="h-full rounded-full transition-all duration-1000" style="width: 0%"></div>
                </div>
                <div class="flex justify-between text-[9px] text-gray-600 mt-1">
                    <span id="mem-used">0 GB</span>
                    <span id="mem-free">0 GB</span>
                    <span id="mem-total">0 GB</span>
                </div>
            </div>
            <!-- Disk -->
            <div>
                <div class="flex justify-between text-xs mb-2">
                    <span class="text-gray-400 font-medium">Disk Storage</span>
                    <span id="disk-percent" class="text-white font-bold">0%</span>
                </div>
                <div class="h-2.5 bg-gray-900 rounded-full overflow-hidden">
                    <div id="disk-bar" class="h-full rounded-full transition-all duration-1000" style="width: 0%"></div>
                </div>
                <div class="flex justify-between text-[9px] text-gray-600 mt-1">
                    <span id="disk-used">0 GB</span>
                    <span id="disk-free">0 GB</span>
                    <span id="disk-total">0 GB</span>
                </div>
            </div>
        </div>
    </div>

    <!-- System Info Card -->
    <div class="bg-gray-800 rounded-2xl border border-gray-700 p-6 shadow-xl">
        <h2 class="text-base font-bold text-white mb-5 flex items-center gap-2">
            <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
            System Information
        </h2>
        <div class="space-y-3">
            <div class="flex justify-between p-3 bg-gray-900/50 rounded-xl border border-gray-700">
                <span class="text-xs text-gray-400">Hostname</span>
                <span id="sys-hostname" class="text-xs font-bold text-white">--</span>
            </div>
            <div class="flex justify-between p-3 bg-gray-900/50 rounded-xl border border-gray-700">
                <span class="text-xs text-gray-400">Platform</span>
                <span id="sys-platform" class="text-xs font-bold text-white">--</span>
            </div>
            <div class="flex justify-between p-3 bg-gray-900/50 rounded-xl border border-gray-700">
                <span class="text-xs text-gray-400">Architecture</span>
                <span id="sys-arch" class="text-xs font-bold text-white">--</span>
            </div>
            <div class="flex justify-between p-3 bg-gray-900/50 rounded-xl border border-gray-700">
                <span class="text-xs text-gray-400">Processor</span>
                <span id="sys-cpu" class="text-xs font-bold text-white">--</span>
            </div>
            <div class="flex justify-between p-3 bg-gray-900/50 rounded-xl border border-gray-700">
                <span class="text-xs text-gray-400">CPU Cores</span>
                <span id="sys-cores" class="text-xs font-bold text-white">--</span>
            </div>
            <div class="flex justify-between p-3 bg-gray-900/50 rounded-xl border border-gray-700">
                <span class="text-xs text-gray-400">CPU Temperature</span>
                <span id="sys-temp" class="text-xs font-bold text-white">--</span>
            </div>
            <div class="flex justify-between p-3 bg-gray-900/50 rounded-xl border border-gray-700">
                <span class="text-xs text-gray-400">Server Uptime</span>
                <span id="sys-uptime" class="text-xs font-bold text-cyan-400">--</span>
            </div>
            <div class="flex justify-between p-3 bg-gray-900/50 rounded-xl border border-gray-700">
                <span class="text-xs text-gray-400">Node.js Version</span>
                <span id="sys-node" class="text-xs font-bold text-white">--</span>
            </div>
            <div class="flex justify-between p-3 bg-gray-900/50 rounded-xl border border-gray-700">
                <span class="text-xs text-gray-400">App Version</span>
                <span id="sys-version" class="text-xs font-bold text-emerald-400">--</span>
            </div>
            <div class="flex justify-between p-3 bg-gray-900/50 rounded-xl border border-gray-700">
                <span class="text-xs text-gray-400">AI Engine</span>
                <span id="sys-ai" class="text-xs font-bold text-white">Checking...</span>
            </div>
        </div>
    </div>
</div>

<!-- Temperature & Disks Detail -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
    <!-- Recent Recordings -->
    <div class="bg-gray-800 rounded-2xl border border-gray-700 p-6 shadow-xl">
        <h2 class="text-base font-bold text-white mb-4 flex items-center gap-2">
            <svg class="w-4 h-4 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"></path></svg>
            Disk Partitions
        </h2>
        <div id="disks-container" class="space-y-2">
            <div class="text-center text-gray-500 text-xs py-4">Loading disk info...</div>
        </div>
    </div>

    <!-- Service Status -->
    <div class="bg-gray-800 rounded-2xl border border-gray-700 p-6 shadow-xl">
        <h2 class="text-base font-bold text-white mb-4 flex items-center gap-2">
            <span class="w-1.5 h-5 bg-emerald-500 rounded-full"></span>
            Service Status
        </h2>
        <div class="space-y-3">
            <div class="flex items-center justify-between p-3 bg-gray-900/50 rounded-xl border border-gray-700">
                <div class="flex items-center gap-2.5">
                    <div id="srv-mediamtx" class="w-2 h-2 rounded-full bg-gray-500"></div>
                    <span class="text-xs font-medium text-gray-300">MediaMTX API</span>
                </div>
                <span id="srv-mediamtx-txt" class="text-[10px] font-bold text-gray-500 uppercase tracking-widest">Checking...</span>
            </div>
            <div class="flex items-center justify-between p-3 bg-gray-900/50 rounded-xl border border-gray-700">
                <div class="flex items-center gap-2.5">
                    <div id="srv-hls" class="w-2 h-2 rounded-full bg-gray-500"></div>
                    <span class="text-xs font-medium text-gray-300">HLS Streamer</span>
                </div>
                <span id="srv-hls-txt" class="text-[10px] font-bold text-gray-500 uppercase tracking-widest">Checking...</span>
            </div>
            <div class="flex items-center justify-between p-3 bg-gray-900/50 rounded-xl border border-gray-700">
                <div class="flex items-center gap-2.5">
                    <div id="srv-ffmpeg" class="w-2 h-2 rounded-full bg-gray-500"></div>
                    <span class="text-xs font-medium text-gray-300">FFmpeg Engine</span>
                </div>
                <span id="srv-ffmpeg-txt" class="text-[10px] font-bold text-gray-500 uppercase tracking-widest">Checking...</span>
            </div>
            <div class="flex items-center justify-between p-3 bg-gray-900/50 rounded-xl border border-gray-700">
                <div class="flex items-center gap-2.5">
                    <div id="srv-ai" class="w-2 h-2 rounded-full bg-gray-500"></div>
                    <span class="text-xs font-medium text-gray-300">AI Engine</span>
                </div>
                <span id="srv-ai-txt" class="text-[10px] font-bold text-gray-500 uppercase tracking-widest">Checking...</span>
            </div>
            <div class="flex items-center justify-between p-3 bg-gray-900/50 rounded-xl border border-gray-700">
                <div class="flex items-center gap-2.5">
                    <div id="srv-whatsapp" class="w-2 h-2 rounded-full bg-gray-500"></div>
                    <span class="text-xs font-medium text-gray-300">WhatsApp Bot</span>
                </div>
                <span id="srv-whatsapp-txt" class="text-[10px] font-bold text-gray-500 uppercase tracking-widest">Checking...</span>
            </div>
            <div class="flex items-center justify-between p-3 bg-gray-900/50 rounded-xl border border-gray-700">
                <div class="flex items-center gap-2.5">
                    <div id="srv-telegram" class="w-2 h-2 rounded-full bg-gray-500"></div>
                    <span class="text-xs font-medium text-gray-300">Telegram Bot</span>
                </div>
                <span id="srv-telegram-txt" class="text-[10px] font-bold text-gray-500 uppercase tracking-widest">Checking...</span>
            </div>
            <div class="flex items-center justify-between p-3 bg-gray-900/50 rounded-xl border border-gray-700">
                <div class="flex items-center gap-2.5">
                    <div id="srv-sqlite" class="w-2 h-2 rounded-full bg-gray-500"></div>
                    <span class="text-xs font-medium text-gray-300">Database (SQLite)</span>
