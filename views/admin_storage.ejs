<%- include('partials/admin_header', { title: 'Manajemen Penyimpanan' }) %>
<%- include('partials/admin_sidebar', { page: 'storage' }) %>

<div class="bg-gradient-to-br from-gray-800 via-gray-850 to-gray-900 rounded-2xl border border-gray-700 p-6 mb-8">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h2 class="text-lg font-bold text-white flex items-center gap-2">
                <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
                Manajemen Penyimpanan Rekaman
            </h2>
            <p class="text-[10px] text-gray-500 mt-1">Atur lokasi penyimpanan rekaman - internal atau eksternal USB HDD/SSD</p>
        </div>
        <button onclick="refreshStorage()" class="text-[10px] bg-gray-700 hover:bg-gray-600 text-gray-300 px-3 py-1.5 rounded-lg transition font-bold flex items-center gap-1">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
            Refresh
        </button>
    </div>

    <!-- Current Storage Status -->
    <div id="currentStorageInfo" class="p-4 bg-gray-900/50 rounded-xl border border-gray-700 mb-6">
        <div class="text-[10px] text-gray-500 uppercase tracking-widest font-black mb-1">Active Storage</div>
        <div class="text-white font-bold text-base" id="activeStorageName">Loading...</div>
        <div class="text-[10px] text-gray-500 mt-1" id="activeStoragePath"></div>
    </div>

    <!-- Available Storage Devices -->
    <h3 class="text-xs font-bold text-white mb-3 flex items-center gap-2">
        <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"/></svg>
        Available Storage Devices
    </h3>
    <div id="storageDevices" class="space-y-2">
        <div class="text-center text-gray-500 text-xs py-4">Scanning...</div>
    </div>
</div>

<!-- Directory Explorer -->
<div class="bg-gray-800 rounded-2xl border border-gray-700 overflow-hidden mb-8">
    <div class="p-5 border-b border-gray-700 flex items-center justify-between">
        <h2 class="text-base font-bold text-white flex items-center gap-2">
            <svg class="w-4 h-4 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 19a2 2 0 01-2-2V7a2 2 0 012-2h4l2 2h4a2 2 0 012 2v1M5 19h14a2 2 0 002-2v-5a2 2 0 00-2-2H9a2 2 0 00-2 2v5a2 2 0 01-2 2z"/></svg>
            File Explorer
        </h2>
        <div class="flex items-center gap-2 text-[10px] text-gray-500">
            <span>Current:</span>
            <span id="explorerPath" class="text-white font-mono">/home/goo/cctv-monitoring/recordings</span>
        </div>
    </div>
    <div class="p-4 bg-gray-900/50 border-b border-gray-700">
        <div class="flex items-center gap-2 flex-wrap">
            <button onclick="explorerGoUp()" class="text-[10px] bg-gray-700 hover:bg-gray-600 text-gray-300 px-3 py-1.5 rounded-lg transition font-bold">⬆ Up</button>
            <button onclick="setCurrentAsStorage()" class="text-[10px] bg-emerald-700 hover:bg-emerald-600 text-white px-3 py-1.5 rounded-lg transition font-bold">📁 Gunakan Folder Ini</button>
            <input type="text" id="explorerPathInput" class="flex-1 bg-gray-950 border border-gray-700 rounded-lg px-3 py-1.5 text-white text-xs font-mono" 
                value="/home/goo/cctv-monitoring/recordings" onchange="explorerGoTo(this.value)">
        </div>
    </div>
    <div id="explorerItems" class="divide-y divide-gray-700/50 max-h-[400px] overflow-y-auto custom-scrollbar">
        <div class="text-center text-gray-500 text-xs py-8">Loading...</div>
    </div>
</div>

<script>
let currentExplorerPath = '/home/goo/cctv-monitoring/recordings';
let activeStoragePath = '/home/goo/cctv-monitoring/recordings';

async function refreshStorage() {
    try {
        const res = await fetch('<%= base_path %>/api/storage/devices');
        const data = await res.json();
        if (!data.success) return;
        
        const devices = data.devices;
        const activePath = data.activePath || '/home/goo/cctv-monitoring/recordings';
        activeStoragePath = activePath;
        
        // Update active storage info
        const active = devices.find(d => d.path === activePath);
        document.getElementById('activeStorageName').innerText = active ? active.name : 'Custom Path';
        document.getElementById('activeStoragePath').innerText = activePath;
        
        // Render devices list
        const container = document.getElementById('storageDevices');
        container.innerHTML = '';
        
        let hasExternal = false;
        devices.forEach(dev => {
            if (dev.type === 'external') hasExternal = true;
            const isActive = dev.path === activePath;
            const pct = dev.percent !== undefined ? dev.percent : 0;
            const color = pct > 80 ? 'bg-rose-500' : pct > 60 ? 'bg-amber-500' : 'bg-emerald-500';
            
            const div = document.createElement('div');
            div.className = 'p-4 bg-gray-900/50 rounded-xl border ' + (isActive ? 'border-emerald-500/50' : 'border-gray-700') + ' hover:border-gray-600 transition';
            div.innerHTML = `
                <div class="flex items-center justify-between mb-2">
                    <div class="flex items-center gap-2">
                        <span class="text-lg">${dev.type === 'internal' ? '💾' : '💿'}</span>
                        <div>
                            <span class="text-sm font-bold text-white">${dev.name}</span>
                            <span class="text-[9px] text-gray-500 ml-2">${dev.fstype || ''} ${dev.size || ''}</span>
                        </div>
                    </div>
                    <div class="flex items-center gap-2">
                        ${isActive ? '<span class="text-[9px] font-black text-emerald-400 bg-emerald-900/30 px-2 py-0.5 rounded-lg uppercase tracking-widest">Active</span>' : ''}
                        <button onclick="setStorage('${dev.path}')" class="text-[10px] ${isActive ? 'bg-gray-700 text-gray-500 cursor-not-allowed' : 'bg-blue-600 hover:bg-blue-500 text-white'} px-3 py-1.5 rounded-lg transition font-bold" ${isActive ? 'disabled' : ''}>
                            ${isActive ? 'Digunakan' : 'Gunakan'}
                        </button>
                        ${dev.type === 'external' ? `<button onclick="explorerPathInput.value='${dev.path}';explorerGoTo('${dev.path}')" class="text-[10px] bg-gray-700 hover:bg-gray-600 text-gray-300 px-2 py-1.5 rounded-lg transition">📂</button>` : ''}
                    </div>
                </div>
                <div class="h-1.5 bg-gray-800 rounded-full overflow-hidden">
                    <div class="h-full rounded-full ${color}" style="width: ${pct}%"></div>
                </div>
                <div class="flex justify-between text-[9px] text-gray-600 mt-1">
                    <span>Total: ${dev.total || '?'}</span>
                    <span>Used: ${dev.used || '?'}</span>
                    <span>Free: ${dev.free || '?'}</span>
                    <span>${pct}%</span>
                </div>
            `;
            container.appendChild(div);
        });
        
        if (!hasExternal) {
            container.innerHTML += '<div class="p-4 bg-amber-900/10 rounded-xl border border-amber-500/20 text-center"><p class="text-[11px] text-amber-400">💡 Colokkan USB HDD/SSD untuk opsi penyimpanan eksternal</p></div>';
        }
        
        // Refresh explorer
        explorerGoTo(activePath);
        
    } catch(e) {
        console.error('[Storage] Error:', e);
    }
}

async function setStorage(path) {
    try {
        const res = await fetch('<%= base_path %>/api/storage/set', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ path })
        });
        const data = await res.json();
        if (data.success) {
            showModal('✅ Penyimpanan rekaman dialihkan ke:\n\n' + path + '\n\nStreaming akan restart otomatis.');
            refreshStorage();
        } else {
            showModal('❌ Gagal: ' + (data.error || 'Unknown error'), 'error');
        }
    } catch(e) {
        showModal('❌ Gagal: ' + e.message, 'error');
    }
}

async function explorerGoTo(dirPath) {
    currentExplorerPath = dirPath;
    document.getElementById('explorerPath').innerText = dirPath;
    document.getElementById('explorerPathInput').value = dirPath;
    
    try {
        const res = await fetch('<%= base_path %>/api/storage/explore', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ path: dirPath })
        });
        const data = await res.json();
        if (!data.success) return;
        
        const container = document.getElementById('explorerItems');
        container.innerHTML = '';
        
        if (data.parent) {
            const up = document.createElement('div');
            up.className = 'p-3 hover:bg-gray-700/30 cursor-pointer transition flex items-center gap-3 text-gray-400';
            up.innerHTML = '<span class="text-lg">📂</span><span class="text-xs font-medium">.. (Kembali)</span>';
            up.onclick = () => explorerGoTo(data.parent);
            container.appendChild(up);
        }
        
        (data.items || []).forEach(item => {
            const div = document.createElement('div');
            div.className = 'p-3 hover:bg-gray-700/30 transition flex items-center justify-between group';
            
            const icon = item.isDirectory ? '📁' : '📄';
            const size = item.isDirectory ? '' : '<span class="text-[10px] text-gray-600">' + (item.sizeFormatted || '') + '</span>';
            
            div.innerHTML = `
                <div class="flex items-center gap-3 flex-1 min-w-0 cursor-pointer" onclick="${item.isDirectory ? `explorerGoTo('${item.path}')` : ''}">
                    <span class="text-lg">${icon}</span>
                    <div class="min-w-0">
                        <div class="text-xs text-white truncate font-medium">${item.name}</div>
                        <div class="text-[9px] text-gray-500">${item.mtime ? new Date(item.mtime).toLocaleString('id-ID') : ''} ${size}</div>
                    </div>
                </div>
                <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition">
                    ${item.isDirectory ? `
                        <button onclick="explorerGoTo('${item.path}')" class="text-[10px] bg-gray-700 hover:bg-gray-600 text-gray-300 px-2 py-1 rounded-lg transition">📂 Buka</button>
                        <button onclick="setStorage('${item.path}')" class="text-[10px] bg-emerald-700 hover:bg-emerald-600 text-white px-2 py-1 rounded-lg transition">📁 Pilih</button>
                    ` : ''}
                </div>
            `;
            container.appendChild(div);
        });
        
    } catch(e) {
        console.error('[Explorer] Error:', e);
    }
}

function explorerGoUp() {
    const parent = currentExplorerPath.split('/').slice(0, -1).join('/') || '/';
    explorerGoTo(parent);
}

function setCurrentAsStorage() {
    const path = currentExplorerPath;
    showModal('📁 Gunakan folder ini sebagai penyimpanan rekaman?\n\n' + path, 'confirm', () => {
        setStorage(path);
    });
}

// Init
document.addEventListener('DOMContentLoaded', function() {
    refreshStorage();
});
</script>

<%- include('partials/admin_footer') %>