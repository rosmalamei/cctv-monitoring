                { key: 'vip', label: 'VIP', color: 'bg-amber-900/40 text-amber-400 border-amber-500/20', icon: '📹📼📊' },
                { key: 'vvip', label: 'VVIP', color: 'bg-amber-900/50 text-amber-300 border-amber-500/30', icon: '📹📼📊🏆' },
                { key: 'pemerintahan', label: 'PEMERINTAHAN', color: 'bg-cyan-900/40 text-cyan-400 border-cyan-500/20', icon: '📹📼📊🏛️' },
                { key: 'admin', label: 'ADMIN', color: 'bg-emerald-900/40 text-emerald-400 border-emerald-500/20', icon: '🔒🔑📹📼💰🤖' }
            ];
            %>
            <% levelMeta.forEach(function(meta) { %>
            <div class="<%= meta.color %> rounded-xl border p-3 text-center cursor-pointer hover:scale-105 transition-transform" onclick="toggleLevelDetail('<%= meta.key %>')">
                <div class="text-lg mb-1"><%= meta.icon %></div>
                <div class="text-[9px] font-black uppercase tracking-widest"><%= meta.label %></div>
            </div>
