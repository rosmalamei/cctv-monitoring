            icon: 'bg-gradient-to-br from-amber-600 to-amber-800',
            template: 'rtsp://{username}:{password}@{ip}:{port}/live/ch00_{channel}',
            defaults: { port: 554, channel: 0 },
            description: 'ch00_0 = Main Stream, ch00_1 = Sub Stream',
            tips: 'AVTech DVR umumnya menggunakan port 554'
        },
        xiaomi: {
            name: 'Xiaomi / Yi',
            icon: 'bg-gradient-to-br from-orange-500 to-orange-700',
            template: 'rtsp://{username}:{password}@{ip}:{port}/ch0_{stream}.264',
            defaults: { port: 554, stream: 0 },
            description: 'ch0_0 = HD Stream, ch0_1 = SD Stream',
            tips: 'Xiaomi/Yi camera: Aktifkan "Stream" di aplikasi Mi Home'
        },
        ezviz: {
            name: 'EZVIZ (APK)',
            icon: 'bg-gradient-to-br from-emerald-600 to-emerald-800',
            template: 'rtsp://{username}:{password}@{ip}:{port}/live/ch0',
            defaults: { port: 554 },
            description: 'EZVIZ Cloud Camera via RTSP',
            tips: 'Aktifkan "RTSP" di aplikasi EZVIZ: Settings > LAN Settings. Username & password dari akun EZVIZ Anda'
        },
        imou: {
            name: 'Imou (APK)',
            icon: 'bg-gradient-to-br from-blue-500 to-blue-700',
            template: 'rtsp://{username}:{password}@{ip}:{port}/live/ch0',
            defaults: { port: 554 },
            description: 'Imou Camera - buatan Dahua',
            tips: 'Aktifkan RTSP di aplikasi Imou: Profile > Settings > LAN Settings'
        },
        v380: {
            name: 'V380 (APK)',
            icon: 'bg-gradient-to-br from-pink-600 to-pink-800',
            template: 'rtsp://{username}:{password}@{ip}:{port}/live/ch0',
            defaults: { port: 554 },
            description: 'V380 WiFi Camera via RTSP',
            tips: 'V380: Cek IP kamera di aplikasi V380. Default username: admin'
        },
        wanscam: {
            name: 'Wanscam (APK)',
            icon: 'bg-gradient-to-br from-red-600 to-red-800',
            template: 'rtsp://{username}:{password}@{ip}:{port}/onvif1',
            defaults: { port: 554 },
            description: 'Wanscam WiFi Camera via ONVIF',
            tips: 'Wanscam: Gunakan ONVIF port 8899 untuk beberapa model'
        },
        tengfei: {
            name: 'Tengfei (APK)',
            icon: 'bg-gradient-to-br from-gray-600 to-gray-800',
            template: 'rtsp://{username}:{password}@{ip}:{port}/live/ch0',
            defaults: { port: 554 },
            description: 'Tengfei WiFi Camera via RTSP',
            tips: 'Tengfei: Cek IP melalui aplikasi, default user: admin'
        },
        spc: {
            name: 'SPC',
            icon: 'bg-gradient-to-br from-red-700 to-red-900',
            template: 'rtsp://{username}:{password}@{ip}:{port}/Streaming/Channels/{channel}01',
            defaults: { port: 554, channel: 1 },
            description: 'SPC DVR 4/8/16 channel. Channel 1=kamera1, channel2=kamera2, dst. SPC banyak yang berbasis Hikvision.',
            tips: 'SPC: Pastikan fitur RTSP diaktifkan. Untuk DVR 4 channel, ubah angka channel sesuai kamera yang ingin ditambahkan.'
        },
        tiandy: {
            name: 'Tiandy',
            icon: 'bg-gradient-to-br from-cyan-700 to-cyan-900',
            template: 'rtsp://{username}:{password}@{ip}:{port}/live/ch0',
            defaults: { port: 554 },
            description: 'Tiandy IP Camera via RTSP',
            tips: 'Tiandy: Aktifkan RTSP di menu Network > RTSP Settings.'
        },
        glenz: {
            name: 'Glenz',
            icon: 'bg-gradient-to-br from-amber-700 to-amber-900',
            template: 'rtsp://{username}:{password}@{ip}:{port}/live/ch0',
            defaults: { port: 554 },
            description: 'Glenz/HDW WiFi Camera via RTSP',
            tips: 'Glenz: Cek IP kamera di aplikasi HDW. Default user: admin'
        },
        generic: {
            name: 'Kustom / Manual',
            icon: 'bg-gradient-to-br from-gray-500 to-gray-700',
            template: 'rtsp://{username}:{password}@{ip}:{port}/',
            defaults: { port: 554 },
            description: 'URL RTSP kustom. Sesuaikan dengan merek kamera Anda.',
            tips: 'Jika merek Anda tidak terdaftar, masukkan URL RTSP manual di atas.'
        }
    };

    let selectedBrand = null;

    // ========== BRAND SELECTION ==========
    document.querySelectorAll('.brand-card').forEach(card => {
        card.addEventListener('click', function() {
            document.querySelectorAll('.brand-card').forEach(c => c.classList.remove('selected'));
            this.classList.add('selected');
            selectedBrand = this.dataset.brand;
            
            // Enable continue button
            document.getElementById('continueStep1').disabled = false;
            document.getElementById('continueStep1').className = 'bg-emerald-600 hover:bg-emerald-500 text-white font-bold py-3 px-10 rounded-xl shadow-lg shadow-emerald-900/20 transition transform active:scale-95';
            document.getElementById('continueStep1').onclick = goToStep2;
        });
    });

    // Brand Search
    document.getElementById('brandSearch').addEventListener('input', function() {
        const term = this.value.toLowerCase();
        document.querySelectorAll('.brand-card').forEach(card => {
            const search = (card.dataset.search || '').toLowerCase();
            const match = search.includes(term);
            card.style.display = match ? '' : 'none';
        });
    });

    // ========== STEP NAVIGATION ==========
    function goToStep2() {
        if (!selectedBrand) return;
        
        const info = BRAND_INFO[selectedBrand];
        document.getElementById('formBrand').value = selectedBrand;
        document.getElementById('selectedBrandName').textContent = info.name;
        document.getElementById('selectedBrandDesc').textContent = info.description;
        
        // Brand info detail
        document.getElementById('brandInfoDetail').innerHTML = `
            <p><strong class="text-white">Merek:</strong> ${info.name}</p>
            <p><strong class="text-white">Port Default:</strong> ${info.defaults.port}</p>
            <p><strong class="text-white">Template URL:</strong></p>
            <code class="block bg-gray-950 p-2 rounded-lg text-[10px] text-emerald-400 mt-1 break-all font-mono">${info.template}</code>
            <p class="mt-2 text-amber-400"><strong>Tips:</strong> ${info.tips}</p>
        `;
        
        // Set default port
        document.getElementById('formPort').value = info.defaults.port;
        
        document.getElementById('step1-content').classList.add('hidden');
        document.getElementById('step2-content').classList.remove('hidden');
        
        // Update steps
        document.getElementById('step1-num').className = 'step-number completed';
        document.getElementById('step2-num').className = 'step-number active';
        
        // Generate URL
        generateUrl();
        
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function backToStep1() {
        selectedBrand = null;
        document.querySelectorAll('.brand-card').forEach(c => c.classList.remove('selected'));
        
        document.getElementById('step1-content').classList.remove('hidden');
        document.getElementById('step2-content').classList.add('hidden');
        
        document.getElementById('step1-num').className = 'step-number active';
        document.getElementById('step2-num').className = 'step-number inactive';
        document.getElementById('step3-num').className = 'step-number inactive';
        
        // Reset test result
        document.getElementById('testResult').classList.add('hidden');
        
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // ========== URL GENERATOR ==========
    function generateUrl() {
        if (!selectedBrand) return;
        
        const info = BRAND_INFO[selectedBrand];
        const ip = document.getElementById('formIp').value || '192.168.1.100';
        const port = document.getElementById('formPort').value || info.defaults.port;
        const username = document.getElementById('formUsername').value || 'admin';
        const password = document.getElementById('formPassword').value || 'password';
        const channel = document.getElementById('formChannel').value || 1;
        const streamType = document.getElementById('formStreamType').value === 'main' ? 'main' : 'sub';
        
        let url = info.template;
        
        // Build params with defaults
        const params = {
            username: encodeURIComponent(username),
            password: encodeURIComponent(password),
            ip: ip,
            port: port,
            channel: channel,
            stream: streamType === 'main' ? 'main' : 'sub',
            subtype: streamType === 'main' ? 0 : 1
        };
        
        // Replace placeholders
        Object.keys(info.defaults).forEach(key => {
            if (params[key] === undefined) {
                params[key] = info.defaults[key];
            }
        });
        
        Object.keys(params).forEach(key => {
            url = url.replace(new RegExp(`\\{${key}\\}`, 'g'), params[key]);
        });
        
        document.getElementById('generatedUrl').value = url;
        document.getElementById('urlDescription').textContent = info.description;
    }

    // Auto generate on input change
    ['formIp', 'formPort', 'formUsername', 'formPassword', 'formChannel', 'formStreamType'].forEach(id => {
        document.getElementById(id).addEventListener('input', generateUrl);
        document.getElementById(id).addEventListener('change', generateUrl);
    });

    function copyGeneratedUrl() {
        const url = document.getElementById('generatedUrl').value;
        if (!url || url.includes('password')) {
            showModal('Lengkapi form konfigurasi terlebih dahulu', 'error');
            return;
        }
        navigator.clipboard.writeText(url).then(() => {
            showModal('URL RTSP berhasil disalin!');
        });
    }

    // ========== TEST CONNECTION ==========
    async function testRtspConnection() {
        const url = document.getElementById('generatedUrl').value;
        if (!url || url.includes('192.168.1.100')) {
            showModal('Lengkapi IP Address dan kredensial terlebih dahulu', 'error');
            return;
        }
        
        const testBtn = document.getElementById('testBtn');
        const testText = document.getElementById('testBtnText');
        const resultDiv = document.getElementById('testResult');
        
        testBtn.disabled = true;
        testBtn.classList.add('testing-active');
        testText.textContent = 'Menguji...';
        resultDiv.classList.add('hidden');
        
        try {
            const res = await fetch('<%= base_path %>/api/dvr/test-rtsp', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ url, brand: selectedBrand })
            });
            const data = await res.json();
            
            resultDiv.classList.remove('hidden');
            
            if (data.success) {
                resultDiv.className = 'mt-6 p-4 rounded-xl border bg-emerald-900/20 border-emerald-500/30';
                resultDiv.innerHTML = `
                    <div class="flex items-center gap-2 text-emerald-400 font-bold">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        Koneksi Berhasil!
                    </div>
                    <p class="text-xs text-gray-400 mt-1">${data.message || 'Kamera dapat dijangkau.'}</p>
                    ${data.latency ? `<p class="text-[10px] text-gray-500 mt-1">Latency: ${data.latency}ms</p>` : ''}
                    ${data.info ? `<pre class="text-[10px] text-gray-500 mt-2 bg-gray-950 p-2 rounded-lg">${JSON.stringify(data.info, null, 2)}</pre>` : ''}
                `;
            } else {
                resultDiv.className = 'mt-6 p-4 rounded-xl border bg-rose-900/20 border-rose-500/30';
                resultDiv.innerHTML = `
                    <div class="flex items-center gap-2 text-rose-400 font-bold">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        Koneksi Gagal
                    </div>
                    <p class="text-xs text-gray-400 mt-1">${data.message || 'Tidak dapat terhubung ke kamera. Periksa IP, port, dan kredensial.'}</p>
                `;
            }
        } catch (e) {
            resultDiv.className = 'mt-6 p-4 rounded-xl border bg-rose-900/20 border-rose-500/30';
            resultDiv.innerHTML = `
                <div class="flex items-center gap-2 text-rose-400 font-bold">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    Error Koneksi
                </div>
                <p class="text-xs text-gray-400 mt-1">Gagal menghubungi server: ${e.message}</p>
            `;
        } finally {
            testBtn.disabled = false;
            testBtn.classList.remove('testing-active');
            testText.textContent = 'Test Koneksi';
        }
    }

    // ========== SUBMIT FORM ==========
    document.getElementById('dvrConfigForm').onsubmit = async (e) => {
        e.preventDefault();
        
        const url = document.getElementById('generatedUrl').value;
        if (!url || url.includes('192.168.1.100')) {
            showModal('Lengkapi IP Address dengan benar', 'error');
            return;
        }
        
        const saveBtn = document.getElementById('saveBtn');
        saveBtn.disabled = true;
        saveBtn.innerHTML = '<span class="animate-spin">⟳</span> Menyimpan...';
        
        const formData = new URLSearchParams();
        formData.append('nama', document.getElementById('formNama').value);
        formData.append('lokasi', document.getElementById('formLokasi').value);
        formData.append('url_rtsp', url);
        formData.append('level', document.getElementById('formLevel').value);
        formData.append('camera_type', 'rtsp');
        
        try {
            const res = await fetch('<%= base_path %>/admin/camera/add', {
                method: 'POST',
                body: formData
            });
            
            if (res.ok) {
                showModal('✅ Kamera berhasil ditambahkan!');
                setTimeout(() => {
                    window.location.href = '<%= base_path %>/admin/cameras';
                }, 1500);
            } else {
                const err = await res.text();
                showModal('Gagal menyimpan: ' + err, 'error');
            }
        } catch (err) {
            showModal('Kesalahan koneksi: ' + err.message, 'error');
        } finally {
            saveBtn.disabled = false;
            saveBtn.innerHTML = '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4"></path></svg> Simpan Kamera';
        }
    };
</script>

<%- include('partials/admin_footer') %>