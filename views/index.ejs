    <script id="cameras-data" type="application/json"><%- JSON.stringify(cameras) %></script>
    <script>
        const cameras = JSON.parse(document.getElementById('cameras-data').textContent);
        const basePath = '<%= base_path %>';
        const hlsPort = '<%= (typeof mediamtx !== "undefined" ? mediamtx.hls_port : "8856") %>';
        const hlsBase = '<%= hlsBaseUrl %>';
        const userStatus = JSON.parse('<%- typeof userStatus !== "undefined" ? userStatus : JSON.stringify({isAdmin:false,isCustomer:false}) %>');
        
        let selectedCameraIds = [];
        let viewMode = 'live';
        let hlsInstances = {};
        let map = null;

        // --- Embed Camera Helper ---
        function generateEmbedHtml(camera) {
            if (!camera.embed_url) return '<div class="text-red-500">No embed URL</div>';
            
            const embedType = camera.embed_type || detectEmbedType(camera.embed_url);
            
            if (embedType === 'youtube') {
                let videoId = '';
                const url = camera.embed_url;
                if (url.includes('youtube.com/watch?v=')) {
                    videoId = url.split('v=')[1]?.split('&')[0];
                } else if (url.includes('youtube.com/embed/')) {
                    videoId = url.split('embed/')[1]?.split('?')[0];
                } else if (url.includes('youtu.be/')) {
                    videoId = url.split('youtu.be/')[1]?.split('?')[0];
                }
                if (videoId) {
                    return `<iframe src="https://www.youtube.com/embed/${videoId}?autoplay=1&mute=1&controls=1" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen class="w-full h-full"></iframe>`;
                }
                return `<iframe src="${camera.embed_url}" frameborder="0" allowfullscreen class="w-full h-full"></iframe>`;
            } else if (embedType === 'hls') {
                // Return only video element, script init will be called separately
                return `<video id="embed-hls-${camera.id}" class="w-full h-full" controls autoplay muted></video>`;
            }
            
            // Default iframe
            return `<iframe src="${camera.embed_url}" frameborder="0" allowfullscreen class="w-full h-full"></iframe>`;
        }
        
        function initEmbedHls(cameraId, embedUrl) {
            const video = document.getElementById(`embed-hls-${cameraId}`);
            if (!video) return;
            
            if (typeof Hls !== 'undefined' && Hls.isSupported()) {
                const hls = new Hls({ enableWorker: true, lowLatencyMode: true });
                hls.loadSource(embedUrl);
                hls.attachMedia(video);
                hls.on(Hls.Events.MANIFEST_PARSED, () => {
                    video.play().catch(e => console.log('Autoplay prevented:', e));
                });
                hls.on(Hls.Events.ERROR, (event, data) => {
                    console.error('HLS error:', data);
                });
                // Store reference for cleanup
                if (!window.hlsInstances) window.hlsInstances = {};
                window.hlsInstances[cameraId] = hls;
            } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
                video.src = embedUrl;
                video.addEventListener('loadedmetadata', () => {
                    video.play().catch(e => console.log('Autoplay prevented:', e));
                });
            } else {
                console.error('HLS not supported on this browser');
                video.insertAdjacentHTML('afterend', `<div class="text-red-500 text-center p-4">Browser tidak mendukung HLS. Silakan gunakan Chrome/Edge/Firefox.</div>`);
            }
        }
        
        function detectEmbedType(url) {
            if (!url) return 'custom';
            const urlLower = url.toLowerCase();
            if (urlLower.includes('youtube.com') || urlLower.includes('youtu.be')) return 'youtube';
            if (urlLower.includes('.m3u8')) return 'hls';
            if (urlLower.includes('.mpd')) return 'dash';
            return 'iframe';
        }

        // --- Core Functions ---
        function toggleCameraSelection(id) {
            const isMobile = window.innerWidth < 1024;
            if (isMobile) {
                selectedCameraIds = [String(id)];
                window.scrollTo({ top: 0, behavior: 'smooth' });
            } else {
                const idx = selectedCameraIds.indexOf(String(id));
                if (idx === -1) {
                    // No limit - allow unlimited cameras
                    selectedCameraIds.push(String(id));
                } else {
                    selectedCameraIds.splice(idx, 1);
                }
            }
            updateGrid();
            renderMobileList();
            saveState();
        }

        function updateGrid() {
            const grid = document.getElementById('live-grid');
            const count = selectedCameraIds.length;
            
            // Kill old streams
            Object.values(hlsInstances).forEach(h => h.destroy());
            hlsInstances = {};

            // Update Desktop UI sidebar
            document.querySelectorAll('#camera-list .camera-item').forEach(el => {
                const isSelected = selectedCameraIds.includes(el.dataset.id);
                el.classList.toggle('selected', isSelected);
                el.querySelector('.status-indicator').classList.toggle('hidden', !isSelected);
            });

            if (count === 0) {
                grid.className = 'live-grid grid-1 flex-1 min-h-0';
                grid.innerHTML = `<div class="empty-slot animate-fade-in flex-col gap-4">
                    <svg class="w-12 h-12 text-slate-900" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
                    <p class="text-xs font-black uppercase tracking-widest text-slate-800">Pilih Kamera</p>
                </div>`;
                return;
            }

            // Dynamic grid layout based on camera count
            let gridClass = 'grid-2'; // default
            if (count === 1) gridClass = 'grid-1';
            else if (count <= 4) gridClass = 'grid-4';
            else if (count <= 6) gridClass = 'grid-6';
            else if (count <= 9) gridClass = 'grid-9';
            else if (count <= 12) gridClass = 'grid-12';
            else gridClass = 'grid-16';
            
            grid.className = `live-grid ${gridClass} flex-1 min-h-0`;
            grid.innerHTML = selectedCameraIds.map(id => {
                const cam = cameras.find(c => String(c.id) === id);
                const isEmbed = cam && cam.camera_type === 'embed';
                
                return `
                <div class="video-wrapper group relative bg-black aspect-video rounded-none overflow-hidden border border-slate-900 flex items-center justify-center hover-lift" id="wrapper-${id}">
                    ${isEmbed ? `<div id="embed-${id}" class="w-full h-full"></div>` : `
                        <video id="video-${id}" class="w-full h-full object-cover lg:object-contain" playsinline autoplay muted></video>
                        <div class="video-loading" id="loading-${id}">
                            <div class="loading-spinner"></div>
                            <span class="text-xs text-slate-300 font-medium">Loading stream...</span>
                        </div>
                    `}
                    <!-- Label -->
                    <div class="absolute top-2 left-2 px-2 py-1 bg-slate-950/80 rounded text-[8px] font-black ${isEmbed ? 'text-cyan-400' : 'text-emerald-500'} uppercase border ${isEmbed ? 'border-cyan-500/20' : 'border-emerald-500/20'}">
                        ${cam?.nama || 'Camera'} ${isEmbed ? '🌐' : ''}
                        <div class="inline-block w-1.5 h-1.5 bg-current rounded-full pulse-dot ml-1"></div>
                    </div>
                    <!-- Controls Overlay -->
                    ${!isEmbed ? `<div class="absolute top-2 right-2 opacity-0 group-hover:opacity-100 lg:opacity-0 lg:group-hover:opacity-100 transition-opacity flex gap-2">
                        <button onclick="takeScreenshot('video-${id}', '${cam?.nama || 'Camera'}')" class="p-1.5 bg-slate-950/80 text-white rounded-lg hover:bg-blue-600 transition shadow-xl border border-white/10 btn-press" title="Screenshot">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                        </button>
                        <button onclick="toggleFullscreen('video-${id}')" class="p-1.5 bg-slate-950/80 text-white rounded-lg hover:bg-emerald-600 transition shadow-xl border border-white/10 btn-press" title="Fullscreen">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"></path></svg>
                        </button>
                    </div>` : ''}
                </div>
                `;
            }).join('');

            selectedCameraIds.forEach(id => {
                const cam = cameras.find(c => String(c.id) === id);
                if (!cam) return;

                const wrapper = document.getElementById(`wrapper-${id}`);
                
                if (!cam.isPlayable) {
                    wrapper.innerHTML = `
                        <div class="absolute inset-0 bg-slate-900/90 flex flex-col items-center justify-center p-6 text-center">
                            <svg class="w-10 h-10 text-rose-500 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                            <h4 class="text-[10px] font-black text-white uppercase tracking-widest mb-1">${cam.nama} TERKUNCI</h4>
                            <p class="text-[8px] text-slate-400 uppercase mb-4">Butuh Level ${cam.level.toUpperCase()}</p>
                            <a href="${basePath}/user/login" class="px-4 py-2 bg-emerald-600 text-white text-[8px] font-black rounded-lg uppercase tracking-widest">Upgrade / Login</a>
                        </div>
                    `;
                    return;
                }

                // Handle Embed Camera
                if (cam.camera_type === 'embed') {
                    const embedContainer = document.getElementById(`embed-${id}`);
                    if (embedContainer && cam.embed_url) {
                        const embedType = cam.embed_type || detectEmbedType(cam.embed_url);
                        embedContainer.innerHTML = generateEmbedHtml(cam);
                        // Initialize HLS if needed (script in innerHTML won't execute)
                        if (embedType === 'hls') {
                            setTimeout(() => initEmbedHls(cam.id, cam.embed_url), 100);
                        }
                    }
                    return;
                }

                // Handle RTSP Camera (existing logic)
                const v = document.getElementById(`video-${id}`);
                if (!v) {
                    console.warn(`Video element not found for camera ${id}`);
                    return;
                }

                const primaryUrl = `${hlsBase}/cam_${id}/index.m3u8`;
                const fallbackUrl = `${hlsBase}/cam_${id}_input/index.m3u8`;
                
                console.log(`Initializing HLS for camera ${id}:`, primaryUrl);
                
                // Destroy existing instance
                if (hlsInstances[id]) {
                    hlsInstances[id].destroy();
                    delete hlsInstances[id];
                }
                
                // Helper function to hide loading indicator
                const hideLoading = () => {
                    const loadingEl = document.getElementById(`loading-${id}`);
                    if (loadingEl && loadingEl.style.display !== 'none') {
                        loadingEl.style.opacity = '0';
                        setTimeout(() => {
                            loadingEl.style.display = 'none';
                        }, 300);
                    }
                };
                
                // Timeout to force hide loading after 15 seconds
                const loadingTimeout = setTimeout(() => {
                    console.warn(`Loading timeout for camera ${id}, hiding loading indicator`);
                    hideLoading();
                }, 15000);
                
                // Clear timeout when loading is hidden
                const originalHideLoading = hideLoading;
                const hideLoadingWithTimeout = () => {
                    clearTimeout(loadingTimeout);
                    originalHideLoading();
                };
                
                if (Hls.isSupported()) {
                    const hls = new Hls({
                        manifestLoadingMaxRetry: 2,
                        manifestLoadingRetryDelay: 1000,
                        debug: false
                    });
                    
                    hls.loadSource(primaryUrl);
                    hls.attachMedia(v);
                    
                    // Hide loading when video starts playing
                    v.addEventListener('playing', hideLoadingWithTimeout, { once: true });
                    v.addEventListener('canplay', hideLoadingWithTimeout, { once: true });
                    
                    hls.on(Hls.Events.MANIFEST_PARSED, () => {
                        console.log(`HLS manifest parsed for camera ${id}`);
                        v.play().catch(e => console.warn(`Play failed for camera ${id}:`, e));
                    });
                    
                    hls.on(Hls.Events.ERROR, (event, data) => {
                        console.error(`HLS error for camera ${id}:`, data.type, data.details);
                        if (data.fatal) {
                            console.log(`Trying fallback URL for camera ${id}:`, fallbackUrl);
                            hls.destroy();
                            
                            // Try fallback
                            const hlsFallback = new Hls({
                                manifestLoadingMaxRetry: 5,
                                manifestLoadingRetryDelay: 1000
                            });
                            hlsFallback.loadSource(fallbackUrl);
                            hlsFallback.attachMedia(v);
                            
                            // Add loading hide for fallback
                            v.addEventListener('playing', hideLoadingWithTimeout, { once: true });
                            
                            hlsFallback.on(Hls.Events.MANIFEST_PARSED, () => {
                                console.log(`Fallback HLS manifest parsed for camera ${id}`);
                                v.play().catch(() => {});
                            });
                            hlsInstances[id] = hlsFallback;
                        }
                    });
                    
                    hlsInstances[id] = hls;
                } else if (v.canPlayType('application/vnd.apple.mpegurl')) {
                    // Native HLS support (Safari, iOS)
                    console.log(`Using native HLS for camera ${id}`);
                    
                    v.addEventListener('playing', hideLoadingWithTimeout, { once: true });
                    v.addEventListener('canplay', hideLoadingWithTimeout, { once: true });
                    
                    v.src = primaryUrl;
                    v.play().catch(() => {
                        console.log(`Primary URL failed for camera ${id}, trying fallback`);
                        v.src = fallbackUrl;
                        v.play().catch(() => {
                            console.error(`Both URLs failed for camera ${id}`);
                        });
                    });
                }
            });
        }

        function renderMobileList() {
            const list = document.getElementById('mobile-camera-list');
            if (!list) return;
            
            const userLevel = (userStatus.customerLevel || 'umum').toLowerCase();
            
            list.innerHTML = cameras.map(cam => {
                const camLevel = (cam.level || 'umum').toLowerCase();
                let canView = userStatus.isAdmin || userLevel === 'admin';
                
                if (!canView) {
                    const hierarchy = ['umum', 'member', 'vip', 'vvip', 'pemerintahan'];
                    const uIdx = hierarchy.indexOf(userLevel);
                    const cIdx = hierarchy.indexOf(camLevel);
                    if (camLevel === 'umum') canView = true;
                    else if (uIdx !== -1 && cIdx !== -1 && uIdx >= cIdx) canView = true;
                }

                const isSelected = selectedCameraIds.includes(String(cam.id));
                const levelColors = {
                    'umum': 'text-emerald-500',
                    'member': 'text-blue-500',
                    'vip': 'text-purple-500',
                    'vvip': 'text-orange-500',
                    'pemerintahan': 'text-sky-400',
                    'admin': 'text-rose-500'
                };
                const colorClass = levelColors[camLevel] || 'text-slate-500';
                
                return `
                    <div class="p-4 glass-panel rounded-2xl border ${isSelected ? 'border-emerald-500 bg-emerald-500/10' : 'border-slate-800'} transition flex items-center justify-between" onclick="toggleCameraSelection('${cam.id}')">
                        <div class="flex items-center gap-4 flex-1 min-w-0">
                            <div class="w-10 h-10 bg-slate-950 rounded-xl flex items-center justify-center border border-slate-800 text-slate-700 relative">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
                                <!-- Status Badge -->
                                <div class="absolute -top-1 -right-1 w-3 h-3 rounded-full border-2 border-slate-950 camera-status-badge" data-camera-id="${cam.id}" title="Checking...">
