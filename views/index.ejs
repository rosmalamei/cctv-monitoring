        }

        function loadState() {
            const saved = localStorage.getItem('cctv_state');
            if (saved) {
                try {
                    const state = JSON.parse(saved);
                    // Validate camera IDs - only keep IDs that exist in current cameras list
                    const validIds = (state.selected || []).filter(id =>
                        cameras.some(cam => String(cam.id) === String(id))
                    );
                    selectedCameraIds = validIds;
                    console.log('Loaded state - Valid camera IDs:', validIds);
                    
                    if (state.mode) {
                        setTimeout(() => switchMode(state.mode), 100);
                    }
                    updateGrid();
                } catch (e) {
                    console.error('Failed to load state', e);
                    selectedCameraIds = []; // Reset to empty on error
                    updateGrid();
                }
            }
        }

