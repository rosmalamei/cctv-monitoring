<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#0f172a">
    <link rel="manifest" href="<%= base_path %>/manifest.json">
    <link rel="icon" href="<%= base_path %>/icon-192x192.png">
    <link rel="apple-touch-icon" href="<%= base_path %>/icon-192x192.png">
    <title><%= site.title %> - Live Dashboard</title>
    
    <!-- Fonts & CSS -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    animation: {
                        'marquee': 'marquee 30s linear infinite',
                        'fade-in': 'fadeIn 0.5s ease-out forwards',
                    },
                    keyframes: {
                        marquee: { '0%': { transform: 'translateX(100%)' }, '100%': { transform: 'translateX(-100%)' } },
                        fadeIn: { '0%': { opacity: '0', transform: 'translateY(10px)' }, '100%': { opacity: '1', transform: 'translateY(0)' } }
                    }
                }
            }
        }
    </script>
    <link rel="stylesheet" href="<%= base_path %>/css/modern.css">
    <link rel="stylesheet" href="<%= base_path %>/css/leaflet.css" />
    
    <style>
        /* Theme Variables */
        :root {
            --bg-primary: #020617;
            --bg-secondary: #0f172a;
            --bg-tertiary: #1e293b;
            --text-primary: #f8fafc;
            --text-secondary: #cbd5e1;
            --text-tertiary: #64748b;
            --border-color: rgba(255,255,255,0.05);
            --glass-bg: rgba(15, 23, 42, 0.6);
            --nav-bg: rgba(15, 23, 42, 0.9);
            --sidebar-bg: #0f172a;
            --video-border: #1e293b;
            --empty-slot-text: #1e293b;
            --scrollbar-thumb: #334155;
        }
        
        [data-theme="light"] {
            --bg-primary: #f8fafc;
            --bg-secondary: #ffffff;
            --bg-tertiary: #e2e8f0;
            --text-primary: #0f172a;
            --text-secondary: #334155;
            --text-tertiary: #64748b;
            --border-color: rgba(0,0,0,0.1);
            --glass-bg: rgba(255, 255, 255, 0.8);
            --nav-bg: rgba(255, 255, 255, 0.95);
            --sidebar-bg: #ffffff;
            --video-border: #cbd5e1;
            --empty-slot-text: #cbd5e1;
            --scrollbar-thumb: #cbd5e1;
        }
        
        * { transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease; }
        
        body { 
            background-color: var(--bg-primary); 
            color: var(--text-primary); 
            font-family: 'Inter', sans-serif; 
        }
        .glass-panel { 
            background: var(--glass-bg); 
            backdrop-filter: blur(12px); 
            border: 1px solid var(--border-color); 
        }
        .sidebar-scroll::-webkit-scrollbar { width: 4px; }
        .sidebar-scroll::-webkit-scrollbar-track { background: transparent; }
        .sidebar-scroll::-webkit-scrollbar-thumb { 
            background: var(--scrollbar-thumb); 
            border-radius: 10px; 
        }
        
        #live-display { height: 100%; display: flex; flex-direction: column; gap: 0.75rem; overflow: hidden; }
        .live-grid { display: grid; gap: 1rem; width: 100%; flex: 1; min-height: 0; transition: all 0.3s ease; }
        .grid-1 { grid-template-columns: 1fr; width: 100%; margin: 0 auto; }
        .grid-2 { grid-template-columns: 1fr 1fr; grid-template-rows: auto auto; width: 100%; }
        .grid-4 { grid-template-columns: repeat(2, 1fr); grid-template-rows: repeat(2, 1fr); }
        .grid-6 { grid-template-columns: repeat(3, 1fr); grid-template-rows: repeat(2, 1fr); }
        .grid-9 { grid-template-columns: repeat(3, 1fr); grid-template-rows: repeat(3, 1fr); }
        .grid-12 { grid-template-columns: repeat(4, 1fr); grid-template-rows: repeat(3, 1fr); }
        .grid-16 { grid-template-columns: repeat(4, 1fr); grid-template-rows: repeat(4, 1fr); }
        
        @media (min-width: 1024px) {
            .grid-1 { max-width: 100%; height: auto; aspect-ratio: 16/9; }
        }

        .video-wrapper { position: relative; width: 100%; height: 100%; aspect-ratio: 16 / 9; background: #000; border-radius: 0; overflow: hidden; border: 1px solid var(--video-border); box-shadow: 0 10px 30px -10px rgba(0,0,0,0.5); }
        .video-wrapper video { width: 100%; height: 100%; object-fit: cover; }
        @media (min-width: 1024px) {
            .video-wrapper video { object-fit: contain; }
        }
        
        .empty-slot { aspect-ratio: 16 / 9; background: #000; display: flex; align-items: center; justify-content: center; color: var(--empty-slot-text); border-radius: 0.75rem; border: 1px dashed var(--empty-slot-text); }
        .camera-item.selected { border-color: #10b981; background: rgba(16, 185, 129, 0.05); }
        
        .nav-tab { transition: all 0.2s ease; cursor: pointer; }
        .nav-tab:hover { background: rgba(255,255,255,0.05); }
        .nav-tab.active { background: #10b981; color: #020617; }
        .custom-div-icon { background: none !important; border: none !important; }
        .blink { animation: blink 1s steps(5, start) infinite; }
        @keyframes blink { to { visibility: hidden; } }
        
        /* Theme Toggle Button */
        .theme-toggle {
            position: relative;
            width: 36px;
            height: 36px;
            border-radius: 10px;
            background: var(--bg-tertiary);
            border: 1px solid var(--border-color);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
        }
        .theme-toggle:hover {
            transform: scale(1.05);
            box-shadow: 0 4px 12px rgba(16, 185, 129, 0.2);
        }
        .theme-toggle svg {
            width: 18px;
            height: 18px;
            color: var(--text-primary);
        }
        
        /* Theme-aware utility classes */
        .bg-primary { background-color: var(--bg-primary) !important; }
        .bg-secondary { background-color: var(--bg-secondary) !important; }
        .bg-tertiary { background-color: var(--bg-tertiary) !important; }
        .text-primary { color: var(--text-primary) !important; }
        .text-secondary { color: var(--text-secondary) !important; }
        .border-themed { border-color: var(--border-color) !important; }
        
        /* Override Tailwind for theme support */
        nav, aside, .glass-panel { background: var(--nav-bg) !important; }
        aside { background: var(--sidebar-bg) !important; }
        main { background: var(--bg-primary) !important; }
        
        [data-theme="light"] .bg-slate-900,
        [data-theme="light"] .bg-slate-900\/90,
        [data-theme="light"] .bg-slate-900\/95,
        [data-theme="light"] .bg-slate-900\/50 {
            background-color: rgba(255, 255, 255, 0.95) !important;
        }
        
        [data-theme="light"] .bg-slate-950,
        [data-theme="light"] .bg-slate-950\/50,
        [data-theme="light"] .bg-slate-950\/80 {
            background-color: rgba(248, 250, 252, 0.95) !important;
        }
        
        [data-theme="light"] .text-white,
        [data-theme="light"] .text-slate-200,
        [data-theme="light"] .text-slate-300 {
            color: #0f172a !important;
        }
        
        [data-theme="light"] .text-slate-400,
        [data-theme="light"] .text-slate-500 {
            color: #64748b !important;
        }
        
        [data-theme="light"] .text-slate-600,
        [data-theme="light"] .text-slate-700 {
            color: #475569 !important;
        }
        
        [data-theme="light"] .border-slate-700,
        [data-theme="light"] .border-slate-800 {
            border-color: #e2e8f0 !important;
        }
        
        [data-theme="light"] .shadow-2xl {
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15) !important;
        }
        
        /* ===== LOADING STATES & ANIMATIONS ===== */
        .loading-spinner {
            width: 40px;
            height: 40px;
            border: 3px solid rgba(16, 185, 129, 0.2);
            border-top: 3px solid #10b981;
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }
        
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
        
        .pulse-dot {
            animation: pulse-dot 2s infinite;
        }
        
        @keyframes pulse-dot {
            0%, 100% { opacity: 0.4; transform: scale(1); }
            50% { opacity: 1; transform: scale(1.1); }
        }
        
        /* Smooth hover effects */
        .hover-lift {
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        
        .hover-lift:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
        }
        
        /* Video loading overlay */
        .video-loading {
            position: absolute;
            inset: 0;
            background: rgba(0, 0, 0, 0.8);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 12px;
            z-index: 10;
        }
        
        /* Notification animations */
        @keyframes slideInRight {
            from { transform: translateX(100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }
        
        @keyframes slideOutRight {
            from { transform: translateX(0); opacity: 1; }
            to { transform: translateX(100%); opacity: 0; }
        }
        
        .notification-enter {
            animation: slideInRight 0.3s ease-out;
        }
        
        .notification-exit {
            animation: slideOutRight 0.3s ease-in;
        }
        
        /* Button press effect */
        .btn-press {
            transition: transform 0.1s ease;
        }
        
        .btn-press:active {
            transform: scale(0.95);
        }
        
        /* Sidebar collapse - simple reliable approach */
        #desktopSidebar.sidebar-closed {
            width: 0px !important;
            min-width: 0px !important;
            flex: 0 0 0px !important;
            overflow: hidden !important;
            padding: 0 !important;
            border-left: none !important;
            opacity: 0;
            margin-left: -420px;
        }
        #main-content-display.sidebar-closed {
            width: 100%;
        }
        #sidebarToggle.toggle-visible {
            display: flex !important;
        }
        #sidebarToggle.toggle-hidden {
            display: none !important;
        }
        
        /* Skeleton loading for camera items */
        .skeleton {
            background: linear-gradient(90deg, 
                var(--bg-tertiary) 25%, 
                rgba(255,255,255,0.05) 50%, 
                var(--bg-tertiary) 75%);
            background-size: 200% 100%;
            animation: skeleton-loading 1.5s infinite;
        }
        
        @keyframes skeleton-loading {
            0% { background-position: 200% 0; }
            100% { background-position: -200% 0; }
        }
    </style>
    
    <script src="<%= base_path %>/js/hls.min.js"></script>
    <script src="<%= base_path %>/js/leaflet.js"></script>
</head>
<body class="antialiased h-screen flex flex-col overflow-hidden">
    <%- include('partials/global_modal') %>

    <!-- Time Modal (Mobile) -->
    <div id="timeModal" onclick="closeTimeModal()" class="fixed inset-0 z-[110] hidden items-center justify-center p-4 bg-slate-950/80 backdrop-blur-md animate-fade-in">
        <div onclick="event.stopPropagation()" class="bg-slate-900 border border-slate-800 w-full max-w-xs rounded-3xl shadow-2xl overflow-hidden p-8 flex flex-col items-center gap-6">
            <div class="w-16 h-16 bg-emerald-500/10 rounded-2xl flex items-center justify-center">
                <svg class="w-8 h-8 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <div class="text-center">
                <h2 id="modal-clock" class="text-4xl font-black text-white tracking-tighter mb-1">00:00:00</h2>
                <p id="modal-date" class="text-[10px] font-bold text-slate-500 uppercase tracking-[0.2em]">01 Januari 2026</p>
            </div>
            <div class="w-full h-px bg-slate-800"></div>
            <div class="flex items-center gap-3">
                <div class="w-2 h-2 bg-emerald-500 rounded-full blink"></div>
                <span class="text-[10px] font-black text-slate-300 uppercase tracking-widest">Server Live Status</span>
            </div>
            <button onclick="closeTimeModal()" class="mt-4 w-full py-3 bg-slate-800 text-white text-[10px] font-black rounded-xl uppercase tracking-widest hover:bg-slate-700 transition">Tutup</button>
        </div>
    </div>

    <!-- Header Navigation -->
    <nav class="bg-slate-900/90 backdrop-blur-md border-b border-slate-800 flex-none h-14 lg:h-16 flex items-center z-50">
        <div class="w-full px-6 flex justify-between items-center gap-4">
            <!-- Brand -->
            <div class="flex items-center gap-4 flex-none cursor-pointer" onclick="window.location.href='<%= base_path %>/'">
                <div class="p-2 bg-emerald-500/20 rounded-lg hidden sm:block">
                    <svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
                    </svg>
                </div>
                <div>
                    <h1 class="text-sm font-black text-white tracking-tight uppercase leading-none"><%= site.title %></h1>
                    <p class="text-[9px] text-slate-500 font-bold uppercase tracking-widest mt-1"><%= site.footer %></p>
                </div>
            </div>

            <!-- Central Area (Desktop Only) -->
            <div class="hidden lg:flex flex-1 items-center justify-center gap-4">
                <div class="flex bg-slate-950 p-1 rounded-xl border border-slate-800">
                    <button onclick="switchMode('live')" id="tab-live" class="nav-tab active px-4 py-1.5 rounded-lg text-[10px] font-bold uppercase tracking-widest transition-all">Live</button>
                    <button onclick="switchMode('map')" id="tab-map" class="nav-tab px-4 py-1.5 rounded-lg text-[10px] font-bold text-slate-500 uppercase tracking-widest transition-all">Peta</button>
                </div>
                
                <!-- Grid Layout Presets -->
                <div class="flex bg-slate-950 p-1 rounded-xl border border-slate-800 gap-1">
                    <button onclick="setGridPreset(1)" class="px-3 py-1.5 rounded-lg text-[10px] font-bold text-slate-500 hover:text-white transition-all" title="1x1 Grid">1×1</button>
                    <button onclick="setGridPreset(4)" class="px-3 py-1.5 rounded-lg text-[10px] font-bold text-slate-500 hover:text-white transition-all" title="2x2 Grid">2×2</button>
                    <button onclick="setGridPreset(9)" class="px-3 py-1.5 rounded-lg text-[10px] font-bold text-slate-500 hover:text-white transition-all" title="3x3 Grid">3×3</button>
                    <button onclick="setGridPreset(16)" class="px-3 py-1.5 rounded-lg text-[10px] font-bold text-slate-500 hover:text-white transition-all" title="4x4 Grid">4×4</button>
                </div>
            </div>

            <!-- User/Weather -->
            <div class="flex items-center gap-2 lg:gap-3 flex-none">
                <!-- Desktop Clock & Status -->
                <div class="hidden lg:flex items-center gap-4 px-4 py-1.5 bg-slate-950/50 rounded-xl border border-slate-800/50 mr-2">
                    <div class="flex items-center gap-3">
                        <span id="topbar-clock" class="text-sm font-black text-white leading-none tracking-tighter">00:00:00</span>
                        <div class="w-px h-3 bg-slate-800"></div>
                        <span id="topbar-date" class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">01 Januari 2026</span>
                    </div>
                    <div class="h-6 w-px bg-slate-800"></div>
                    <div class="flex items-center gap-2">
                        <div class="w-2 h-2 bg-emerald-500 rounded-full blink"></div>
                        <span class="text-[9px] font-black text-slate-300 uppercase tracking-widest">Server Live</span>
                    </div>
                </div>

                <!-- Mobile Date Button -->
                <button onclick="showTimeModal()" class="lg:hidden flex items-center justify-center w-9 h-9 bg-slate-800 text-white rounded-xl border border-slate-700 shadow-lg active:scale-95 transition">
                    <span id="mobile-date-num" class="text-sm font-black"><%= new Date().getDate() %></span>
                </button>

                <div id="weather-widget" onclick="showWeatherDetail()" class="flex items-center gap-2 px-3 py-1.5 bg-slate-800/50 hover:bg-slate-700/50 cursor-pointer rounded-xl border border-slate-700/50 transition duration-300">
                    <span id="weather-icon" class="text-sm">🌤️</span>
                    <span id="weather-temp" class="text-xs font-bold text-slate-200">--°C</span>
                </div>
                
                <!-- Theme Toggle Button -->
                <button onclick="cycleTheme()" class="theme-toggle" title="Ganti Tema" id="theme-toggle-btn">
                    <svg id="theme-icon-dark" class="hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
                    </svg>
                    <svg id="theme-icon-light" class="hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
                    </svg>
                    <svg id="theme-icon-auto" class="hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
                    </svg>
                </button>
                
                <div class="hidden lg:flex items-center gap-1">
                    <a href="<%= base_path %>/archive" class="px-3 py-2 text-[10px] font-bold text-slate-400 hover:text-white uppercase tracking-widest transition">REKAMAN</a>
                    <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
                        <a href="<%= base_path %>/admin" class="px-3 py-2 text-[10px] font-bold text-emerald-400 hover:text-emerald-300 uppercase tracking-widest transition">Admin</a>
                        <a href="<%= base_path %>/user/logout" class="ml-1 px-3 py-1.5 bg-rose-500/10 text-rose-500 text-[10px] font-black rounded-lg hover:bg-rose-500 hover:text-white transition uppercase tracking-widest">Logout</a>
                    <% } else if (typeof isCustomer !== 'undefined' && isCustomer) { %>
                        <span onclick="window.location.href='<%= base_path %>/user/account'" class="hidden md:block text-[10px] font-bold text-emerald-400 hover:text-emerald-300 cursor-pointer uppercase tracking-widest mx-2"><%= (customer.full_name || customer.username).toUpperCase() %></span>
                        <a href="<%= base_path %>/user/logout" class="px-3 py-1.5 bg-rose-500/10 text-rose-500 text-[10px] font-black rounded-lg hover:bg-rose-500 hover:text-white transition uppercase tracking-widest">Logout</a>
                    <% } else { %>
                        <a href="<%= base_path %>/user/login" class="ml-2 px-4 py-2 bg-emerald-600 text-white text-[10px] font-black rounded-xl hover:bg-emerald-500 transition shadow-lg shadow-emerald-500/20 uppercase tracking-widest">Login</a>
                    <% } %>
                </div>
            </div>
        </div>
    </nav>

    <!-- Mobile Bottom Navigation -->
    <div class="lg:hidden fixed bottom-0 left-0 right-0 h-14 bg-slate-900/95 backdrop-blur-xl border-t border-slate-800 flex items-center justify-around px-2 z-[100] shadow-[0_-10px_30px_-15px_rgba(0,0,0,0.5)]">
        <button onclick="switchMode('live')" id="m-tab-live" class="flex flex-col items-center gap-1 px-3 group">
            <div class="p-1.5 rounded-xl bg-emerald-500 text-slate-950 shadow-lg shadow-emerald-500/20 transition-all duration-300" id="m-icon-live">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
            </div>
            <span class="text-[8px] font-black text-emerald-500 uppercase tracking-widest" id="m-text-live">Live</span>
        </button>
        
        <button onclick="switchMode('map')" id="m-tab-map" class="flex flex-col items-center gap-1 px-3 group">
            <div class="p-1.5 rounded-xl text-slate-500 transition-all duration-300" id="m-icon-map">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m6 13l5.447-2.724A1 1 0 0121 18.382V7.618a1 1 0 01-1.447-.894L15 9m-6 11V7m6 11V9"></path></svg>
            </div>
            <span class="text-[8px] font-black text-slate-500 uppercase tracking-widest" id="m-text-map">Peta</span>
        </button>

        <% if (typeof isCustomer !== 'undefined' && isCustomer || typeof isAdmin !== 'undefined' && isAdmin) { %>
            <a href="<%= base_path %>/archive" class="flex flex-col items-center gap-1 px-3 group">
                <div class="p-1.5 rounded-xl text-slate-500">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                </div>
                <span class="text-[8px] font-black text-slate-500 uppercase tracking-widest">Rekaman</span>
            </a>

            <button onclick="window.location.href='<%= base_path %>/user/account'" class="flex flex-col items-center gap-1 px-3 group">
                <div class="p-1.5 rounded-xl text-slate-500 transition-all duration-300" id="m-icon-account">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                </div>
                <span class="text-[8px] font-black text-slate-500 uppercase tracking-widest" id="m-text-account">Akun</span>
            </button>

            <button onclick="openReportModal()" class="flex flex-col items-center gap-1 px-3 group text-amber-500">
