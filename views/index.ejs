                                    <span class="text-[8px] text-slate-400 block uppercase font-bold">Suhu</span>
                                    <span class="text-[10px] font-black text-slate-700" id="pw-temp-${cam.id}">--</span>
                                </div>
                                <div class="bg-slate-50 p-1 rounded border border-slate-100">
                                    <span class="text-[8px] text-slate-400 block uppercase font-bold">Angin</span>
                                    <span class="text-[10px] font-black text-slate-700" id="pw-wind-${cam.id}">--</span>
                                </div>
                                <div class="bg-slate-50 p-1 rounded border border-slate-100">
                                    <span class="text-[8px] text-slate-400 block uppercase font-bold">Ombak</span>
