        document.getElementById('reportForm').onsubmit = async function(e) {
            e.preventDefault();
            const formData = new FormData(this);
            const data = Object.fromEntries(formData.entries());
            
            try {
                const res = await fetch(`${basePath}/api/reports/submit`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const result = await res.json();
                if (result.success) {
                    alert('Laporan berhasil dikirim. Terima kasih atas laporannya.');
                    closeReportModal();
                    this.reset();
                } else {
                    alert('Gagal mengirim laporan: ' + result.message);
                }
            } catch (e) {
                alert('Terjadi kesalahan saat mengirim laporan.');
            }
        };

        // --- Search Logic ---
        function filterCameras(term, listId = 'camera-list') {
            term = term.toLowerCase();
            const items = document.querySelectorAll(`#${listId} .camera-item, #${listId} .p-4.glass-panel`);
            items.forEach(item => {
                const name = (item.dataset.nama || item.querySelector('h4')?.textContent || '').toLowerCase();
                const location = (item.querySelector('p')?.textContent || '').toLowerCase();
                const level = (item.querySelector('span')?.textContent || '').toLowerCase();
                const matches = name.includes(term) || location.includes(term) || level.includes(term);
                item.classList.toggle('hidden', !matches);
            });
        }

        document.getElementById('camera-search')?.addEventListener('input', (e) => filterCameras(e.target.value, 'camera-list'));
        document.getElementById('mobile-search')?.addEventListener('input', (e) => filterCameras(e.target.value, 'mobile-camera-list'));

        function updateClock() {
            const now = new Date();
            const options = { timeZone: 'Asia/Jakarta', hour12: false, hour: '2-digit', minute: '2-digit', second: '2-digit' };
            const timeStr = now.toLocaleTimeString('en-GB', options);
            const dateStr = now.toLocaleDateString('id-ID', { timeZone: 'Asia/Jakarta', day: 'numeric', month: 'long', year: 'numeric' });
            
            const clockEl = document.getElementById('topbar-clock');
            const dateEl = document.getElementById('topbar-date');
            const mClockEl = document.getElementById('modal-clock');
            const mDateEl = document.getElementById('modal-date');
            
            if (clockEl) clockEl.textContent = timeStr;
            if (dateEl) dateEl.textContent = dateStr;
            if (mClockEl) mClockEl.textContent = timeStr;
            if (mDateEl) mDateEl.textContent = dateStr;
        }

        function showTimeModal() {
            document.getElementById('timeModal').classList.remove('hidden');
            document.getElementById('timeModal').classList.add('flex');
        }
        function closeTimeModal() {
            document.getElementById('timeModal').classList.add('hidden');
            document.getElementById('timeModal').classList.remove('flex');
        }

        setInterval(updateClock, 1000);
        updateClock();

        // ===== THEME MANAGEMENT =====
        const THEMES = ['dark', 'light', 'auto'];
        let currentThemeIndex = 0;
        
        function getSystemTheme() {
            return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }
        
        function applyTheme(theme) {
            const root = document.documentElement;
            const actualTheme = theme === 'auto' ? getSystemTheme() : theme;
            
            if (actualTheme === 'light') {
                root.setAttribute('data-theme', 'light');
            } else {
                root.removeAttribute('data-theme');
            }
            
            // Update theme color meta tag
            const metaThemeColor = document.querySelector('meta[name="theme-color"]');
            if (metaThemeColor) {
                metaThemeColor.setAttribute('content', actualTheme === 'light' ? '#f8fafc' : '#0f172a');
            }
            
            // Update icon visibility
            document.getElementById('theme-icon-dark').classList.toggle('hidden', theme !== 'dark');
            document.getElementById('theme-icon-light').classList.toggle('hidden', theme !== 'light');
            document.getElementById('theme-icon-auto').classList.toggle('hidden', theme !== 'auto');
            
            // Update button title
            const titles = {
                'dark': 'Mode: Gelap 🌙',
                'light': 'Mode: Terang ☀️',
                'auto': 'Mode: Otomatis 🌓'
            };
            document.getElementById('theme-toggle-btn').setAttribute('title', titles[theme]);
        }
        
        function cycleTheme() {
            currentThemeIndex = (currentThemeIndex + 1) % THEMES.length;
            const newTheme = THEMES[currentThemeIndex];
            localStorage.setItem('cctv_theme', newTheme);
            applyTheme(newTheme);
        }
        
        function initTheme() {
            const savedTheme = localStorage.getItem('cctv_theme') || 'dark';
            currentThemeIndex = THEMES.indexOf(savedTheme);
            if (currentThemeIndex === -1) currentThemeIndex = 0;
            applyTheme(THEMES[currentThemeIndex]);
            
            // Listen for system theme changes when in auto mode
            window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
                const currentTheme = THEMES[currentThemeIndex];
                if (currentTheme === 'auto') {
                    applyTheme('auto');
                }
            });
        }
        
        // Initialize theme immediately (before page load)
        initTheme();

        // ===== CAMERA STATUS MANAGEMENT =====
        let cameraStatusData = {};
        
        async function fetchCameraStatus() {
            try {
                const response = await fetch(`${basePath}/api/cameras/status`);
                const data = await response.json();
                
                if (data.success && data.cameras) {
                    cameraStatusData = data.cameras;
                    updateCameraStatusUI();
                }
            } catch (error) {
                console.error('Failed to fetch camera status:', error);
            }
        }
        
        // ===== SIDEBAR TOGGLE =====
        function toggleSidebar() {
            const sidebar = document.getElementById('desktopSidebar');
            const toggle = document.getElementById('sidebarToggle');
            const arrow = document.getElementById('sidebarArrow');
            
            const isClosed = sidebar.classList.contains('sidebar-closed');
            
            const mainContent = document.getElementById('main-content-display');
            
            if (!isClosed) {
                // Close sidebar
                sidebar.classList.add('sidebar-closed');
                if (mainContent) mainContent.classList.add('sidebar-closed');
                toggle.classList.remove('toggle-hidden');
                toggle.classList.add('toggle-visible');
                if (arrow) {
                    arrow.style.transform = 'rotate(0deg)';
                    arrow.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 5v14m7-7l-7 7-7-7"></path>';
                }
                localStorage.setItem('sidebar_collapsed', 'true');
            } else {
                // Open sidebar
                sidebar.classList.remove('sidebar-closed');
                if (mainContent) mainContent.classList.remove('sidebar-closed');
                toggle.classList.remove('toggle-visible');
                toggle.classList.add('toggle-hidden');
                if (arrow) {
                    arrow.style.transform = 'rotate(180deg)';
                    arrow.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M11 19l-7-7 7-7m8 14l-7-7 7-7"></path>';
                }
                localStorage.setItem('sidebar_collapsed', 'false');
            }
            
            // Trigger resize for map if visible
            setTimeout(() => {
                if (map) map.invalidateSize();
            }, 450);
        }
        
        // Load sidebar state on init
        function loadSidebarState() {
            const collapsed = localStorage.getItem('sidebar_collapsed');
            if (collapsed === 'true') {
                const sidebar = document.getElementById('desktopSidebar');
                const toggle = document.getElementById('sidebarToggle');
                const mainContent = document.getElementById('main-content-display');
                if (sidebar) sidebar.classList.add('sidebar-closed');
                if (mainContent) mainContent.classList.add('sidebar-closed');
                if (toggle) {
                    toggle.classList.remove('toggle-hidden');
                    toggle.classList.add('toggle-visible');
                }
            }
        }

        // Fetch status immediately and then every 30 seconds
        fetchCameraStatus();
        setInterval(fetchCameraStatus, 30000);
        
        // Update sidebar online/offline counts
        function updateCameraStatusUI() {
            // Count unique camera IDs to avoid double counting (desktop + mobile badges)
            const countedCameras = new Set();
            let onlineCount = 0;
            let offlineCount = 0;
            
            // Update all status badges (both desktop and mobile)
            document.querySelectorAll('.camera-status-badge').forEach(badge => {
                const cameraId = badge.getAttribute('data-camera-id');
                const status = cameraStatusData[cameraId];
                const innerDiv = badge.querySelector('div');
                
                if (status && status.online) {
                    innerDiv.className = 'w-full h-full rounded-full bg-emerald-500';
                    innerDiv.style.animation = 'none';
                    badge.setAttribute('title', 'Online');
                    if (!countedCameras.has(cameraId)) {
                        countedCameras.add(cameraId);
                        onlineCount++;
                    }
                } else if (status && !status.online) {
                    innerDiv.className = 'w-full h-full rounded-full bg-rose-500';
                    innerDiv.style.animation = 'none';
                    badge.setAttribute('title', 'Offline');
                    if (!countedCameras.has(cameraId)) {
                        countedCameras.add(cameraId);
                        offlineCount++;
                    }
                } else {
                    innerDiv.className = 'w-full h-full rounded-full bg-slate-600 animate-pulse';
                    badge.setAttribute('title', 'Checking...');
                }
            });
            
            // Update status text
            document.querySelectorAll('.camera-status-text').forEach(text => {
                const cameraId = text.getAttribute('data-camera-id');
                const status = cameraStatusData[cameraId];
                
                if (status && status.online) {
                    text.textContent = '• Online';
                    text.className = 'text-[7px] font-bold text-emerald-500 uppercase tracking-widest camera-status-text';
                } else if (status && !status.online) {
                    text.textContent = '• Offline';
                    text.className = 'text-[7px] font-bold text-rose-500 uppercase tracking-widest camera-status-text';
                } else {
                    text.textContent = '• Checking...';
                    text.className = 'text-[7px] font-bold text-slate-600 uppercase tracking-widest camera-status-text';
                }
            });
            
            // Update sidebar footer counts
            const onlineEl = document.getElementById('sidebarOnlineCount');
            const offlineEl = document.getElementById('sidebarOfflineCount');
            if (onlineEl) onlineEl.textContent = onlineCount;
            if (offlineEl) offlineEl.textContent = offlineCount;
            
            // Update mobile footer counts
            const mobileOnlineEl = document.getElementById('mobileOnlineCount');
            const mobileOfflineEl = document.getElementById('mobileOfflineCount');
            if (mobileOnlineEl) mobileOnlineEl.textContent = onlineCount;
            if (mobileOfflineEl) mobileOfflineEl.textContent = offlineCount;
        }

        // ===== KEYBOARD SHORTCUTS =====
        document.addEventListener('keydown', (e) => {
            // Ignore if user is typing in input fields
            if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.isContentEditable) {
                return;
            }
            
            switch(e.key.toLowerCase()) {
                case ' ': // Spacebar - Toggle play/pause for all videos
                    e.preventDefault();
                    const videos = document.querySelectorAll('video');
                    videos.forEach(video => {
                        if (video.paused) {
                            video.play().catch(() => {});
                        } else {
                            video.pause();
                        }
                    });
                    showNotification(videos.length > 0 ? '⏯️ Toggle play/pause' : 'ℹ️ Tidak ada video aktif', 'info');
                    break;
                    
                case 'f': // F - Fullscreen first video
                    e.preventDefault();
                    const firstVideo = document.querySelector('video');
                    if (firstVideo) {
                        toggleFullscreen(firstVideo.id);
                        showNotification('🔍 Fullscreen mode', 'info');
                    }
                    break;
                    
                case 's': // S - Screenshot first video
                    e.preventDefault();
                    const videoForScreenshot = document.querySelector('video');
                    if (videoForScreenshot) {
                        const cameraName = selectedCameraIds.length > 0 ? 
                            cameras.find(c => String(c.id) === selectedCameraIds[0])?.nama || 'Camera' : 
                            'Camera';
                        takeScreenshot(videoForScreenshot.id, cameraName);
                    } else {
                        showNotification('ℹ️ Tidak ada video untuk screenshot', 'info');
                    }
                    break;
                    
                case 'm': // M - Toggle between Live and Map
                    e.preventDefault();
                    const newMode = viewMode === 'live' ? 'map' : 'live';
                    switchMode(newMode);
                    showNotification(`🗺️ Mode: ${newMode === 'live' ? 'Live' : 'Peta'}`, 'info');
                    break;
                    
                case 't': // T - Toggle theme
                    e.preventDefault();
                    cycleTheme();
                    break;
                    
                case 'escape': // ESC - Clear selection
                    e.preventDefault();
                    selectedCameraIds = [];
                    updateGrid();
                    showNotification('🔄 Selection cleared', 'info');
                    break;
                    
                case '1':
                case '2':
                case '3':
                case '4':
                case '5':
                case '6':
                case '7':
                case '8':
                case '9':
                    // Number keys - Quick select camera
                    e.preventDefault();
                    const cameraIndex = parseInt(e.key) - 1;
                    if (cameras[cameraIndex]) {
                        const cameraId = String(cameras[cameraIndex].id);
                        if (!selectedCameraIds.includes(cameraId)) {
                            selectedCameraIds = [cameraId]; // Replace selection
                            updateGrid();
                            showNotification(`📹 ${cameras[cameraIndex].nama}`, 'success');
                        }
                    }
                    break;
                    
                case '?': // ? - Show help
                    e.preventDefault();
                    showKeyboardHelp();
                    break;
            }
        });
        
        function showKeyboardHelp() {
            const helpModal = document.createElement('div');
            helpModal.className = 'fixed inset-0 z-[200] flex items-center justify-center p-4 bg-slate-950/80 backdrop-blur-sm';
            helpModal.onclick = (e) => {
                if (e.target === helpModal) helpModal.remove();
            };
            
            helpModal.innerHTML = `
                <div class="bg-slate-900 border border-slate-800 rounded-2xl shadow-2xl max-w-md w-full p-6" onclick="event.stopPropagation()">
                    <div class="flex items-center justify-between mb-4">
                        <h3 class="text-lg font-bold text-white">⌨️ Keyboard Shortcuts</h3>
                        <button onclick="this.closest('.fixed').remove()" class="text-slate-400 hover:text-white">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                            </svg>
                        </button>
                    </div>
                    <div class="space-y-3 text-sm">
                        <div class="flex justify-between"><kbd class="px-2 py-1 bg-slate-800 rounded text-xs">Space</kbd><span class="text-slate-300">Play/Pause videos</span></div>
                        <div class="flex justify-between"><kbd class="px-2 py-1 bg-slate-800 rounded text-xs">F</kbd><span class="text-slate-300">Fullscreen</span></div>
                        <div class="flex justify-between"><kbd class="px-2 py-1 bg-slate-800 rounded text-xs">S</kbd><span class="text-slate-300">Screenshot</span></div>
                        <div class="flex justify-between"><kbd class="px-2 py-1 bg-slate-800 rounded text-xs">M</kbd><span class="text-slate-300">Toggle Live/Map</span></div>
                        <div class="flex justify-between"><kbd class="px-2 py-1 bg-slate-800 rounded text-xs">T</kbd><span class="text-slate-300">Toggle Theme</span></div>
                        <div class="flex justify-between"><kbd class="px-2 py-1 bg-slate-800 rounded text-xs">ESC</kbd><span class="text-slate-300">Clear selection</span></div>
                        <div class="flex justify-between"><kbd class="px-2 py-1 bg-slate-800 rounded text-xs">1-9</kbd><span class="text-slate-300">Quick select camera</span></div>
                        <div class="flex justify-between"><kbd class="px-2 py-1 bg-slate-800 rounded text-xs">?</kbd><span class="text-slate-300">Show this help</span></div>
                    </div>
                    <button onclick="this.closest('.fixed').remove()" class="mt-4 w-full py-2 bg-emerald-600 text-white rounded-lg font-bold hover:bg-emerald-500 transition">
                        Got it!
                    </button>
                </div>
            `;
            
            document.body.appendChild(helpModal);
        }

        // ===== GRID LAYOUT PRESETS =====
        function setGridPreset(maxCameras) {
            if (cameras.length === 0) {
                showNotification('ℹ️ Tidak ada kamera tersedia', 'info');
                return;
            }
            
            // Select first N cameras
            const availableCameras = cameras.filter(cam => cam.isPlayable !== false);
            const camerasToSelect = availableCameras.slice(0, maxCameras).map(cam => String(cam.id));
            
            if (camerasToSelect.length === 0) {
                showNotification('ℹ️ Tidak ada kamera yang dapat diakses', 'info');
                return;
            }
            
            selectedCameraIds = camerasToSelect;
            updateGrid();
            
            const gridNames = {
                1: '1×1',
                4: '2×2', 
                9: '3×3',
                16: '4×4'
            };
            
            showNotification(`📺 Grid ${gridNames[maxCameras]} (${camerasToSelect.length} kamera)`, 'success');
        }

        // ===== PERFORMANCE OPTIMIZATIONS =====
        
        // Lazy loading for video elements
        const videoObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const video = entry.target;
                    if (video.dataset.src && !video.src) {
                        video.src = video.dataset.src;
                        video.load();
                    }
                }
            });
        }, { threshold: 0.1 });
        
        // Debounced resize handler
        let resizeTimeout;
        window.addEventListener('resize', () => {
            clearTimeout(resizeTimeout);
            resizeTimeout = setTimeout(() => {
                if (map) {
                    map.invalidateSize();
                }
            }, 250);
        });
        
        // Memory cleanup for HLS instances
        function cleanupHlsInstances() {
            Object.keys(hlsInstances).forEach(id => {
                if (!selectedCameraIds.includes(id)) {
                    if (hlsInstances[id]) {
                        hlsInstances[id].destroy();
                        delete hlsInstances[id];
                    }
                }
            });
        }
        
        // Auto cleanup every 2 minutes
        setInterval(cleanupHlsInstances, 120000);
        
        // Visibility API - pause videos when tab is hidden
        document.addEventListener('visibilitychange', () => {
            const videos = document.querySelectorAll('video');
            if (document.hidden) {
                videos.forEach(video => {
                    video.dataset.wasPlaying = !video.paused;
                    video.pause();
                });
            } else {
                videos.forEach(video => {
                    if (video.dataset.wasPlaying === 'true') {
                        video.play().catch(() => {});
                    }
                });
            }
        });

        window.onload = () => { 
            renderMobileList(); 
            loadState();
            loadSidebarState();
            updateWeather();
            setInterval(updateWeather, 300000); // 5 minutes
        };
    </script>
    <script>
        (() => {
            const basePath = '<%= base_path %>' || '';
            if ('serviceWorker' in navigator) {
                window.addEventListener('load', () => {
                    navigator.serviceWorker.register(`${basePath}/sw.js`).catch(() => { });
                });
            }

            let deferredPrompt = null;
            const showBanner = () => {
                if (document.getElementById('pwa-install-banner')) return;
                const banner = document.createElement('div');
                banner.id = 'pwa-install-banner';
                banner.style.cssText = 'position:fixed;left:12px;right:12px;bottom:12px;z-index:9999;display:flex;gap:10px;align-items:center;justify-content:space-between;padding:12px 14px;background:rgba(2,6,23,0.95);border:1px solid rgba(148,163,184,0.25);border-radius:14px;color:#e2e8f0;font:700 12px/1.2 Inter, system-ui, sans-serif;';
                banner.innerHTML = '<div style="display:flex;flex-direction:column;gap:2px"><div style="font-weight:900;letter-spacing:.08em;text-transform:uppercase;font-size:10px;color:#94a3b8">Install</div><div>Pasang aplikasi untuk akses lebih cepat.</div></div><div style="display:flex;gap:8px;flex-shrink:0"><button id="pwa-install-btn" style="padding:8px 10px;border-radius:10px;background:#10b981;color:#020617;border:0;font-weight:900;font-size:12px;cursor:pointer">Install</button><button id="pwa-close-btn" style="padding:8px 10px;border-radius:10px;background:transparent;color:#94a3b8;border:1px solid rgba(148,163,184,0.35);font-weight:900;font-size:12px;cursor:pointer">Tutup</button></div>';
                document.body.appendChild(banner);
                document.getElementById('pwa-close-btn').onclick = () => banner.remove();
                document.getElementById('pwa-install-btn').onclick = async () => {
                    if (!deferredPrompt) return;
                    banner.remove();
                    deferredPrompt.prompt();
                    try { await deferredPrompt.userChoice; } catch { }
                    deferredPrompt = null;
                };
            };

            window.addEventListener('beforeinstallprompt', (e) => {
                e.preventDefault();
                deferredPrompt = e;
                showBanner();
            });

            window.addEventListener('appinstalled', () => {
                deferredPrompt = null;
                const b = document.getElementById('pwa-install-banner');
                if (b) b.remove();
            });
        })();
    </script>
</body>
</html>
