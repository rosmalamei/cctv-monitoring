        // ===== SCREENSHOT FUNCTIONALITY =====
        function takeScreenshot(videoId, cameraName) {
            const video = document.getElementById(videoId);
            if (!video) {
                showNotification('❌ Video tidak ditemukan', 'error');
                return;
            }

            try {
                // Create canvas
                const canvas = document.createElement('canvas');
                const ctx = canvas.getContext('2d');
                
                // Set canvas size to video size
                canvas.width = video.videoWidth || video.clientWidth;
                canvas.height = video.videoHeight || video.clientHeight;
                
                // Draw video frame to canvas
                ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
                
                // Add timestamp and camera name overlay
                const now = new Date();
                const timestamp = now.toLocaleString('id-ID', { 
                    timeZone: 'Asia/Jakarta',
                    year: 'numeric',
                    month: '2-digit', 
                    day: '2-digit',
                    hour: '2-digit',
                    minute: '2-digit',
                    second: '2-digit'
                });
                
                // Overlay styling
                ctx.fillStyle = 'rgba(0, 0, 0, 0.7)';
                ctx.fillRect(10, canvas.height - 60, canvas.width - 20, 50);
                
                ctx.fillStyle = '#ffffff';
                ctx.font = 'bold 16px Inter, sans-serif';
                ctx.fillText(cameraName, 20, canvas.height - 35);
                
                ctx.fillStyle = '#10b981';
                ctx.font = '14px Inter, sans-serif';
                ctx.fillText(timestamp, 20, canvas.height - 15);
                
                // Convert to blob and download
                canvas.toBlob((blob) => {
                    const url = URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url;
                    a.download = `${cameraName.replace(/[^a-zA-Z0-9]/g, '_')}_${now.getTime()}.png`;
                    document.body.appendChild(a);
                    a.click();
                    document.body.removeChild(a);
                    URL.revokeObjectURL(url);
                    
                    showNotification('📸 Screenshot berhasil disimpan', 'success');
                }, 'image/png', 0.9);
                
            } catch (error) {
                console.error('Screenshot error:', error);
                showNotification('❌ Gagal mengambil screenshot', 'error');
            }
        }

        // ===== NOTIFICATION SYSTEM =====
        function showNotification(message, type = 'info') {
            // Remove existing notification
            const existing = document.getElementById('notification');
            if (existing) {
                existing.classList.add('notification-exit');
                setTimeout(() => existing.remove(), 300);
            }
            
            // Create notification
            const notification = document.createElement('div');
            notification.id = 'notification';
            notification.className = `fixed top-4 right-4 z-[200] px-4 py-3 rounded-xl shadow-2xl border backdrop-blur-md max-w-sm notification-enter`;
            
            // Style based on type
            if (type === 'success') {
                notification.className += ' bg-emerald-500/90 border-emerald-400 text-white';
            } else if (type === 'error') {
                notification.className += ' bg-rose-500/90 border-rose-400 text-white';
            } else if (type === 'warning') {
                notification.className += ' bg-amber-500/90 border-amber-400 text-white';
            } else {
                notification.className += ' bg-slate-900/90 border-slate-700 text-slate-200';
            }
            
            notification.innerHTML = `
                <div class="flex items-center gap-3">
                    <span class="text-sm font-bold">${message}</span>
                    <button onclick="closeNotification(this)" class="ml-auto text-white/70 hover:text-white transition btn-press">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </button>
                </div>
            `;
            
            document.body.appendChild(notification);
            
            // Auto remove after 4 seconds
            setTimeout(() => {
                if (notification.parentElement) {
                    closeNotification(notification.querySelector('button'));
                }
            }, 4000);
        }
        
        function closeNotification(button) {
            const notification = button.closest('#notification');
            if (notification) {
                notification.classList.remove('notification-enter');
                notification.classList.add('notification-exit');
                setTimeout(() => notification.remove(), 300);
            }
        }

