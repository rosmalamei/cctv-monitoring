                                </div>
                                <div class="bg-slate-50 p-1 rounded border border-slate-100">
                                    <span class="text-[8px] text-slate-400 block uppercase font-bold">Arah</span>
                                    <span class="text-[10px] font-black text-slate-700" id="pw-wave-dir-${cam.id}">--</span>
                                </div>
                                <div class="bg-slate-50 p-1 rounded border border-slate-100">
                                    <span class="text-[8px] text-slate-400 block uppercase font-bold">Periode</span>
                                    <span class="text-[10px] font-black text-slate-700" id="pw-wave-period-${cam.id}">--</span>
                                </div>
                                <div class="bg-slate-50 p-1 rounded border border-slate-100">
                                    <span class="text-[8px] text-slate-400 block uppercase font-bold">Peak</span>
                                    <span class="text-[10px] font-black text-slate-700" id="pw-wave-peak-${cam.id}">--</span>
                                </div>
                                <div class="bg-slate-50 p-1 rounded border border-slate-100">
                                    <span class="text-[8px] text-slate-400 block uppercase font-bold">SST</span>
                                    <span class="text-[10px] font-black text-slate-700" id="pw-sst-${cam.id}">--</span>
                                </div>
                                <div class="bg-slate-50 p-1 rounded border border-slate-100">
                                    <span class="text-[8px] text-slate-400 block uppercase font-bold">Arus</span>
                                    <span class="text-[10px] font-black text-slate-700" id="pw-current-${cam.id}">--</span>
                                </div>
                                <div class="bg-slate-50 p-1 rounded border border-slate-100">
                                    <span class="text-[8px] text-slate-400 block uppercase font-bold">Pasang</span>
                                    <span class="text-[10px] font-black text-slate-700" id="pw-sea-${cam.id}">--</span>
                                </div>
                            </div>
                        </div>
                    `;

                    const marker = L.marker([cam.lat, cam.lng], { icon: markerIcon })
                        .addTo(map)
                        .bindPopup(popupContent, { maxWidth: 260 });

                    marker.on('popupopen', async () => {
                        const isYoutube = embedUrl.includes('youtube.com') || embedUrl.includes('youtu.be') || embedUrl.includes('youtube-nocookie.com');
                        const isEmbedHls = cam.camera_type === 'embed' && !isYoutube && (cam.embed_type === 'hls' || embedUrl.toLowerCase().includes('m3u8') || embedUrl.toLowerCase().includes('/hls/') || cam.embed_type !== 'iframe');
                        
                        // Skip HLS initialization for non-HLS embed cameras (YouTube/iframe handled via HTML)
                        if (cam.camera_type === 'embed' && !isEmbedHls) {
                            const loadingEl = document.getElementById(`popup-loading-${cam.id}`);
                            if (loadingEl) loadingEl.classList.add('hidden');
                            return;
                        }
                        
                        // 1. Setup Video Stream
                        const videoEl = document.getElementById(`popup-video-${cam.id}`);
                        const loadingEl = document.getElementById(`popup-loading-${cam.id}`);
                        if (!videoEl) {
                            if (loadingEl) loadingEl.classList.add('hidden');
                            return;
                        }
                        const primaryUrl = isEmbedHls ? cam.embed_url : `${hlsBase}/cam_${cam.id}/index.m3u8`;
                        const fallbackUrl = isEmbedHls ? null : `${hlsBase}/cam_${cam.id}_input/index.m3u8`;
                        
                        function startHls(url, isFallback = false) {
                            if (marker.hlsInstance) { marker.hlsInstance.destroy(); marker.hlsInstance = null; }
                            
                            if (window.Hls && Hls.isSupported()) {
                                const hls = new Hls({ manifestLoadingMaxRetry: isFallback ? 5 : 2 });
                                hls.loadSource(url);
                                hls.attachMedia(videoEl);
                                hls.on(Hls.Events.MANIFEST_PARSED, () => {
                                    videoEl.play().catch(e => {
                                        setTimeout(() => {
                                            if (loadingEl) loadingEl.classList.add('hidden');
                                        }, 1000);
                                    });
                                    if (loadingEl) loadingEl.classList.add('hidden');
                                });
                                hls.on(Hls.Events.ERROR, (event, data) => {
                                    if (data.fatal) {
                                        if (!isFallback && fallbackUrl) {
                                            console.warn(`Popup HLS error, trying fallback for camera ${cam.id}`);
                                            startHls(fallbackUrl, true);
                                        } else {
                                            console.error(`Popup HLS failed for camera ${cam.id}`);
                                            if (loadingEl) loadingEl.classList.add('hidden');
                                            if (videoEl) {
                                                videoEl.insertAdjacentHTML('afterend', 
                                                    '<div class="absolute inset-0 flex items-center justify-center bg-slate-900/80 text-rose-500 text-xs font-bold uppercase tracking-widest">Stream Error</div>');
                                            }
                                        }
                                    }
                                });
                                marker.hlsInstance = hls;
                            } else if (videoEl.canPlayType('application/vnd.apple.mpegurl')) {
                                videoEl.src = url;
                                videoEl.addEventListener('loadedmetadata', () => {
                                    videoEl.play().catch(e => {});
                                    if (loadingEl) loadingEl.classList.add('hidden');
                                });
                                videoEl.addEventListener('error', () => {
                                    if (!isFallback && fallbackUrl) {
                                        startHls(fallbackUrl, true);
                                    } else {
                                        if (loadingEl) loadingEl.classList.add('hidden');
                                    }
                                });
                            } else {
                                console.error('HLS not supported in this browser for popup');
                                if (loadingEl) loadingEl.classList.add('hidden');
                            }
                        }
                        
                        startHls(primaryUrl);

                        // 2. Fetch Localized Weather
                        const weatherDiv = document.getElementById(`popup-weather-${cam.id}`);
                        if (!weatherDiv || !weatherDiv.classList.contains('hidden')) return; 

                        try {
                            const res = await fetch(`${basePath}/api/weather?lat=${cam.lat}&lng=${cam.lng}`);
                            const data = await res.json();
                            if (data && data.success) {
                                document.getElementById(`pw-temp-${cam.id}`).textContent = data.current ? `${Math.round(data.current.temperature_2m)}°C` : '-';
                                document.getElementById(`pw-wind-${cam.id}`).textContent = data.current ? `${data.current.wind_speed_10m} km/h` : '-';
                                
                                const hourPart = new Intl.DateTimeFormat('en-US', { timeZone: 'Asia/Jakarta', hour: 'numeric', hour12: false }).format(new Date());
                                const nowIdx = parseInt(hourPart, 10);

                                const mh = data.marine_hourly || {};
                                const pick = (arr) => {
                                    if (!Array.isArray(arr) || arr.length === 0) return null;
                                    const v = arr[nowIdx];
                                    if (v !== null && v !== undefined) return v;
                                    const v0 = arr[0];
                                    if (v0 !== null && v0 !== undefined) return v0;
                                    return null;
                                };

                                const waveHeight = pick(mh.wave_height);
                                document.getElementById(`pw-wave-${cam.id}`).textContent = (waveHeight !== null && waveHeight !== undefined) ? `${Number(waveHeight).toFixed(1)}m` : '-';

                                const waveDir = pick(mh.wave_direction);
                                document.getElementById(`pw-wave-dir-${cam.id}`).textContent = (waveDir !== null && waveDir !== undefined) ? `${Math.round(Number(waveDir))}°` : '-';

                                const wavePeriod = pick(mh.wave_period);
                                document.getElementById(`pw-wave-period-${cam.id}`).textContent = (wavePeriod !== null && wavePeriod !== undefined) ? `${Number(wavePeriod).toFixed(1)}s` : '-';

                                const wavePeak = pick(mh.wave_peak_period);
                                document.getElementById(`pw-wave-peak-${cam.id}`).textContent = (wavePeak !== null && wavePeak !== undefined) ? `${Number(wavePeak).toFixed(1)}s` : '-';

                                const sst = pick(mh.sea_surface_temperature);
                                document.getElementById(`pw-sst-${cam.id}`).textContent = (sst !== null && sst !== undefined) ? `${Number(sst).toFixed(1)}°C` : '-';

                                const curVel = pick(mh.ocean_current_velocity);
                                const curDir = pick(mh.ocean_current_direction);
                                if (curVel !== null && curVel !== undefined) {
                                    document.getElementById(`pw-current-${cam.id}`).textContent = `${Number(curVel).toFixed(1)} km/h${(curDir !== null && curDir !== undefined) ? ` • ${Math.round(Number(curDir))}°` : ''}`;
                                } else {
                                    document.getElementById(`pw-current-${cam.id}`).textContent = '-';
                                }

                                const sea = pick(mh.sea_level_height_msl);
                                document.getElementById(`pw-sea-${cam.id}`).textContent = (sea !== null && sea !== undefined) ? `${Number(sea).toFixed(2)} m` : '-';
                                weatherDiv.classList.remove('hidden');
                            }
                        } catch(e) {}
                    });

                    marker.on('popupclose', () => {
                        if (marker.hlsInstance) {
                            marker.hlsInstance.destroy();
                            marker.hlsInstance = null;
                        }
                    });
                }
            });

            if (mapBounds.length > 0) {
                map.fitBounds(mapBounds, { padding: [30, 30], maxZoom: 16 });
            }

            // Trigger resize to fix grey tiles issue
            setTimeout(() => map.invalidateSize(), 300);
        }

