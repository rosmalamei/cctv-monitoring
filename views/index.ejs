                                    ${!canView ? '<svg class="w-3 h-3 text-rose-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"></path></svg>' : ''}
                                </div>
                                <p class="text-[9px] text-sky-400 font-bold uppercase truncate tracking-wide">${cam.lokasi || 'Live'}</p>
                                <div class="flex items-center gap-2 mt-1">
                                    <span class="text-[7px] font-black ${colorClass} uppercase tracking-widest">
                                        ${camLevel === 'umum' ? 'UMUM' : camLevel === 'member' ? 'MEMBER' : camLevel.toUpperCase()}
                                    </span>
                                    <span class="text-[7px] font-bold text-slate-500 uppercase tracking-widest camera-status-text" data-camera-id="${cam.id}">
                                        • Checking...
                                    </span>
                                </div>
                            </div>
                        </div>
                        ${isSelected ? '<div class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse ml-3"></div>' : ''}
                    </div>
                `;
            }).join('');
        }

        // --- Utils ---
        function switchMode(mode) {
            viewMode = mode;
            
            // Update Desktop Tabs
            const tLive = document.getElementById('tab-live');
            const tMap = document.getElementById('tab-map');
            if (tLive) tLive.classList.toggle('active', mode === 'live');
            if (tMap) tMap.classList.toggle('active', mode === 'map');
            if (tLive) tLive.classList.toggle('text-slate-500', mode !== 'live');
            if (tMap) tMap.classList.toggle('text-slate-500', mode !== 'map');

            // Update Mobile Bottom Bar
            const mIconLive = document.getElementById('m-icon-live');
            const mTextLive = document.getElementById('m-text-live');
            const mIconMap = document.getElementById('m-icon-map');
            const mTextMap = document.getElementById('m-text-map');

            if (mode === 'live') {
                if (mIconLive) mIconLive.className = 'p-2 rounded-xl bg-emerald-500 text-slate-950 shadow-lg shadow-emerald-500/20 transition-all duration-300';
                if (mTextLive) mTextLive.className = 'text-[9px] font-black text-emerald-500 uppercase tracking-widest';
                if (mIconMap) mIconMap.className = 'p-2 rounded-xl text-slate-500 transition-all duration-300';
                if (mTextMap) mTextMap.className = 'text-[9px] font-black text-slate-500 uppercase tracking-widest';
            } else {
                if (mIconLive) mIconLive.className = 'p-2 rounded-xl text-slate-500 transition-all duration-300';
                if (mTextLive) mTextLive.className = 'text-[9px] font-black text-slate-500 uppercase tracking-widest';
                if (mIconMap) mIconMap.className = 'p-2 rounded-xl bg-emerald-500 text-slate-950 shadow-lg shadow-emerald-500/20 transition-all duration-300';
                if (mTextMap) mTextMap.className = 'text-[9px] font-black text-emerald-500 uppercase tracking-widest';
            }

            document.getElementById('live-display').classList.toggle('hidden', mode === 'map');
            document.getElementById('map-display').classList.toggle('hidden', mode === 'live');
            
            const mMain = document.getElementById('main-content-display');
            const mList = document.getElementById('mobile-list-container');
            
            if (window.innerWidth < 1024) {
                if (mode === 'map') {
                    mMain.classList.replace('flex-none', 'flex-1');
                    mMain.style.height = 'calc(100vh - 144px)'; // Adjust for header and bottom bar
                    if (mList) mList.classList.add('hidden');
                } else {
                    mMain.classList.replace('flex-1', 'flex-none');
                    mMain.style.height = '';
                    if (mList) mList.classList.remove('hidden');
                }
            }
            
            saveState();
            if (mode === 'map') {
                initMap();
                setTimeout(() => map.invalidateSize(), 300);
            }
        }

        function initMap() {
            if (map) return;
            // Default view (will be overridden if there are cameras)
            map = L.map('map', { zoomControl: false }).setView([-0.8173, 103.4616], 14);
            
            // Define base layers
            const streetLayer = L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
                attribution: '&copy; OpenStreetMap contributors &copy; CARTO',
                maxZoom: 19
            });
            
            const satelliteLayer = L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', {
                attribution: '&copy; Esri &mdash; Source: Esri, i-cubed, USDA, USGS, AEX, GeoEye, Getmapping, Aerogrid, IGN, IGP, UPR-EGP, and the GIS User Community',
                maxZoom: 19
            });
            
            const hybridLayer = L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', {
                attribution: '&copy; Esri',
                maxZoom: 19
            });
            
            const labelsLayer = L.tileLayer('https://{s}.basemaps.cartocdn.com/light_only_labels/{z}/{x}/{y}{r}.png', {
                attribution: '&copy; CARTO',
                maxZoom: 19
            });
            
            // Add default layer
            streetLayer.addTo(map);
            
            // Create layer control
            const baseLayers = {
                "🗺️ Peta Standar": streetLayer,
                "🛰️ Satelit": satelliteLayer,
                "🌍 Hybrid": L.layerGroup([hybridLayer, labelsLayer])
            };
            
            // Add layer control with custom styling
            const layerControl = L.control.layers(baseLayers, null, {
                position: 'topright',
                collapsed: false
            }).addTo(map);
            
            // Custom styling for layer control
            setTimeout(() => {
                const controlContainer = document.querySelector('.leaflet-control-layers');
                if (controlContainer) {
                    controlContainer.style.background = 'rgba(15, 23, 42, 0.95)';
                    controlContainer.style.backdropFilter = 'blur(12px)';
                    controlContainer.style.border = '1px solid rgba(255, 255, 255, 0.1)';
                    controlContainer.style.borderRadius = '12px';
                    controlContainer.style.padding = '12px';
                    controlContainer.style.boxShadow = '0 10px 30px -10px rgba(0, 0, 0, 0.5)';
                    
                    const labels = controlContainer.querySelectorAll('label');
                    labels.forEach(label => {
                        label.style.color = '#f8fafc';
                        label.style.fontSize = '11px';
                        label.style.fontWeight = '600';
                        label.style.padding = '6px 0';
                        label.style.cursor = 'pointer';
                        label.style.display = 'flex';
                        label.style.alignItems = 'center';
                        label.style.gap = '8px';
                    });
                    
                    const inputs = controlContainer.querySelectorAll('input[type="radio"]');
                    inputs.forEach(input => {
                        input.style.accentColor = '#10b981';
                        input.style.cursor = 'pointer';
                    });
                }
            }, 100);
            
            const mapBounds = [];
            
            cameras.forEach(cam => {
                if (cam.lat && cam.lng) {
                    mapBounds.push([cam.lat, cam.lng]);
                    const markerIcon = L.divIcon({
                        className: 'custom-div-icon',
                        html: `
                            <div class="relative group">
                                <div class="w-8 h-8 bg-emerald-500 rounded-2xl flex items-center justify-center text-white shadow-lg border-2 border-white ring-2 ring-emerald-500/20 transform -rotate-45 hover:rotate-0 transition-all duration-500">
                                    <svg class="w-5 h-5 transform rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"></path>
                                    </svg>
                                </div>
                                <div class="absolute -bottom-1 -right-1 w-2 h-2 bg-white rounded-full flex items-center justify-center shadow-md">
                                    <div class="w-1 h-1 bg-emerald-500 rounded-full animate-ping"></div>
                                </div>
                            </div>
                        `,
                        iconSize: [32, 32],
                        iconAnchor: [16, 16]
                    });
                    
                    const isEmbedCam = cam.camera_type === 'embed';
                    const embedUrl = cam.embed_url || '';
                    const isYoutube = embedUrl.includes('youtube.com') || embedUrl.includes('youtu.be') || embedUrl.includes('youtube-nocookie.com');
                    const isEmbedHls = isEmbedCam && !isYoutube && (cam.embed_type === 'hls' || embedUrl.toLowerCase().includes('m3u8') || embedUrl.toLowerCase().includes('/hls/') || cam.embed_type !== 'iframe');
                    let popupVideoHtml = '';
                    
                    if (isEmbedCam && (embedUrl.includes('youtube.com') || embedUrl.includes('youtu.be'))) {
                        // YouTube embed
                        let videoId = '';
                        if (embedUrl.includes('youtube.com/watch?v=')) {
                            videoId = embedUrl.split('v=')[1]?.split('&')[0];
                        } else if (embedUrl.includes('youtube.com/embed/')) {
                            videoId = embedUrl.split('embed/')[1]?.split('?')[0];
                        } else if (embedUrl.includes('youtu.be/')) {
                            videoId = embedUrl.split('youtu.be/')[1]?.split('?')[0];
                        }
                        if (videoId) {
                            popupVideoHtml = `<iframe src="https://www.youtube.com/embed/${videoId}?autoplay=1&mute=1&controls=0" frameborder="0" allow="autoplay; encrypted-media" allowfullscreen class="w-full h-full"></iframe>`;
                        } else {
                            popupVideoHtml = `<iframe src="${embedUrl}" frameborder="0" allowfullscreen class="w-full h-full"></iframe>`;
                        }
                    } else if (isEmbedHls) {
                        // Embed HLS camera - use video with HLS (just like RTSP)
                        popupVideoHtml = `
                            <video id="popup-video-${cam.id}" class="w-full h-full object-cover" muted playsinline preload="none"></video>
                            <div class="absolute inset-0 flex items-center justify-center pointer-events-none" id="popup-loading-${cam.id}">
                                <span class="w-4 h-4 border-2 border-emerald-500 border-t-transparent rounded-full animate-spin"></span>
                            </div>
                        `;
                    } else if (isEmbedCam && embedUrl) {
                        // Other embed URL (generic iframe, DASH, etc.)
                        popupVideoHtml = `<iframe src="${embedUrl}" frameborder="0" allowfullscreen class="w-full h-full"></iframe>`;
                    } else {
                        // RTSP camera - use video with HLS
                        popupVideoHtml = `
                            <video id="popup-video-${cam.id}" class="w-full h-full object-cover" muted playsinline preload="none"></video>
                            <div class="absolute inset-0 flex items-center justify-center pointer-events-none" id="popup-loading-${cam.id}">
                                <span class="w-4 h-4 border-2 border-emerald-500 border-t-transparent rounded-full animate-spin"></span>
                            </div>
                        `;
                    }
                    
                    const popupContent = `
                        <div class="p-2 min-w-[220px]">
                            <b class="text-slate-900 text-xs block mb-1">${cam.nama}</b>
                            <p class="text-[10px] text-slate-500 mb-2 border-b border-slate-200 pb-2">${cam.lokasi || 'Kuala Tungkal'}</p>
                            
                            <div class="w-full bg-slate-900 rounded-lg overflow-hidden mb-2 aspect-video relative group cursor-pointer" onclick="selectFromMap('${cam.id}')" title="Klik untuk lihat penuh">
                                ${popupVideoHtml}
                                <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition flex items-center justify-center pointer-events-none">
                                    <span class="text-[10px] font-bold text-white uppercase tracking-widest">Lihat Penuh</span>
                                </div>
                            </div>

                            <div class="weather-data hidden mb-1 grid grid-cols-3 gap-1 text-center" id="popup-weather-${cam.id}">
